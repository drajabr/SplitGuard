<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Style Selector="TextBox">
    <Setter Property="MinHeight" Value="{DynamicResource CtrlH}" />
    <Setter Property="Padding" Value="8,3" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="FontSize" Value="{DynamicResource Fs13}" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{DynamicResource FieldBorderBrush}" />
  </Style>
  <!-- "mono" is now just the compact value size; the family follows the chosen UI font. -->
  <Style Selector="TextBox.mono">
    <Setter Property="FontSize" Value="{DynamicResource Fs12}" />
  </Style>
  <!-- Tiny numeric boxes (metric, counts, timeout): slim padding so 2-3 digits fit
       in half the normal width. -->
  <Style Selector="TextBox.num">
    <Setter Property="Padding" Value="2,3" />
    <Setter Property="MinWidth" Value="0" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
  </Style>
  <Style Selector="TextBox.error">
    <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
  </Style>
  <!-- Inline "+" add box: a square button-like affordance that becomes an input on focus. -->
  <Style Selector="TextBox.addbox">
    <Setter Property="MinWidth" Value="{DynamicResource CtrlH}" />
    <Setter Property="Height" Value="{DynamicResource CtrlH}" />
    <Setter Property="Padding" Value="4,3" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{DynamicResource FieldBorderBrush}" />
  </Style>
  <Style Selector="TextBox.addbox:focus">
    <Setter Property="MinWidth" Value="120" />
    <Setter Property="Watermark" Value="" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
  </Style>

  <Style Selector="ToolTip">
    <Setter Property="FontSize" Value="{DynamicResource Fs12}" />
  </Style>

  <Style Selector="Button">
    <Setter Property="MinHeight" Value="{DynamicResource CtrlH}" />
    <Setter Property="Padding" Value="10,3" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="FontSize" Value="{DynamicResource Fs12}" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
  </Style>
  <Style Selector="Button.icon">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="4" />
    <Setter Property="MinHeight" Value="0" />
  </Style>
  <Style Selector="Button.chipx">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="1" />
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="Button.link">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="4,2" />
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
  </Style>
  <!-- Header action buttons (Add / Settings): subtle, pill-ish. -->
  <Style Selector="Button.hdr">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="8,3" />
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="CornerRadius" Value="5" />
  </Style>
  <Style Selector="Button.hdr:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource ItemBrush}" />
  </Style>

  <!-- Floating Add control: centered at the page bottom, borderless, icon over label. -->
  <Style Selector="Button.addbtn">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="10,4" />
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="CornerRadius" Value="6" />
  </Style>
  <Style Selector="Button.addbtn:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource ItemBrush}" />
  </Style>

  <!-- Segmented option buttons inside the Settings popover. -->
  <Style Selector="Button.seg">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{DynamicResource FieldBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="8,2" />
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="FontSize" Value="{DynamicResource Fs12}" />
  </Style>
  <Style Selector="Button.seg.sel">
    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource OnAccentBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
  </Style>

  <!-- Connect toggle: a big square power button. Outlined when off, accent-filled when on. -->
  <Style Selector="ToggleButton.conn">
    <Setter Property="Width" Value="40" />
    <Setter Property="Height" Value="40" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{DynamicResource FieldBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Foreground" Value="{DynamicResource DotBrush}" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>
  <Style Selector="ToggleButton.conn:checked /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
  </Style>
  <Style Selector="ToggleButton.conn:checked">
    <Setter Property="Foreground" Value="{DynamicResource OnAccentBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
  </Style>

  <Style Selector="Button.danger">
    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
  </Style>
  <Style Selector="Button.danger.armed">
    <Setter Property="FontWeight" Value="Bold" />
  </Style>
  <Style Selector="Button.primary">
    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource OnAccentBrush}" />
  </Style>

  <Style Selector="Border.card">
    <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="ClipToBounds" Value="True" />
  </Style>
  <Style Selector="Border.card.editing">
    <Setter Property="BorderBrush" Value="{DynamicResource AccentDimBrush}" />
  </Style>
  <!-- Value chips (addresses, allowed IPs, domains): outlined like the input boxes.
       MinHeight (not Height): long values wrap to more lines and the chip grows,
       keeping the × inside the box, top-right. -->
  <Style Selector="Border.item">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{DynamicResource FieldBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Padding" Value="8,3" />
    <Setter Property="MinHeight" Value="{DynamicResource CtrlH}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="Border.item > DockPanel">
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="Border.card">
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="Border.card.editing">
    <Setter Property="Cursor" Value="Arrow" />
  </Style>

  <!-- Single clipped region below the header. Its Height is animated by the code-behind
       between the collapsed-detail height and the expanded height, so the card grows and
       shrinks in one smooth motion (no overlap, no fade). -->
  <Style Selector="Border.body">
    <Setter Property="ClipToBounds" Value="True" />
  </Style>

  <!-- Bottom status bar: slides/fades in and out with the same easing. -->
  <Style Selector="Border.statusbar">
    <Setter Property="ClipToBounds" Value="True" />
    <Setter Property="MaxHeight" Value="0" />
    <Setter Property="Opacity" Value="0" />
    <Setter Property="Transitions">
      <Transitions>
        <DoubleTransition Property="MaxHeight" Duration="0:0:0.20" Easing="CubicEaseOut" />
        <DoubleTransition Property="Opacity" Duration="0:0:0.20" Easing="CubicEaseOut" />
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="Border.statusbar.shown">
    <Setter Property="MaxHeight" Value="80" />
    <Setter Property="Opacity" Value="1" />
  </Style>

  <Style Selector="Border.peerblock">
    <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="4" />
  </Style>

  <Style Selector="TextBlock.lbl">
    <Setter Property="FontSize" Value="{DynamicResource Fs115}" />
    <Setter Property="Opacity" Value="{DynamicResource DimOpacity}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="TextBlock.mono">
    <Setter Property="FontSize" Value="{DynamicResource Fs12}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="TextBlock.muted">
    <Setter Property="FontSize" Value="{DynamicResource Fs12}" />
    <Setter Property="Opacity" Value="{DynamicResource DimOpacity}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="TextBlock.glyph">
    <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
    <Setter Property="FontSize" Value="{DynamicResource Fs14}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="TextBlock.pinicon">
    <Setter Property="Opacity" Value="0.45" />
  </Style>
  <Style Selector="TextBlock.pinicon.pinned">
    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    <Setter Property="Opacity" Value="1" />
  </Style>
  <!-- Pinned but its tunnel is down: filled pin in the warning color. -->
  <Style Selector="TextBlock.pinicon.pinned.suspended">
    <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
  </Style>
  <!-- Failover role badge on a peer block: outlined chip, accent when active. -->
  <Style Selector="Border.rolebadge">
    <Setter Property="BorderBrush" Value="{DynamicResource FieldBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Padding" Value="6,1" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="Border.rolebadge > TextBlock">
    <Setter Property="Opacity" Value="0.7" />
  </Style>
  <Style Selector="Border.rolebadge.active">
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
  </Style>
  <Style Selector="Border.rolebadge.active > TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    <Setter Property="Opacity" Value="1" />
  </Style>
  <Style Selector="TextBlock.accent">
    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    <Setter Property="FontSize" Value="{DynamicResource Fs115}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="TextBlock.errtext">
    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
    <Setter Property="FontSize" Value="{DynamicResource Fs12}" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>
  <Style Selector="TextBlock.warntext">
    <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
    <Setter Property="FontSize" Value="{DynamicResource Fs12}" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>
  <Style Selector="TextBlock.oktext">
    <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
    <Setter Property="FontSize" Value="{DynamicResource Fs12}" />
  </Style>

  <Style Selector="Ellipse.dot">
    <Setter Property="Width" Value="8" />
    <Setter Property="Height" Value="8" />
    <Setter Property="Fill" Value="{DynamicResource DotBrush}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="Ellipse.dot.up">
    <Setter Property="Fill" Value="{DynamicResource AccentBrush}" />
  </Style>
  <!-- Adapter is up but no handshake yet (or it went stale): amber, not green. -->
  <Style Selector="Ellipse.dot.connecting">
    <Setter Property="Fill" Value="{DynamicResource WarningBrush}" />
  </Style>

  <Style Selector="TextBlock.accentfg">
    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
  </Style>

  <Style Selector="TextBlock.synip">
    <Setter Property="Foreground" Value="{DynamicResource SynIpBrush}" />
  </Style>
  <Style Selector="TextBlock.syndomain">
    <Setter Property="Foreground" Value="{DynamicResource SynDomainBrush}" />
  </Style>
  <Style Selector="TextBlock.synkey">
    <Setter Property="Foreground" Value="{DynamicResource SynKeyBrush}" />
  </Style>
  <Style Selector="TextBlock.synnum">
    <Setter Property="Foreground" Value="{DynamicResource SynNumBrush}" />
  </Style>
  <!-- Editable inputs are not syntax-highlighted; only read-only value chips are. -->
  <Style Selector="TextBox.plainname">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="ToggleSwitch">
    <Setter Property="OnContent" Value="{x:Null}" />
    <Setter Property="OffContent" Value="{x:Null}" />
    <Setter Property="MinWidth" Value="0" />
  </Style>
  <Style Selector="Separator">
    <Setter Property="Background" Value="{DynamicResource HairlineBrush}" />
    <Setter Property="Height" Value="1" />
    <Setter Property="Margin" Value="0" />
  </Style>
</Styles>
