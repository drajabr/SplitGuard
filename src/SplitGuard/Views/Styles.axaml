<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Style Selector="TextBox">
    <Setter Property="MinHeight" Value="{DynamicResource CtrlH}" />
    <Setter Property="Padding" Value="8,3" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="FontSize" Value="{DynamicResource Fs13}" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Background" Value="{DynamicResource ItemBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource FieldBorderBrush}" />
  </Style>
  <Style Selector="TextBox.mono">
    <Setter Property="FontFamily" Value="Consolas,Courier New,monospace" />
    <Setter Property="FontSize" Value="{DynamicResource Fs12}" />
  </Style>
  <Style Selector="TextBox.error">
    <Setter Property="BorderBrush" Value="#C42B1C" />
  </Style>
  <Style Selector="TextBox.addbox">
    <Setter Property="MinWidth" Value="72" />
    <Setter Property="Height" Value="{DynamicResource CtrlH}" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{DynamicResource FieldBorderBrush}" />
  </Style>

  <Style Selector="Button">
    <Setter Property="MinHeight" Value="{DynamicResource CtrlH}" />
    <Setter Property="Padding" Value="10,3" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="FontSize" Value="{DynamicResource Fs12}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="Button.icon">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="4" />
    <Setter Property="MinHeight" Value="0" />
  </Style>
  <Style Selector="Button.chipx">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="1" />
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="Button.link">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="4,2" />
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
  </Style>
  <Style Selector="Button.danger">
    <Setter Property="Foreground" Value="#C42B1C" />
  </Style>
  <Style Selector="Button.danger.armed">
    <Setter Property="FontWeight" Value="Bold" />
  </Style>
  <Style Selector="Button.primary">
    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
    <Setter Property="Foreground" Value="White" />
  </Style>

  <Style Selector="Border.card">
    <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="4" />
  </Style>
  <Style Selector="Border.card.editing">
    <Setter Property="BorderBrush" Value="{DynamicResource AccentDimBrush}" />
  </Style>
  <Style Selector="Border.item">
    <Setter Property="Background" Value="{DynamicResource ItemBrush}" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Padding" Value="8,0" />
    <Setter Property="Height" Value="{DynamicResource CtrlH}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="Border.item > StackPanel">
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="Border.item > TextBlock">
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="Border.card">
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="Border.card.editing">
    <Setter Property="Cursor" Value="Arrow" />
  </Style>

  <Style Selector="Border.collapsehost">
    <Setter Property="ClipToBounds" Value="True" />
    <Setter Property="MaxHeight" Value="{DynamicResource CollapseH}" />
    <Setter Property="Opacity" Value="1" />
    <Setter Property="Transitions">
      <Transitions>
        <DoubleTransition Property="MaxHeight" Duration="0:0:0.14" Easing="CubicEaseOut" />
        <DoubleTransition Property="Opacity" Duration="0:0:0.10" />
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="Border.collapsehost.hidden">
    <Setter Property="MaxHeight" Value="0" />
    <Setter Property="Opacity" Value="0" />
  </Style>

  <Style Selector="Border.expandhost">
    <Setter Property="ClipToBounds" Value="True" />
    <Setter Property="MaxHeight" Value="0" />
    <Setter Property="Opacity" Value="0" />
    <Setter Property="Transitions">
      <Transitions>
        <DoubleTransition Property="MaxHeight" Duration="0:0:0.14" Easing="CubicEaseOut" />
        <DoubleTransition Property="Opacity" Duration="0:0:0.10" />
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="Border.expandhost.expanded">
    <Setter Property="MaxHeight" Value="1400" />
    <Setter Property="Opacity" Value="1" />
  </Style>

  <Style Selector="Border.peerblock">
    <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="4" />
  </Style>

  <Style Selector="TextBlock.lbl">
    <Setter Property="FontSize" Value="{DynamicResource Fs115}" />
    <Setter Property="Opacity" Value="{DynamicResource DimOpacity}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="TextBlock.mono">
    <Setter Property="FontFamily" Value="Consolas,Courier New,monospace" />
    <Setter Property="FontSize" Value="{DynamicResource Fs12}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="TextBlock.muted">
    <Setter Property="FontSize" Value="{DynamicResource Fs12}" />
    <Setter Property="Opacity" Value="{DynamicResource DimOpacity}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="TextBlock.glyph">
    <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
    <Setter Property="FontSize" Value="{DynamicResource Fs14}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="TextBlock.pinicon">
    <Setter Property="Opacity" Value="0.45" />
  </Style>
  <Style Selector="TextBlock.pinicon.pinned">
    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    <Setter Property="Opacity" Value="1" />
  </Style>
  <Style Selector="TextBlock.accent">
    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    <Setter Property="FontSize" Value="{DynamicResource Fs115}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="TextBlock.errtext">
    <Setter Property="Foreground" Value="#C42B1C" />
    <Setter Property="FontSize" Value="{DynamicResource Fs12}" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>
  <Style Selector="TextBlock.warntext">
    <Setter Property="Foreground" Value="#B25E09" />
    <Setter Property="FontSize" Value="{DynamicResource Fs12}" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>
  <Style Selector="TextBlock.oktext">
    <Setter Property="Foreground" Value="#2E7D32" />
    <Setter Property="FontSize" Value="{DynamicResource Fs12}" />
  </Style>

  <Style Selector="Ellipse.dot">
    <Setter Property="Width" Value="8" />
    <Setter Property="Height" Value="8" />
    <Setter Property="Fill" Value="#888888" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="Ellipse.dot.up">
    <Setter Property="Fill" Value="{DynamicResource AccentBrush}" />
  </Style>

  <Style Selector="TextBlock.accentfg">
    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
  </Style>

  <Style Selector="TextBlock.synip">
    <Setter Property="Foreground" Value="{DynamicResource SynIpBrush}" />
  </Style>
  <Style Selector="TextBlock.syndomain">
    <Setter Property="Foreground" Value="{DynamicResource SynDomainBrush}" />
  </Style>
  <Style Selector="TextBlock.synkey">
    <Setter Property="Foreground" Value="{DynamicResource SynKeyBrush}" />
  </Style>
  <Style Selector="TextBlock.synnum">
    <Setter Property="Foreground" Value="{DynamicResource SynNumBrush}" />
  </Style>
  <Style Selector="TextBox.synip">
    <Setter Property="Foreground" Value="{DynamicResource SynIpBrush}" />
  </Style>
  <Style Selector="TextBox.syndomain">
    <Setter Property="Foreground" Value="{DynamicResource SynDomainBrush}" />
  </Style>
  <Style Selector="TextBox.synkey">
    <Setter Property="Foreground" Value="{DynamicResource SynKeyBrush}" />
  </Style>
  <Style Selector="TextBox.synnum">
    <Setter Property="Foreground" Value="{DynamicResource SynNumBrush}" />
  </Style>

  <Style Selector="ToggleSwitch">
    <Setter Property="OnContent" Value="{x:Null}" />
    <Setter Property="OffContent" Value="{x:Null}" />
    <Setter Property="MinWidth" Value="0" />
  </Style>
  <Style Selector="Separator">
    <Setter Property="Background" Value="{DynamicResource HairlineBrush}" />
    <Setter Property="Height" Value="1" />
    <Setter Property="Margin" Value="0" />
  </Style>
</Styles>
