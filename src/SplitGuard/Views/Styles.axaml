<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:v="clr-namespace:SplitGuard.Views">

  <!-- Fields read as soft filled rows (no visible outline); the 1.5px border is reserved
       transparently at rest so the accent focus-ring can fade in without shifting the text
       (zero jitter). Only the ring color changes on hover/focus. -->
  <Style Selector="TextBox">
    <Setter Property="MinHeight" Value="{DynamicResource CtrlH}" />
    <Setter Property="Padding" Value="8,3" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="FontSize" Value="{DynamicResource Fs13}" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Background" Value="{DynamicResource FieldFillBrush}" />
    <Setter Property="BorderThickness" Value="1.5" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>
  <!-- Universal field animation: fill + ring color fade. Must live on the template border
       (that's the element whose brushes the hover/focus setters change). Thickness is never
       animated (it's constant 1.5) so nothing reflows. -->
  <Style Selector="TextBox /template/ Border#PART_BorderElement">
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background" Duration="{x:Static v:Motion.Fast}" Easing="{x:Static v:Motion.Standard}" />
        <BrushTransition Property="BorderBrush" Duration="{x:Static v:Motion.Fast}" Easing="{x:Static v:Motion.Standard}" />
      </Transitions>
    </Setter>
  </Style>
  <!-- Hover speaks the same language as focus: the fill stays the resting fill and only a
       ring appears (grey on hover, accent on focus) — no separate stronger hover shade. -->
  <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
    <Setter Property="Background" Value="{DynamicResource FieldFillBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource FieldBorderBrush}" />
  </Style>
  <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
    <Setter Property="Background" Value="{DynamicResource FieldFillBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
  </Style>
  <!-- Disabled boxes keep the soft resting fill at reduced opacity — Fluent's own disabled
       shade painted a heavy dark slab that shouted louder than the enabled fields. -->
  <Style Selector="TextBox:disabled">
    <Setter Property="Opacity" Value="0.45" />
  </Style>
  <Style Selector="TextBox:disabled /template/ Border#PART_BorderElement">
    <Setter Property="Background" Value="{DynamicResource FieldFillBrush}" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>
  <!-- Read-only public-key display that copies on click; looks like a field. -->
  <Style Selector="Button.keyfield">
    <Setter Property="Background" Value="{DynamicResource FieldFillBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="8,0" />
    <Setter Property="Height" Value="{DynamicResource CtrlH}" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <!-- "mono" is now just the compact value size; the family follows the chosen UI font. -->
  <Style Selector="TextBox.mono">
    <Setter Property="FontSize" Value="{DynamicResource Fs12}" />
  </Style>
  <!-- Shrink-to-content field: sizes to its text, or just its watermark when empty
       (the watermark is measured), instead of stretching to fill. -->
  <Style Selector="TextBox.fit">
    <Setter Property="MinWidth" Value="0" />
    <Setter Property="HorizontalAlignment" Value="Left" />
  </Style>
  <!-- Tiny numeric boxes (metric, counts, timeout): slim padding, and they shrink to fit their
       value (or the single-char watermark when empty) instead of a fixed width — like TextBox.fit. -->
  <Style Selector="TextBox.num">
    <Setter Property="Padding" Value="7,3" />
    <Setter Property="MinWidth" Value="0" />
    <Setter Property="HorizontalAlignment" Value="Left" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
  </Style>
  <Style Selector="TextBox.error">
    <Setter Property="BorderThickness" Value="1.5" />
    <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
  </Style>
  <!-- Inline "+" add box: a square button-like affordance that becomes an input on focus. -->
  <Style Selector="TextBox.addbox">
    <Setter Property="MinWidth" Value="{DynamicResource CtrlH}" />
    <Setter Property="Height" Value="{DynamicResource CtrlH}" />
    <Setter Property="Padding" Value="4,3" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
  </Style>
  <!-- On focus the "+" clears and the box grows with what's typed — no fixed jump. -->
  <Style Selector="TextBox.addbox:focus">
    <Setter Property="Watermark" Value="" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
  </Style>

  <Style Selector="ToolTip">
    <Setter Property="FontSize" Value="{DynamicResource Fs12}" />
  </Style>

  <Style Selector="Button">
    <Setter Property="MinHeight" Value="{DynamicResource CtrlH}" />
    <Setter Property="Padding" Value="10,3" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="FontSize" Value="{DynamicResource Fs12}" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
  </Style>
  <!-- Universal button animation: every hover/press/selected bg+fg+border fades, on the
       templated ContentPresenter where all button state setters land. -->
  <Style Selector="Button /template/ ContentPresenter">
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background" Duration="{x:Static v:Motion.Fast}" Easing="{x:Static v:Motion.Standard}" />
        <BrushTransition Property="Foreground" Duration="{x:Static v:Motion.Fast}" Easing="{x:Static v:Motion.Standard}" />
        <BrushTransition Property="BorderBrush" Duration="{x:Static v:Motion.Fast}" Easing="{x:Static v:Motion.Standard}" />
        <DoubleTransition Property="Opacity" Duration="{x:Static v:Motion.Fast}" Easing="{x:Static v:Motion.Standard}" />
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="Button.icon">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="4" />
    <Setter Property="MinHeight" Value="0" />
  </Style>
  <!-- Explicit hover/press states: without these the Fluent theme's own pointer-over shade
       (a different gray, plus a foreground repaint) lands first and the universal brush
       transition then fades to it — which read as a two-stage flicker on every icon button. -->
  <Style Selector="Button.icon /template/ ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
  </Style>
  <Style Selector="Button.icon:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource FieldFillHoverBrush}" />
  </Style>
  <Style Selector="Button.icon:pressed /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource FieldFillBrush}" />
  </Style>
  <!-- Icon toggle (e.g. reveal the private key): borderless like Button.icon; the glyph
       tints to the accent while checked. -->
  <Style Selector="ToggleButton.icon">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="4" />
    <Setter Property="MinHeight" Value="0" />
  </Style>
  <Style Selector="ToggleButton.icon /template/ ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Foreground" Duration="{x:Static v:Motion.Fast}" Easing="{x:Static v:Motion.Standard}" />
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="ToggleButton.icon:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
  </Style>
  <Style Selector="ToggleButton.icon:checked /template/ ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
  </Style>
  <!-- Chip remove (×): a destructive tap target, so give it a real minimum hit size — the
       background stays transparent so the chip's visual density is unchanged. -->
  <Style Selector="Button.chipx">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="4" />
    <Setter Property="MinHeight" Value="18" />
    <Setter Property="MinWidth" Value="18" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="Button.link">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="7,3" />
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
  </Style>
  <!-- Fix the weird link hover: a subtle rounded fill (not Fluent gray) that keeps the
       accent text (Fluent otherwise repaints the ContentPresenter fg on hover). -->
  <Style Selector="Button.link:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource FieldFillHoverBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
  </Style>
  <Style Selector="Button.link:pressed /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource FieldFillBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
  </Style>
  <!-- Header action buttons (Add / Settings): subtle, pill-ish. -->
  <Style Selector="Button.hdr">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="8,3" />
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="CornerRadius" Value="6" />
  </Style>
  <Style Selector="Button.hdr:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource FieldFillHoverBrush}" />
  </Style>
  <Style Selector="Button.hdr:pressed /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource FieldFillBrush}" />
  </Style>

  <!-- Full-width action row in the Add drawer: left-aligned label with its shortcut flushed
       right; a soft rounded hover fill (fades via the universal button transition). -->
  <Style Selector="Button.actionrow">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="10,8" />
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
  </Style>
  <Style Selector="Button.actionrow:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource FieldFillHoverBrush}" />
  </Style>
  <Style Selector="Button.actionrow:pressed /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource FieldFillBrush}" />
  </Style>

  <!-- Segmented option buttons inside the appearance menu: soft filled, borderless; the
       selected one fills with the accent. -->
  <Style Selector="Button.seg">
    <Setter Property="Background" Value="{DynamicResource FieldFillBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="6,3" />
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="FontSize" Value="{DynamicResource Fs11}" />
    <!-- Fill the UniformGrid cell so font/scale boxes expand to the width like the swatches. -->
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
  </Style>
  <Style Selector="Button.seg:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource FieldFillHoverBrush}" />
  </Style>
  <Style Selector="Button.seg.sel">
    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource OnAccentBrush}" />
  </Style>
  <Style Selector="Button.seg.sel /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource OnAccentBrush}" />
  </Style>
  <Style Selector="Button.seg.sel:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource OnAccentBrush}" />
  </Style>

  <!-- Pill switch: dim track when off, accent when on; the white knob slides across. Shared by
       the tunnel connect toggle (.conn) and the settings-panel switches (.pill) so both read
       identically. -->
  <Style Selector="ToggleButton.conn, ToggleButton.pill">
    <Setter Property="Width" Value="40" />
    <Setter Property="Height" Value="22" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Background" Value="{DynamicResource DotBrush}" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Name="track" Background="{TemplateBinding Background}" CornerRadius="11">
          <Ellipse Name="knob" Width="16" Height="16" Fill="White"
                   HorizontalAlignment="Left" VerticalAlignment="Center" Margin="3,0">
            <Ellipse.Transitions>
              <Transitions>
                <TransformOperationsTransition Property="RenderTransform" Duration="{x:Static v:Motion.Base}" Easing="{x:Static v:Motion.Standard}" />
              </Transitions>
            </Ellipse.Transitions>
          </Ellipse>
        </Border>
      </ControlTemplate>
    </Setter>
  </Style>
  <Style Selector="ToggleButton.conn /template/ Border#track, ToggleButton.pill /template/ Border#track">
    <Setter Property="Opacity" Value="0.45" />
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background" Duration="{x:Static v:Motion.Base}" Easing="{x:Static v:Motion.Standard}" />
        <DoubleTransition Property="Opacity" Duration="{x:Static v:Motion.Base}" Easing="{x:Static v:Motion.Standard}" />
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="ToggleButton.conn:checked /template/ Border#track, ToggleButton.pill:checked /template/ Border#track">
    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
    <Setter Property="Opacity" Value="1" />
  </Style>
  <Style Selector="ToggleButton.conn:checked /template/ Ellipse#knob, ToggleButton.pill:checked /template/ Ellipse#knob">
    <Setter Property="RenderTransform" Value="translateX(18px)" />
    <!-- Knob takes the on-accent color when checked so it stays visible on the accent track —
         white on green/blue/red, but dark on a near-white "mono" track (which otherwise hid it). -->
    <Setter Property="Fill" Value="{DynamicResource OnAccentBrush}" />
  </Style>
  <!-- Adapter is up but no handshake yet (or it went stale): the track turns amber and softly
       pulses until established, so "connecting" is visible without reading any text. -->
  <Style Selector="ToggleButton.conn.connecting:checked /template/ Border#track">
    <Setter Property="Background" Value="{DynamicResource WarningBrush}" />
    <Style.Animations>
      <Animation Duration="0:0:1.2" IterationCount="Infinite" Easing="{x:Static v:Motion.Standard}">
        <KeyFrame Cue="0%"><Setter Property="Opacity" Value="1" /></KeyFrame>
        <KeyFrame Cue="50%"><Setter Property="Opacity" Value="0.55" /></KeyFrame>
        <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1" /></KeyFrame>
      </Animation>
    </Style.Animations>
  </Style>

  <!-- Accent swatch (appearance picker): a color dot on a soft filled tile; the selected one
       gets an accent ring. Same fill + radius as Button.seg so the two picker rows align. -->
  <!-- Swatch tile: the whole box is the color/shade (a stretched Border fills it, so the box
       grows and shrinks with the column width). The 2px transparent ring is reserved so the
       accent selection ring can appear without resizing the box; content stretches edge-to-edge. -->
  <Style Selector="Button.swatch">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="2" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Setter Property="VerticalContentAlignment" Value="Stretch" />
  </Style>
  <Style Selector="Button.swatch.sel">
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
  </Style>

  <!-- Danger = a red ghost (Delete tunnel, Remove peer): no fill/border until a faint
       danger-tinted hover; text stays red in every state. Must be declared after Button.link
       so "link danger" (Remove peer) resolves to the danger color. -->
  <Style Selector="Button.danger">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
  </Style>
  <Style Selector="Button.danger /template/ ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
  </Style>
  <Style Selector="Button.danger:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource DangerBgBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
  </Style>
  <Style Selector="Button.danger:pressed /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource DangerBgBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
  </Style>
  <Style Selector="Button.danger.armed">
    <Setter Property="FontWeight" Value="Bold" />
  </Style>

  <!-- Primary = a solid accent rounded button (Save); hover/press darken via an opacity dip
       so fill + label stay in contrast. -->
  <Style Selector="Button.primary">
    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource OnAccentBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="16,3" />
  </Style>
  <Style Selector="Button.primary /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource OnAccentBrush}" />
  </Style>
  <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource OnAccentBrush}" />
    <Setter Property="Opacity" Value="0.88" />
  </Style>
  <Style Selector="Button.primary:pressed /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource OnAccentBrush}" />
    <Setter Property="Opacity" Value="0.78" />
  </Style>

  <!-- Quiet ghost secondary (Cancel + the raw-config toggle): muted label, no fill until a
       soft hover. -->
  <Style Selector="Button.quiet">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Opacity" Value="{DynamicResource DimOpacity}" />
    <!-- The dim->full label fade lives on the Button itself (the presenter transition only
         covers presenter properties), so hover fades the text in step with the fill. -->
    <Setter Property="Transitions">
      <Transitions>
        <DoubleTransition Property="Opacity" Duration="{x:Static v:Motion.Fast}" Easing="{x:Static v:Motion.Standard}" />
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="Button.quiet:pointerover">
    <Setter Property="Opacity" Value="1" />
  </Style>
  <Style Selector="Button.quiet /template/ ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
    <!-- Same brush at rest as on hover/press (below), so the label never shifts shade. -->
    <Setter Property="Foreground" Value="{DynamicResource TextControlForeground}" />
  </Style>
  <Style Selector="Button.quiet:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource FieldFillHoverBrush}" />
    <!-- Pin the label color: Fluent's pointer-over otherwise repaints the presenter
         foreground to its own theme shade for a frame (the hover "glitch"). -->
    <Setter Property="Foreground" Value="{DynamicResource TextControlForeground}" />
  </Style>
  <Style Selector="Button.quiet:pressed /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource FieldFillBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextControlForeground}" />
  </Style>

  <Style Selector="Border.card">
    <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <!-- Matches the Windows 11 external window corner radius so cards nest with the window. -->
    <Setter Property="CornerRadius" Value="8" />
    <!-- No ClipToBounds here: it would swallow the elevation shadow. The animated region
         is clipped by the inner Border.body; the header/footer are inset from the corners. -->
    <Setter Property="BoxShadow" Value="{DynamicResource CardShadow}" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="BorderBrush" Duration="{x:Static v:Motion.Base}" Easing="{x:Static v:Motion.Standard}" />
        <!-- Fades (card appear/remove, the bottom cluster's yield-to-content) are applied to the
             shadow-casting Border itself: an opacity layer on an ancestor clips descendant
             BoxShadows to the ancestor's bounds. -->
        <DoubleTransition Property="Opacity" Duration="{x:Static v:Motion.Slow}" Easing="{x:Static v:Motion.Standard}" />
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="Border.card.editing">
    <Setter Property="BorderBrush" Value="{DynamicResource AccentDimBrush}" />
    <Setter Property="Cursor" Value="Arrow" />
  </Style>
  <!-- Floating bottom cluster: an elevated layer the list scrolls beneath. The shadow is what
       sells the elevation; ClipToBounds must stay off or it would swallow the shadow (clipping
       for the drawers lives on an inner panel instead). Drawers only wear the shadow while
       open — a closed (zero-height) region must paint nothing at all. -->
  <Style Selector="Border.float">
    <Setter Property="ClipToBounds" Value="False" />
    <Setter Property="BoxShadow" Value="{DynamicResource FloatShadow}" />
  </Style>
  <Style Selector="Border.drawer.open">
    <Setter Property="BoxShadow" Value="{DynamicResource FloatShadow}" />
  </Style>
  <Style Selector="Border.drawer">
    <Setter Property="Transitions">
      <Transitions>
        <DoubleTransition Property="Opacity" Duration="{x:Static v:Motion.Slow}" Easing="{x:Static v:Motion.Standard}" />
      </Transitions>
    </Setter>
  </Style>
  <!-- Collapsed cards are click-to-expand; a slightly stronger border on hover signals it
       (rides the card's BorderBrush transition). Editing cards keep their accent ring. -->
  <Style Selector="Border.card:not(.editing):pointerover">
    <Setter Property="BorderBrush" Value="{DynamicResource FieldBorderBrush}" />
  </Style>

  <!-- Dashed drop-target outline: the resting empty-state zone, and (with .active) the
       accent-tinted overlay shown while a .conf is dragged over the window. -->
  <Style Selector="Rectangle.dropzone">
    <Setter Property="Stroke" Value="{DynamicResource FieldBorderBrush}" />
    <Setter Property="StrokeThickness" Value="1.5" />
    <Setter Property="StrokeDashArray" Value="4,3" />
    <Setter Property="RadiusX" Value="8" />
    <Setter Property="RadiusY" Value="8" />
    <Setter Property="Fill" Value="Transparent" />
  </Style>
  <Style Selector="Rectangle.dropzone.active">
    <Setter Property="Stroke" Value="{DynamicResource AccentBrush}" />
    <Setter Property="Fill" Value="{DynamicResource AccentDimBrush}" />
    <Setter Property="Opacity" Value="0.55" />
  </Style>
  <!-- Value chips (addresses, allowed IPs, domains): outlined like the input boxes.
       MinHeight (not Height): long values wrap to more lines and the chip grows,
       keeping the × inside the box, top-right. -->
  <Style Selector="Border.item">
    <Setter Property="Background" Value="{DynamicResource FieldFillBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="8,3" />
    <Setter Property="MinHeight" Value="{DynamicResource CtrlH}" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background" Duration="{x:Static v:Motion.Fast}" Easing="{x:Static v:Motion.Standard}" />
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="Border.item > DockPanel">
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="Border.item:pointerover">
    <Setter Property="Background" Value="{DynamicResource FieldFillHoverBrush}" />
  </Style>

  <!-- Single clipped region below the header. Its Height is animated by the code-behind
       between the collapsed-detail height and the expanded height, so the card grows and
       shrinks in one smooth motion (no overlap, no fade). -->
  <Style Selector="Border.body">
    <Setter Property="ClipToBounds" Value="True" />
  </Style>

  <!-- Transient toast: a small card floating bottom-right that slides up + fades in when a
       status message fires and reverses out when it clears. -->
  <Style Selector="Border.toast">
    <Setter Property="Background" Value="{DynamicResource MenuSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="9" />
    <Setter Property="Padding" Value="12,8" />
    <Setter Property="Opacity" Value="0" />
    <Setter Property="RenderTransform" Value="translateY(10px)" />
    <Setter Property="Transitions">
      <Transitions>
        <DoubleTransition Property="Opacity" Duration="{x:Static v:Motion.Slow}" Easing="{x:Static v:Motion.Standard}" />
        <TransformOperationsTransition Property="RenderTransform" Duration="{x:Static v:Motion.Slow}" Easing="{x:Static v:Motion.Standard}" />
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="Border.toast.shown">
    <Setter Property="Opacity" Value="1" />
    <Setter Property="RenderTransform" Value="translateY(0px)" />
  </Style>

  <!-- Each peer is its own hairline-boxed card inside the tunnel card; a soft shadow lifts it
       off the tunnel-card surface, matching the tunnel/settings cards. -->
  <Style Selector="Border.peerblock">
    <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="12,0,2,4" />
    <Setter Property="BoxShadow" Value="{DynamicResource CardShadow}" />
  </Style>

  <Style Selector="TextBlock.lbl">
    <Setter Property="FontSize" Value="{DynamicResource Fs115}" />
    <Setter Property="Opacity" Value="{DynamicResource DimOpacity}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="TextBlock.mono">
    <Setter Property="FontSize" Value="{DynamicResource Fs12}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="TextBlock.muted">
    <Setter Property="FontSize" Value="{DynamicResource Fs12}" />
    <Setter Property="Opacity" Value="{DynamicResource DimOpacity}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <!-- Settings-panel row label: full-opacity body text that scales with the zoom step. -->
  <Style Selector="TextBlock.setlabel">
    <Setter Property="FontSize" Value="{DynamicResource Fs125}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="TextBlock.glyph">
    <!-- Windows: Segoe Fluent (Win11) with MDL2 fallback (Win10). Android swaps the
         resource for the bundled SplitGuard Symbols font at startup. -->
    <Setter Property="FontFamily" Value="{DynamicResource GlyphFontFamily}" />
    <Setter Property="FontSize" Value="{DynamicResource Fs14}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="TextBlock.pinicon">
    <Setter Property="Opacity" Value="0.45" />
  </Style>
  <Style Selector="TextBlock.pinicon.pinned">
    <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
    <Setter Property="Opacity" Value="1" />
  </Style>
  <!-- Pinned but its tunnel is down: filled pin in the warning color. -->
  <Style Selector="TextBlock.pinicon.pinned.suspended">
    <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
  </Style>
  <Style Selector="TextBlock.errtext">
    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
    <Setter Property="FontSize" Value="{DynamicResource Fs12}" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>
  <Style Selector="TextBlock.warntext">
    <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
    <Setter Property="FontSize" Value="{DynamicResource Fs12}" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>
  <Style Selector="TextBlock.oktext">
    <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
    <Setter Property="FontSize" Value="{DynamicResource Fs12}" />
  </Style>

  <Style Selector="TextBlock.accentfg">
    <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
  </Style>

  <!-- Header update button: dim by default, accented + full opacity once an update is ready. -->
  <Style Selector="TextBlock.updicon">
    <Setter Property="Opacity" Value="0.55" />
  </Style>
  <Style Selector="TextBlock.updicon.hot">
    <Setter Property="Opacity" Value="1" />
    <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
  </Style>

  <Style Selector="TextBlock.synip">
    <Setter Property="Foreground" Value="{DynamicResource SynIpBrush}" />
  </Style>
  <Style Selector="TextBlock.syndomain">
    <Setter Property="Foreground" Value="{DynamicResource SynDomainBrush}" />
  </Style>
  <Style Selector="TextBlock.synkey">
    <Setter Property="Foreground" Value="{DynamicResource SynKeyBrush}" />
  </Style>
  <Style Selector="TextBlock.synnum">
    <Setter Property="Foreground" Value="{DynamicResource SynNumBrush}" />
  </Style>
  <!-- Tunnel + peer names share this class: a bold accent title with no fill and no visible
       box at rest, revealing a thin ring on hover/focus so it reads as editable. The 1.5px
       border footprint is inherited from the base TextBox (reserved transparently), so the
       ring fades in via the base transition without shifting the title. -->
  <Style Selector="TextBox.plainname">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>
  <Style Selector="TextBox.plainname:pointerover /template/ Border#PART_BorderElement">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{DynamicResource FieldBorderBrush}" />
  </Style>
  <Style Selector="TextBox.plainname:focus /template/ Border#PART_BorderElement">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
  </Style>
  <!-- An unnamed peer's "Peer" placeholder IS the title being shown — render it exactly like
       the tunnel name (full accent), not as the dimmed input hint the template defaults to. -->
  <Style Selector="TextBox.plainname /template/ TextBlock#PART_Watermark">
    <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
    <Setter Property="Opacity" Value="1" />
  </Style>

  <!-- Avalonia 12's drawn chrome (WindowDrawnDecorations) renders the window title INSIDE the
       extended client area, on top of our own title strip (logo + name + version + update),
       plus a fullscreen caption button we don't want. Hide both; min/max/close stay. -->
  <Style Selector="WindowDrawnDecorations /template/ Panel#PART_TitleTextPanel > TextBlock">
    <Setter Property="IsVisible" Value="False" />
  </Style>
  <Style Selector="WindowDrawnDecorations /template/ Button#PART_FullScreenButton">
    <Setter Property="IsVisible" Value="False" />
    <Setter Property="Width" Value="0" />
  </Style>

  <Style Selector="Separator">
    <Setter Property="Background" Value="{DynamicResource SeparatorBrush}" />
    <Setter Property="Height" Value="1" />
    <Setter Property="Margin" Value="0" />
  </Style>

  <!-- Menu surfaces: the TextBox context flyout and, where Avalonia renders it managed, the
       Windows tray menu. -->
  <Style Selector="MenuFlyoutPresenter">
    <Setter Property="Background" Value="{DynamicResource MenuSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="4" />
  </Style>
  <Style Selector="MenuItem">
    <Setter Property="MinHeight" Value="{DynamicResource CtrlH}" />
    <Setter Property="Padding" Value="10,5" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="FontSize" Value="{DynamicResource Fs12}" />
  </Style>
</Styles>
