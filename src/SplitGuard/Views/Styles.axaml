<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Style Selector="TextBox">
    <Setter Property="MinHeight" Value="{DynamicResource CtrlH}" />
    <Setter Property="Padding" Value="8,3" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="FontSize" Value="{DynamicResource Fs13}" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{DynamicResource FieldBorderBrush}" />
  </Style>
  <!-- The Fluent template fills a solid background on hover/focus; keep it transparent
       so only the border reacts (the fill read as a heavy highlight). -->
  <Style Selector="TextBox /template/ Border#PART_BorderElement">
    <Setter Property="Background" Value="Transparent" />
  </Style>
  <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
    <Setter Property="Background" Value="Transparent" />
  </Style>
  <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
    <Setter Property="Background" Value="Transparent" />
  </Style>
  <!-- Read-only public-key display that copies on click; looks like a field. -->
  <Style Selector="Button.keyfield">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{DynamicResource FieldBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Padding" Value="8,0" />
    <Setter Property="Height" Value="{DynamicResource CtrlH}" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <!-- "mono" is now just the compact value size; the family follows the chosen UI font. -->
  <Style Selector="TextBox.mono">
    <Setter Property="FontSize" Value="{DynamicResource Fs12}" />
  </Style>
  <!-- Shrink-to-content field: sizes to its text, or just its watermark when empty
       (the watermark is measured), instead of stretching to fill. -->
  <Style Selector="TextBox.fit">
    <Setter Property="MinWidth" Value="0" />
    <Setter Property="HorizontalAlignment" Value="Left" />
  </Style>
  <!-- Tiny numeric boxes (metric, counts, timeout): slim padding so 2-3 digits fit
       in half the normal width. -->
  <Style Selector="TextBox.num">
    <Setter Property="Padding" Value="2,3" />
    <Setter Property="MinWidth" Value="0" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
  </Style>
  <Style Selector="TextBox.error">
    <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
  </Style>
  <!-- Inline "+" add box: a square button-like affordance that becomes an input on focus. -->
  <Style Selector="TextBox.addbox">
    <Setter Property="MinWidth" Value="{DynamicResource CtrlH}" />
    <Setter Property="Height" Value="{DynamicResource CtrlH}" />
    <Setter Property="Padding" Value="4,3" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{DynamicResource FieldBorderBrush}" />
  </Style>
  <!-- On focus the "+" clears and the box grows with what's typed — no fixed jump. -->
  <Style Selector="TextBox.addbox:focus">
    <Setter Property="Watermark" Value="" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
  </Style>

  <Style Selector="ToolTip">
    <Setter Property="FontSize" Value="{DynamicResource Fs12}" />
  </Style>

  <Style Selector="Button">
    <Setter Property="MinHeight" Value="{DynamicResource CtrlH}" />
    <Setter Property="Padding" Value="10,3" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="FontSize" Value="{DynamicResource Fs12}" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
  </Style>
  <Style Selector="Button.icon">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="4" />
    <Setter Property="MinHeight" Value="0" />
  </Style>
  <!-- Icon toggle (e.g. reveal the private key): borderless like Button.icon; the glyph
       tints to the accent while checked. -->
  <Style Selector="ToggleButton.icon">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="4" />
    <Setter Property="MinHeight" Value="0" />
  </Style>
  <Style Selector="ToggleButton.icon /template/ ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
  </Style>
  <Style Selector="ToggleButton.icon:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
  </Style>
  <Style Selector="ToggleButton.icon:checked /template/ ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
  </Style>
  <Style Selector="Button.chipx">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="1" />
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="Button.link">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="4,2" />
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
  </Style>
  <!-- Header action buttons (Add / Settings): subtle, pill-ish. -->
  <Style Selector="Button.hdr">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="8,3" />
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="CornerRadius" Value="5" />
  </Style>
  <Style Selector="Button.hdr:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource ItemBrush}" />
  </Style>

  <!-- Floating Add control: centered at the page bottom, borderless, icon over label. -->
  <Style Selector="Button.addbtn">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="10,4" />
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="CornerRadius" Value="6" />
  </Style>
  <Style Selector="Button.addbtn:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource ItemBrush}" />
  </Style>

  <!-- Segmented option buttons inside the Settings popover. -->
  <Style Selector="Button.seg">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{DynamicResource FieldBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="8,2" />
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="FontSize" Value="{DynamicResource Fs12}" />
  </Style>
  <Style Selector="Button.seg.sel">
    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource OnAccentBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
  </Style>
  <Style Selector="Button.seg.sel /template/ ContentPresenter">
    <Setter Property="Foreground" Value="{DynamicResource OnAccentBrush}" />
  </Style>

  <!-- Connect toggle: a pill switch. Dim track when off, accent when on; the white knob
       slides across. -->
  <Style Selector="ToggleButton.conn">
    <Setter Property="Width" Value="40" />
    <Setter Property="Height" Value="22" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Background" Value="{DynamicResource DotBrush}" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Name="track" Background="{TemplateBinding Background}" CornerRadius="11">
          <Ellipse Name="knob" Width="16" Height="16" Fill="White"
                   HorizontalAlignment="Left" VerticalAlignment="Center" Margin="3,0">
            <Ellipse.Transitions>
              <Transitions>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.14" Easing="CubicEaseOut" />
              </Transitions>
            </Ellipse.Transitions>
          </Ellipse>
        </Border>
      </ControlTemplate>
    </Setter>
  </Style>
  <Style Selector="ToggleButton.conn /template/ Border#track">
    <Setter Property="Opacity" Value="0.45" />
  </Style>
  <Style Selector="ToggleButton.conn:checked /template/ Border#track">
    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
    <Setter Property="Opacity" Value="1" />
  </Style>
  <Style Selector="ToggleButton.conn:checked /template/ Ellipse#knob">
    <Setter Property="RenderTransform" Value="translateX(18px)" />
  </Style>

  <Style Selector="Button.danger">
    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
  </Style>
  <Style Selector="Button.danger.armed">
    <Setter Property="FontWeight" Value="Bold" />
  </Style>
  <Style Selector="Button.primary">
    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource OnAccentBrush}" />
  </Style>
  <!-- Override the templated ContentPresenter in every state so the label keeps its
       on-accent color (the theme otherwise repaints it white on hover/press). -->
  <Style Selector="Button.primary /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource OnAccentBrush}" />
  </Style>
  <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AccentDimBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource OnAccentBrush}" />
  </Style>
  <Style Selector="Button.primary:pressed /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource OnAccentBrush}" />
  </Style>

  <Style Selector="Border.card">
    <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="11" />
    <Setter Property="ClipToBounds" Value="True" />
  </Style>
  <Style Selector="Border.card.editing">
    <Setter Property="BorderBrush" Value="{DynamicResource AccentDimBrush}" />
  </Style>
  <!-- Value chips (addresses, allowed IPs, domains): outlined like the input boxes.
       MinHeight (not Height): long values wrap to more lines and the chip grows,
       keeping the × inside the box, top-right. -->
  <Style Selector="Border.item">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{DynamicResource FieldBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="8,3" />
    <Setter Property="MinHeight" Value="{DynamicResource CtrlH}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="Border.item > DockPanel">
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="Border.card">
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="Border.card.editing">
    <Setter Property="Cursor" Value="Arrow" />
  </Style>

  <!-- Single clipped region below the header. Its Height is animated by the code-behind
       between the collapsed-detail height and the expanded height, so the card grows and
       shrinks in one smooth motion (no overlap, no fade). -->
  <Style Selector="Border.body">
    <Setter Property="ClipToBounds" Value="True" />
  </Style>

  <!-- Bottom status bar: slides/fades in and out with the same easing. -->
  <Style Selector="Border.statusbar">
    <Setter Property="ClipToBounds" Value="True" />
    <Setter Property="MaxHeight" Value="0" />
    <Setter Property="Opacity" Value="0" />
    <Setter Property="Transitions">
      <Transitions>
        <DoubleTransition Property="MaxHeight" Duration="0:0:0.20" Easing="CubicEaseOut" />
        <DoubleTransition Property="Opacity" Duration="0:0:0.20" Easing="CubicEaseOut" />
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="Border.statusbar.shown">
    <Setter Property="MaxHeight" Value="80" />
    <Setter Property="Opacity" Value="1" />
  </Style>

  <Style Selector="Border.peerblock">
    <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
  </Style>

  <Style Selector="TextBlock.lbl">
    <Setter Property="FontSize" Value="{DynamicResource Fs115}" />
    <Setter Property="Opacity" Value="{DynamicResource DimOpacity}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="TextBlock.mono">
    <Setter Property="FontSize" Value="{DynamicResource Fs12}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="TextBlock.muted">
    <Setter Property="FontSize" Value="{DynamicResource Fs12}" />
    <Setter Property="Opacity" Value="{DynamicResource DimOpacity}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="TextBlock.glyph">
    <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
    <Setter Property="FontSize" Value="{DynamicResource Fs14}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="TextBlock.pinicon">
    <Setter Property="Opacity" Value="0.45" />
  </Style>
  <Style Selector="TextBlock.pinicon.pinned">
    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    <Setter Property="Opacity" Value="1" />
  </Style>
  <!-- Pinned but its tunnel is down: filled pin in the warning color. -->
  <Style Selector="TextBlock.pinicon.pinned.suspended">
    <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
  </Style>
  <Style Selector="TextBlock.accent">
    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    <Setter Property="FontSize" Value="{DynamicResource Fs115}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="TextBlock.errtext">
    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
    <Setter Property="FontSize" Value="{DynamicResource Fs12}" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>
  <Style Selector="TextBlock.warntext">
    <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
    <Setter Property="FontSize" Value="{DynamicResource Fs12}" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>
  <Style Selector="TextBlock.oktext">
    <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
    <Setter Property="FontSize" Value="{DynamicResource Fs12}" />
  </Style>

  <Style Selector="Ellipse.dot">
    <Setter Property="Width" Value="8" />
    <Setter Property="Height" Value="8" />
    <Setter Property="Fill" Value="{DynamicResource DotBrush}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="Ellipse.dot.up">
    <Setter Property="Fill" Value="{DynamicResource AccentBrush}" />
  </Style>
  <!-- Adapter is up but no handshake yet (or it went stale): amber, not green. -->
  <Style Selector="Ellipse.dot.connecting">
    <Setter Property="Fill" Value="{DynamicResource WarningBrush}" />
  </Style>

  <Style Selector="TextBlock.accentfg">
    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
  </Style>

  <Style Selector="TextBlock.synip">
    <Setter Property="Foreground" Value="{DynamicResource SynIpBrush}" />
  </Style>
  <Style Selector="TextBlock.syndomain">
    <Setter Property="Foreground" Value="{DynamicResource SynDomainBrush}" />
  </Style>
  <Style Selector="TextBlock.synkey">
    <Setter Property="Foreground" Value="{DynamicResource SynKeyBrush}" />
  </Style>
  <Style Selector="TextBlock.synnum">
    <Setter Property="Foreground" Value="{DynamicResource SynNumBrush}" />
  </Style>
  <!-- Editable inputs are not syntax-highlighted; only read-only value chips are. -->
  <Style Selector="TextBox.plainname">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="ToggleSwitch">
    <Setter Property="OnContent" Value="{x:Null}" />
    <Setter Property="OffContent" Value="{x:Null}" />
    <Setter Property="MinWidth" Value="0" />
  </Style>
  <Style Selector="Separator">
    <Setter Property="Background" Value="{DynamicResource HairlineBrush}" />
    <Setter Property="Height" Value="1" />
    <Setter Property="Margin" Value="0" />
  </Style>
</Styles>
