<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             xmlns:vm="clr-namespace:SplitGuard.ViewModels"
             xmlns:views="clr-namespace:SplitGuard.Views"
             xmlns:ae="using:AvaloniaEdit"
             x:Class="SplitGuard.Views.TunnelCard"
             ClipToBounds="False">
  <Border Name="CardShell" Classes="card" Classes.editing="{Binding IsEditing}" Background="{DynamicResource SurfaceBrush}">
    <StackPanel>
      <DockPanel Name="HeaderRow" Background="Transparent" Margin="12,5" Height="{DynamicResource HeaderH}">
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="3" IsVisible="{Binding StatsVisible}">
            <TextBlock Classes="glyph accentfg" Text="&#xE74A;" FontSize="{DynamicResource Fs11}" />
            <TextBlock Classes="mono" Text="{Binding UpRate}" Opacity="0.75" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="3" IsVisible="{Binding StatsVisible}">
            <TextBlock Classes="glyph accentfg" Text="&#xE74B;" FontSize="{DynamicResource Fs11}" />
            <TextBlock Classes="mono" Text="{Binding DownRate}" Opacity="0.75" />
          </StackPanel>
          <StackPanel Name="ConnectBox" Orientation="Horizontal" VerticalAlignment="Center" IsVisible="{Binding ShowConnect}">
            <ToggleButton Classes="conn" Classes.connecting="{Binding ShowConnecting}" IsChecked="{Binding IsConnected}"
                          ToolTip.Tip="Connect / disconnect (saves &amp; applies while editing)" />
          </StackPanel>
        </StackPanel>
        <Grid VerticalAlignment="Center" ColumnDefinitions="Auto,Auto,Auto,*">
          <TextBox Grid.Column="0" MinWidth="60" MaxWidth="240" HorizontalAlignment="Left" VerticalAlignment="Center"
                   FontSize="{DynamicResource Fs17}" FontWeight="Bold"
                   Foreground="{DynamicResource AccentTextBrush}" Text="{Binding Name}"
                   Classes="plainname"
                   IsReadOnly="{Binding !NameEditable}" IsHitTestVisible="{Binding NameEditable}" />
          <!-- Export the whole tunnel's .conf (QR / copy / save). Shown by the name while editing. -->
          <Button Grid.Column="1" Classes="icon" Name="ExportBtn" Margin="6,0,0,0" VerticalAlignment="Center"
                  Command="{Binding ShowExportCommand}" IsVisible="{Binding ExportButtonVisible}"
                  ToolTip.Tip="Export tunnel configuration (QR · copy · save)">
            <TextBlock Classes="glyph accentfg" Text="&#xE8B8;" FontSize="{DynamicResource Fs14}" />
          </Button>
          <Border Grid.Column="2" Background="{DynamicResource ItemBrush}" CornerRadius="4" Padding="6,2" Margin="10,0,0,0"
                  IsVisible="{Binding IsExternal}" VerticalAlignment="Center">
            <TextBlock FontSize="{DynamicResource Fs11}" Opacity="0.7" Text="External" />
          </Border>
          <TextBlock Grid.Column="3" Classes="mono synip" Margin="10,0,0,0" VerticalAlignment="Center"
                     TextTrimming="CharacterEllipsis" Text="{Binding CollapsedSummary}" IsVisible="{Binding !IsEditing}" />
        </Grid>
      </DockPanel>

      <Border Name="Body" Classes="body">
      <Panel Name="BodyContent">
      <StackPanel Name="DetailPanel" Margin="20,0,12,8" IsHitTestVisible="{Binding !IsEditing}" />

      <!-- Export pane: a QR of the WHOLE tunnel's standalone .conf (Interface + every Peer).
           Opened from the header's export button (edit view); swaps in like the edit pane.
           Copy / Save file below. Wired in code. -->
      <Border Name="ExportOverlay" IsVisible="False" Background="{DynamicResource SurfaceBrush}" ClipToBounds="True">
        <StackPanel Margin="16,8,16,14" Spacing="11">
          <DockPanel>
            <Button DockPanel.Dock="Right" Classes="icon" Name="ExportClose" VerticalAlignment="Center" ToolTip.Tip="Back">
              <TextBlock Classes="glyph" Text="&#xE711;" FontSize="{DynamicResource Fs14}" Opacity="0.7" />
            </Button>
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
              <TextBlock Classes="glyph accentfg" Text="&#xE8B8;" FontSize="{DynamicResource Fs14}" VerticalAlignment="Center" />
              <TextBlock Name="ExportTitle" Text="Export config" Classes="accentfg" FontWeight="Bold" FontSize="{DynamicResource Fs14}" VerticalAlignment="Center" />
            </StackPanel>
          </DockPanel>
          <Border Background="White" CornerRadius="10" Padding="12" HorizontalAlignment="Center" BoxShadow="{DynamicResource CardShadow}">
            <Image Name="ExportQr" Width="220" Height="220" RenderOptions.BitmapInterpolationMode="None" />
          </Border>
          <TextBlock Classes="muted" HorizontalAlignment="Center" FontSize="{DynamicResource Fs11}" Text="Scan on another device, or:" />
          <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
            <Button Classes="hdr" Name="ExportCopy" Padding="12,7">
              <StackPanel Orientation="Horizontal" Spacing="7">
                <TextBlock Classes="glyph accentfg" Text="&#xE8C8;" FontSize="{DynamicResource Fs13}" />
                <TextBlock Text="Copy" Classes="setlabel" />
              </StackPanel>
            </Button>
            <Button Classes="hdr" Name="ExportSave" Padding="12,7">
              <StackPanel Orientation="Horizontal" Spacing="7">
                <TextBlock Classes="glyph accentfg" Text="&#xE896;" FontSize="{DynamicResource Fs13}" />
                <TextBlock Text="Save file" Classes="setlabel" />
              </StackPanel>
            </Button>
          </StackPanel>
        </StackPanel>
      </Border>

      <StackPanel Name="ExpandContent" IsHitTestVisible="{Binding IsEditing}">

        <Border Name="EditorHost" Margin="12,8" CornerRadius="4" BorderBrush="{DynamicResource FieldBorderBrush}" BorderThickness="1"
                IsVisible="{Binding IsTextMode}">
          <StackPanel>
            <ae:TextEditor Name="ConfEditor" MinHeight="90" Padding="8,6"
                           FontFamily="Cascadia Mono, Consolas, Courier New, monospace" FontSize="{DynamicResource Fs12}"
                           Background="Transparent"
                           Foreground="{DynamicResource TextControlForeground}"
                           ShowLineNumbers="False"
                           HorizontalScrollBarVisibility="Auto"
                           VerticalScrollBarVisibility="Disabled" />
            <!-- Live lint: parse + sanity findings for the staged text, updated per keystroke. -->
            <Border Name="LintBar" BorderBrush="{DynamicResource FieldBorderBrush}" BorderThickness="0,1,0,0"
                    Padding="8,4" IsVisible="False">
              <TextBlock Name="LintText" FontSize="{DynamicResource Fs11}" TextWrapping="Wrap"
                         Foreground="{DynamicResource WarningBrush}" />
            </Border>
          </StackPanel>
        </Border>

        <StackPanel Name="FieldsGrid" IsVisible="{Binding !IsTextMode}">
          <!-- Interface (self-evident top section, no border): the public key shown by
               default (click to copy), a key button reveals the private key to edit or
               regenerate, addresses sit next to it, and the listen port docks right. -->
          <DockPanel Margin="14,4,14,6" IsVisible="{Binding ShowInterfaceSection}">
            <TextBox DockPanel.Dock="Right" Classes="mono fit" MinWidth="0" HorizontalAlignment="Right" VerticalAlignment="Top"
                     Text="{Binding ListenPortText}" Watermark="port" ToolTip.Tip="Listen port (blank = automatic)" />
            <Grid Name="IfaceGrid" ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">
              <StackPanel Name="KeyGroup" Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="4" Margin="0,0,10,0" VerticalAlignment="Top">
                <Panel>
                  <!-- Default: the derived public key, click to copy. -->
                  <Button Classes="keyfield" Command="{Binding CopyPublicKeyCommand}" ToolTip.Tip="{Binding PublicKeyFull}"
                          IsVisible="{Binding !EditingPrivateKey}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <TextBlock Classes="mono synkey" Text="{Binding PublicKeyShort}" VerticalAlignment="Center" />
                      <TextBlock Classes="glyph" Text="&#xE8C8;" FontSize="{DynamicResource Fs11}" Opacity="0.55" VerticalAlignment="Center" />
                    </StackPanel>
                  </Button>
                  <!-- Revealed: the masked private key with only a regenerate button. Fixed to
                       the public display's width so revealing never widens the row. -->
                  <TextBox Classes="mono" Width="150" MinWidth="0" ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                           IsVisible="{Binding EditingPrivateKey}"
                           Text="{Binding PrivateKeyEdit}" Watermark="private key" PasswordChar="●">
                    <TextBox.InnerRightContent>
                      <Button Classes="icon" Command="{Binding GenerateKeyCommand}"
                              ToolTip.Tip="Regenerate the keypair">
                        <TextBlock Classes="glyph" Text="&#xE72C;" FontSize="{DynamicResource Fs12}" Opacity="0.7" />
                      </Button>
                    </TextBox.InnerRightContent>
                  </TextBox>
                </Panel>
                <!-- Single toggle: reveal the private key to edit/regenerate, or hide it. -->
                <ToggleButton Classes="icon" IsChecked="{Binding EditingPrivateKey}" ToolTip.Tip="Edit the private key">
                  <TextBlock Classes="glyph" Text="&#xE70F;" FontSize="{DynamicResource Fs12}" Opacity="0.6" />
                </ToggleButton>
              </StackPanel>
              <!-- Shown only when the addresses can't sit next to the keys (see code-behind). -->
              <TextBlock Name="AddrLabel" Grid.Row="1" Grid.Column="0" Classes="lbl" Text="Addresses"
                         Margin="0,5,10,0" VerticalAlignment="Top" IsVisible="False" />
              <ItemsControl Name="AddrList" Grid.Row="0" Grid.Column="1" ItemsSource="{Binding Addresses}" VerticalAlignment="Top">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.DataTemplates>
                    <DataTemplate DataType="sys:String">
                      <Border Classes="item" Margin="0,0,6,4">
                        <DockPanel>
                          <Button Classes="chipx" ToolTip.Tip="Remove" DockPanel.Dock="Right" VerticalAlignment="Center" Margin="6,0,0,0"
                                  Command="{Binding $parent[ItemsControl].DataContext.RemoveAddressCommand}" CommandParameter="{Binding}">
                            <TextBlock Classes="glyph" Text="&#xE711;" FontSize="{DynamicResource Fs9}" Opacity="0.6" />
                          </Button>
                          <WrapPanel VerticalAlignment="Center">
                            <TextBlock Classes="mono synip" TextWrapping="Wrap" Text="{Binding Converter={x:Static views:Syntax.IpPart}}" />
                            <TextBlock Classes="mono synnum" Text="{Binding Converter={x:Static views:Syntax.MaskPart}}" />
                          </WrapPanel>
                        </DockPanel>
                      </Border>
                    </DataTemplate>
                    <DataTemplate DataType="vm:AddSlot">
                      <TextBox Classes="mono addbox" Margin="0,0,6,4" Watermark="+"
                               Classes.error="{Binding $parent[ItemsControl].DataContext.AddressAddError}"
                               Text="{Binding $parent[ItemsControl].DataContext.NewAddress}">
                        <TextBox.KeyBindings>
                          <KeyBinding Gesture="Enter" Command="{Binding $parent[ItemsControl].DataContext.AddAddressCommand}" />
                        </TextBox.KeyBindings>
                      </TextBox>
                    </DataTemplate>
                  </ItemsControl.DataTemplates>
                </ItemsControl>
            </Grid>
          </DockPanel>

          <!-- Peers: full-width cards stacking vertically. -->
          <StackPanel Name="PeersHost" Margin="0,2,0,2">
            <ItemsControl ItemsSource="{Binding Peers}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <views:PeerBlock />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Button Classes="link" Content="{Binding AddPeerLabel}" Command="{Binding AddPeerCommand}" Margin="12,0,0,6" FontSize="{DynamicResource Fs115}" />
          </StackPanel>
        </StackPanel>

        <TextBlock Classes="warntext" Margin="12,0,12,8" Text="{Binding WarningText}"
                   IsVisible="{Binding WarningText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        <TextBlock Classes="errtext" Margin="12,0,12,8" Text="{Binding ValidationError}"
                   IsVisible="{Binding ValidationError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

        <DockPanel Margin="12,16,12,10">
          <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8">
            <Button Classes="quiet" Command="{Binding ToggleTextModeCommand}" IsVisible="{Binding ShowInterfaceSection}"
                    ToolTip.Tip="Toggle raw config editing (Ctrl+E)">
              <Panel>
                <TextBlock Classes="glyph" Text="&#xE70F;" IsVisible="{Binding !IsTextMode}" />
                <TextBlock Classes="glyph" Text="&#xE80A;" IsVisible="{Binding IsTextMode}" />
              </Panel>
            </Button>
            <Button Classes="quiet" Content="Cancel" Command="{Binding CancelEditCommand}" />
            <Button Classes="primary" Content="Save" Command="{Binding SaveEditCommand}" />
          </StackPanel>
          <Button Classes="danger" Classes.armed="{Binding DeleteArmed}" Content="{Binding DeleteLabel}"
                  Command="{Binding DeleteCommand}" HorizontalAlignment="Left" FontSize="{DynamicResource Fs115}" />
        </DockPanel>
      </StackPanel>
      </Panel>
      </Border>
    </StackPanel>
  </Border>
</UserControl>
