<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             xmlns:vm="clr-namespace:SplitGuard.ViewModels"
             xmlns:views="clr-namespace:SplitGuard.Views"
             xmlns:ae="using:AvaloniaEdit"
             x:Class="SplitGuard.Views.TunnelCard">
  <Border Classes="card" Classes.editing="{Binding IsEditing}" Background="Transparent">
    <StackPanel>
      <DockPanel Margin="12,8" Height="30">
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
          <TextBlock Classes="muted" Text="{Binding HeaderHandshake}" IsVisible="{Binding StatsVisible}" />
          <StackPanel Orientation="Horizontal" Spacing="3" IsVisible="{Binding StatsVisible}">
            <TextBlock Classes="glyph" Text="&#xE74A;" FontSize="11" Opacity="0.6" />
            <TextBlock Classes="mono" Text="{Binding UpRate}" Opacity="0.75" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="3" IsVisible="{Binding StatsVisible}">
            <TextBlock Classes="glyph" Text="&#xE74B;" FontSize="11" Opacity="0.6" />
            <TextBlock Classes="mono" Text="{Binding DownRate}" Opacity="0.75" />
          </StackPanel>
          <TextBlock Classes="muted" Text="Disconnected" IsVisible="{Binding !IsConnected}" />
          <ToggleSwitch IsChecked="{Binding IsConnected}" IsVisible="{Binding !IsExternal}" IsEnabled="{Binding !IsEditing}" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
          <Ellipse Classes="dot" Classes.up="{Binding IsConnected}" />
          <Grid VerticalAlignment="Center">
            <TextBlock FontSize="13.5" FontWeight="Medium" VerticalAlignment="Center" Margin="9,0,0,0"
                       Text="{Binding Name}" IsVisible="{Binding !IsEditing}" />
            <TextBox Width="150" FontSize="13.5" FontWeight="Medium" Text="{Binding Name}" IsVisible="{Binding IsEditing}" />
          </Grid>
          <TextBlock Classes="muted" Text="{Binding CollapsedSummary}" IsVisible="{Binding !IsEditing}" />
          <Border Background="#12808080" CornerRadius="4" Padding="6,2" IsVisible="{Binding IsExternal}" VerticalAlignment="Center">
            <TextBlock FontSize="11" Opacity="0.7" Text="External" />
          </Border>
        </StackPanel>
      </DockPanel>

      <Border Classes="collapsehost" Classes.hidden="{Binding IsEditing}" IsHitTestVisible="{Binding !IsEditing}">
        <DockPanel Margin="30,0,12,8">
          <TextBlock DockPanel.Dock="Right" Classes="mono muted" Margin="12,0,0,0"
                     Text="{Binding CollapsedAllowedIps}" />
          <TextBlock Classes="muted" TextTrimming="CharacterEllipsis" Text="{Binding CollapsedDetail}" />
        </DockPanel>
      </Border>

      <Border Name="ExpandHost" Classes="expandhost" Classes.expanded="{Binding IsEditing}" IsHitTestVisible="{Binding IsEditing}">
      <StackPanel>
        <Separator />

        <Border Margin="12,8" CornerRadius="4" Background="#10808080" BorderBrush="#28808080" BorderThickness="1"
                IsVisible="{Binding IsTextMode}">
          <ae:TextEditor Name="ConfEditor" MinHeight="220" Padding="8,6"
                         FontFamily="Consolas,Courier New,monospace" FontSize="12"
                         Background="Transparent"
                         ShowLineNumbers="False"
                         HorizontalScrollBarVisibility="Auto"
                         VerticalScrollBarVisibility="Auto" />
        </Border>

        <Grid ColumnDefinitions="3*,7*" IsVisible="{Binding !IsTextMode}">
          <StackPanel Grid.Column="0" Margin="12,8" Spacing="8" IsVisible="{Binding ShowInterfaceSection}">
            <StackPanel Spacing="3">
              <TextBlock Classes="lbl" Text="Public key" />
              <StackPanel Orientation="Horizontal" Spacing="6">
                <Border Classes="item">
                  <TextBlock Classes="mono" Text="{Binding PublicKeyShort}" />
                </Border>
                <Button Classes="icon" Command="{Binding CopyPublicKeyCommand}" ToolTip.Tip="Copy full public key">
                  <TextBlock Classes="glyph" Text="&#xE8C8;" FontSize="12" Opacity="0.6" />
                </Button>
              </StackPanel>
            </StackPanel>

            <StackPanel Spacing="3">
              <TextBlock Classes="lbl" Text="Private key · listen port" />
              <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                <TextBox Grid.Column="0" Classes="mono" PasswordChar="●"
                         RevealPassword="{Binding #PrivEye.IsChecked}" Text="{Binding PrivateKeyEdit}" />
                <ToggleButton Grid.Column="1" Name="PrivEye" Background="Transparent" BorderThickness="0" Padding="4" ToolTip.Tip="Reveal">
                  <TextBlock Classes="glyph" Text="&#xE7B3;" FontSize="13" />
                </ToggleButton>
                <Button Grid.Column="2" Classes="icon" Command="{Binding GenerateKeyCommand}" ToolTip.Tip="Generate new keypair">
                  <TextBlock Classes="glyph" Text="&#xE72C;" FontSize="13" Opacity="0.6" />
                </Button>
                <TextBox Grid.Column="3" Classes="mono" Width="56" Text="{Binding ListenPortText}" Watermark="port" ToolTip.Tip="Listen port (blank = automatic)" Margin="4,0,0,0" />
              </Grid>
            </StackPanel>

            <StackPanel Spacing="3">
              <TextBlock Classes="lbl" Text="Address" />
              <ItemsControl ItemsSource="{Binding Addresses}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.DataTemplates>
                  <DataTemplate DataType="sys:String">
                    <Border Classes="item" Margin="0,0,6,4">
                      <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Classes="mono" Text="{Binding}" />
                        <Button Classes="chipx"
                                Command="{Binding $parent[ItemsControl].DataContext.RemoveAddressCommand}" CommandParameter="{Binding}">
                          <TextBlock Classes="glyph" Text="&#xE711;" FontSize="9" Opacity="0.6" />
                        </Button>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                  <DataTemplate DataType="vm:AddSlot">
                    <TextBox Classes="mono addbox" Margin="0,0,6,4" Watermark="+"
                             Classes.error="{Binding $parent[ItemsControl].DataContext.AddressAddError}"
                             Text="{Binding $parent[ItemsControl].DataContext.NewAddress}">
                      <TextBox.KeyBindings>
                        <KeyBinding Gesture="Enter" Command="{Binding $parent[ItemsControl].DataContext.AddAddressCommand}" />
                      </TextBox.KeyBindings>
                    </TextBox>
                  </DataTemplate>
                </ItemsControl.DataTemplates>
              </ItemsControl>
            </StackPanel>
          </StackPanel>

          <Border Grid.Column="1" Name="PeersHost" BorderBrush="#20808080" BorderThickness="1,0,0,0">
            <StackPanel Margin="0,8,0,2">
              <ItemsControl ItemsSource="{Binding Peers}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <views:PeerBlock />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
              <Button Classes="link" Content="+ Add peer" Command="{Binding AddPeerCommand}" Margin="8,0,0,6" FontSize="11.5" />
            </StackPanel>
          </Border>
        </Grid>

        <TextBlock Classes="warntext" Margin="12,0,12,8" Text="{Binding WarningText}"
                   IsVisible="{Binding WarningText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        <TextBlock Classes="errtext" Margin="12,0,12,8" Text="{Binding ValidationError}"
                   IsVisible="{Binding ValidationError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

        <Separator />
        <DockPanel Margin="12,8">
          <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8">
            <Button Content="Cancel" Command="{Binding CancelEditCommand}" />
            <Button Classes="primary" Content="Save" Command="{Binding SaveEditCommand}" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Left">
            <Button Classes="icon" Command="{Binding ToggleTextModeCommand}" IsVisible="{Binding !IsExternal}"
                    ToolTip.Tip="Toggle raw config editing (Ctrl+E)">
              <Panel>
                <TextBlock Classes="glyph" Text="&#xE70F;" Opacity="0.6" IsVisible="{Binding !IsTextMode}" />
                <TextBlock Classes="glyph" Text="&#xE80A;" Opacity="0.6" IsVisible="{Binding IsTextMode}" />
              </Panel>
            </Button>
            <Button Classes="link danger" Classes.armed="{Binding DeleteArmed}" Content="{Binding DeleteLabel}"
                    Command="{Binding DeleteCommand}" FontSize="11.5" />
          </StackPanel>
        </DockPanel>
      </StackPanel>
      </Border>
    </StackPanel>
  </Border>
</UserControl>
