<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             xmlns:vm="clr-namespace:SplitGuard.ViewModels"
             xmlns:views="clr-namespace:SplitGuard.Views"
             xmlns:ae="using:AvaloniaEdit"
             x:Class="SplitGuard.Views.TunnelCard"
             ClipToBounds="False" DragDrop.AllowDrop="True">
  <Border Name="CardShell" Classes="card" Classes.editing="{Binding IsEditing}" Background="{DynamicResource SurfaceBrush}">
    <StackPanel>
      <DockPanel Name="HeaderRow" Background="Transparent" Margin="12,5" Height="{DynamicResource HeaderH}">
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="3" IsVisible="{Binding StatsVisible}">
            <TextBlock Classes="glyph accentfg" Text="&#xE74A;" FontSize="{DynamicResource Fs11}" />
            <TextBlock Classes="mono" Text="{Binding UpRate}" Opacity="0.75" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="3" IsVisible="{Binding StatsVisible}">
            <TextBlock Classes="glyph accentfg" Text="&#xE74B;" FontSize="{DynamicResource Fs11}" />
            <TextBlock Classes="mono" Text="{Binding DownRate}" Opacity="0.75" />
          </StackPanel>
          <StackPanel Name="ConnectBox" Orientation="Horizontal" VerticalAlignment="Center" IsVisible="{Binding ShowConnect}">
            <ToggleButton Classes="conn" Classes.connecting="{Binding ShowConnecting}" IsChecked="{Binding IsConnected}"
                          ToolTip.Tip="Connect / disconnect (saves &amp; applies while editing)" />
          </StackPanel>
        </StackPanel>
        <Grid VerticalAlignment="Center" ColumnDefinitions="Auto,Auto,Auto,*">
          <TextBox Grid.Column="0" MinWidth="60" MaxWidth="240" HorizontalAlignment="Left" VerticalAlignment="Center"
                   FontSize="{DynamicResource Fs17}" FontWeight="Bold"
                   Foreground="{DynamicResource AccentTextBrush}" Text="{Binding Name}"
                   Classes="plainname"
                   IsReadOnly="{Binding !NameEditable}" IsHitTestVisible="{Binding NameEditable}" />
          <!-- Pair (chain): show this device's descriptor QR for another device to scan. By the
               name while editing. Export lives down by the Save/edit row. -->
          <Button Grid.Column="1" Classes="hdr" Name="PairBtn" Margin="6,0,0,0" VerticalAlignment="Center"
                  Command="{Binding ShowPairCommand}" IsVisible="{Binding PairButtonVisible}"
                  ToolTip.Tip="Pair — show this device's code for another device to scan">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Classes="glyph accentfg" Text="&#xE71B;" FontSize="{DynamicResource Fs13}" />
              <TextBlock Text="Pair" FontSize="{DynamicResource Fs12}" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
          <Border Grid.Column="2" Background="{DynamicResource ItemBrush}" CornerRadius="4" Padding="6,2" Margin="10,0,0,0"
                  IsVisible="{Binding IsExternal}" VerticalAlignment="Center">
            <TextBlock FontSize="{DynamicResource Fs11}" Opacity="0.7" Text="External" />
          </Border>
          <TextBlock Grid.Column="3" Classes="mono synip" Margin="10,0,0,0" VerticalAlignment="Center"
                     TextTrimming="CharacterEllipsis" Text="{Binding CollapsedSummary}" IsVisible="{Binding !IsEditing}" />
        </Grid>
      </DockPanel>

      <Border Name="Body" Classes="body">
      <Panel Name="BodyContent">
      <StackPanel Name="DetailPanel" Margin="20,0,12,8" IsHitTestVisible="{Binding !IsEditing}" />

      <!-- Export pane: a QR of the WHOLE tunnel's standalone .conf (Interface + every Peer).
           QR sits left; title / hint / Copy / Save file stack to its right. Swaps in like the
           edit pane; the card clips it to its rounded corners. Wired in code. -->
      <Border Name="ExportOverlay" IsVisible="False">
        <!-- Width-adaptive (see UpdateOverlayLayouts): wide cards keep the QR left with the
             text/buttons beside it; narrow cards stack the QR full-width on top. -->
        <Grid Name="ExportGrid" Margin="16,10,14,14" ColumnDefinitions="Auto,*">
          <Border Name="ExportQrBox" Grid.Column="0" Background="White" CornerRadius="7" Padding="5" VerticalAlignment="Top" Margin="0,0,14,0">
            <Image Name="ExportQr" Width="184" Height="184" RenderOptions.BitmapInterpolationMode="None" />
          </Border>
          <StackPanel Name="ExportSide" Grid.Column="1" Spacing="9">
            <DockPanel>
              <Button DockPanel.Dock="Right" Classes="icon" Name="ExportClose" VerticalAlignment="Top" ToolTip.Tip="Back">
                <TextBlock Classes="glyph" Text="&#xE711;" FontSize="{DynamicResource Fs14}" Opacity="0.7" />
              </Button>
              <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                <TextBlock Classes="glyph accentfg" Text="&#xE72D;" FontSize="{DynamicResource Fs14}" VerticalAlignment="Center" />
                <TextBlock Name="ExportTitle" Text="Export config" Classes="accentfg" FontWeight="Bold" FontSize="{DynamicResource Fs135}" VerticalAlignment="Center" TextWrapping="Wrap" />
              </StackPanel>
            </DockPanel>
            <TextBlock Classes="muted" FontSize="{DynamicResource Fs11}" TextWrapping="Wrap" Text="Scan on another device to clone this tunnel — or:" />
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Classes="hdr" Name="ExportCopy" Padding="11,7">
                <StackPanel Orientation="Horizontal" Spacing="7">
                  <TextBlock Classes="glyph accentfg" Text="&#xE8C8;" FontSize="{DynamicResource Fs13}" />
                  <TextBlock Text="Copy" Classes="setlabel" />
                </StackPanel>
              </Button>
              <Button Classes="hdr" Name="ExportSave" Padding="11,7">
                <StackPanel Orientation="Horizontal" Spacing="7">
                  <TextBlock Classes="glyph accentfg" Text="&#xE896;" FontSize="{DynamicResource Fs13}" />
                  <TextBlock Text="Save file" Classes="setlabel" />
                </StackPanel>
              </Button>
            </StackPanel>
          </StackPanel>
        </Grid>
      </Border>

      <!-- Pair pane: a QR of THIS device's [Peer] descriptor (public key + routes + optional
           endpoint, NO private key) for another device to scan. QR left; description, the
           "reachable at" endpoint, and Copy stack to its right. Wired in code. -->
      <Border Name="PairOverlay" IsVisible="False">
        <Grid Name="PairGrid" Margin="16,10,14,14" ColumnDefinitions="Auto,*">
          <Border Name="PairQrBox" Grid.Column="0" Background="White" CornerRadius="7" Padding="5" VerticalAlignment="Top" Margin="0,0,14,0">
            <Image Name="PairQr" Width="184" Height="184" RenderOptions.BitmapInterpolationMode="None" />
          </Border>
          <StackPanel Name="PairSide" Grid.Column="1" Spacing="9">
            <DockPanel>
              <Button DockPanel.Dock="Right" Classes="icon" Name="PairClose" VerticalAlignment="Top" ToolTip.Tip="Back">
                <TextBlock Classes="glyph" Text="&#xE711;" FontSize="{DynamicResource Fs14}" Opacity="0.7" />
              </Button>
              <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                <TextBlock Classes="glyph accentfg" Text="&#xE71B;" FontSize="{DynamicResource Fs14}" VerticalAlignment="Center" />
                <TextBlock Name="PairTitle" Text="Pair" Classes="accentfg" FontWeight="Bold" FontSize="{DynamicResource Fs135}" VerticalAlignment="Center" TextWrapping="Wrap" />
              </StackPanel>
            </DockPanel>
            <TextBlock Classes="muted" FontSize="{DynamicResource Fs11}" TextWrapping="Wrap"
                       Text="Add a peer on the other device and scan this. It gets this device's key and routes — no private key is shared." />
            <StackPanel Spacing="4">
              <TextBlock Classes="muted" Text="Reachable at (optional)" FontSize="{DynamicResource Fs11}" />
              <TextBox Classes="mono" Text="{Binding PairEndpoint}" Watermark="{Binding PairEndpointHint}" />
            </StackPanel>
            <Button Classes="hdr" Name="PairCopy" Padding="11,7" HorizontalAlignment="Left">
              <StackPanel Orientation="Horizontal" Spacing="7">
                <TextBlock Classes="glyph accentfg" Text="&#xE8C8;" FontSize="{DynamicResource Fs13}" />
                <TextBlock Text="Copy descriptor" Classes="setlabel" />
              </StackPanel>
            </Button>
          </StackPanel>
        </Grid>
      </Border>

      <!-- In-card camera scan pane: the add-peer "scan" button opens the camera HERE (not the
           bottom drawer). The platform scanner's preview fills ScanHost; a decode adds a peer.
           The accent frame + hint overlay the camera on Android; desktop's scanner owns the stage. -->
      <Border Name="ScanOverlay" IsVisible="False">
        <StackPanel Margin="16,10,14,14" Spacing="9">
          <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
            <TextBlock Grid.Column="0" Classes="glyph accentfg" Text="&#xEE6F;" FontSize="{DynamicResource Fs14}" VerticalAlignment="Center" />
            <TextBlock Grid.Column="1" Name="ScanTitle" Text="Scan a peer QR" Classes="accentfg" FontWeight="Bold"
                       FontSize="{DynamicResource Fs135}" Margin="8,0,0,0" VerticalAlignment="Center" />
            <Button Grid.Column="2" Classes="hdr" Name="ScanClose" Padding="10,4">
              <TextBlock Text="Cancel" Classes="setlabel" />
            </Button>
          </Grid>
          <!-- Camera stage: full card width; height follows the width (UpdateOverlayLayouts)
               so a narrow card gets a taller, more usable preview than the old fixed 240. -->
          <Panel Name="ScanStage" Height="240" ClipToBounds="True">
            <Border CornerRadius="10" ClipToBounds="True" Background="#0A0A0A">
              <ContentControl Name="ScanHost" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
            </Border>
            <Border Name="ScanFrame" Width="150" Height="150" HorizontalAlignment="Center" VerticalAlignment="Center"
                    BorderBrush="{DynamicResource AccentBrush}" BorderThickness="2.5" CornerRadius="12" IsHitTestVisible="False" />
            <TextBlock Name="ScanHint" Text="Point at a peer's QR" Classes="muted" FontSize="{DynamicResource Fs11}"
                       HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,8" IsHitTestVisible="False" />
          </Panel>
        </StackPanel>
      </Border>

      <StackPanel Name="ExpandContent" IsHitTestVisible="{Binding IsEditing}">

        <Border Name="EditorHost" Margin="12,8" CornerRadius="4" BorderBrush="{DynamicResource FieldBorderBrush}" BorderThickness="1"
                IsVisible="{Binding IsTextMode}">
          <StackPanel>
            <ae:TextEditor Name="ConfEditor" MinHeight="90" Padding="8,6"
                           FontFamily="Cascadia Mono, Consolas, Courier New, monospace" FontSize="{DynamicResource Fs12}"
                           Background="Transparent"
                           Foreground="{DynamicResource TextControlForeground}"
                           ShowLineNumbers="False"
                           HorizontalScrollBarVisibility="Auto"
                           VerticalScrollBarVisibility="Disabled" />
            <!-- Live lint: parse + sanity findings for the staged text, updated per keystroke. -->
            <Border Name="LintBar" BorderBrush="{DynamicResource FieldBorderBrush}" BorderThickness="0,1,0,0"
                    Padding="8,4" IsVisible="False">
              <TextBlock Name="LintText" FontSize="{DynamicResource Fs11}" TextWrapping="Wrap"
                         Foreground="{DynamicResource WarningBrush}" />
            </Border>
          </StackPanel>
        </Border>

        <StackPanel Name="FieldsGrid" IsVisible="{Binding !IsTextMode}">
          <!-- Interface identity as two labelled rows — "Keys" (the derived public key
               stretches across to the port box; the reveal toggle swaps in the private key)
               and "Addresses" (chips wrapping the full width). No adaptive re-flow: a
               narrow card just trims the key. -->
          <Grid Margin="14,4,14,6" IsVisible="{Binding ShowInterfaceSection}"
                ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
            <TextBlock Grid.Row="0" Grid.Column="0" Classes="lbl" Text="Keys" MinWidth="46"
                       VerticalAlignment="Center" Margin="0,0,8,4" />
            <DockPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,4">
              <!-- Single toggle: reveal the private key to edit/regenerate, or hide it. -->
              <ToggleButton DockPanel.Dock="Right" Classes="icon" Margin="4,0,0,0" VerticalAlignment="Center"
                            IsChecked="{Binding EditingPrivateKey}" ToolTip.Tip="Edit the private key">
                <TextBlock Classes="glyph" Text="&#xE70F;" FontSize="{DynamicResource Fs12}" Opacity="0.6" />
              </ToggleButton>
              <Panel>
                <!-- Default: the derived public key, click to copy; fills the row and trims. -->
                <Button Classes="keyfield" HorizontalAlignment="Stretch" Command="{Binding CopyPublicKeyCommand}"
                        ToolTip.Tip="{Binding PublicKeyFull}" IsVisible="{Binding !EditingPrivateKey}">
                  <DockPanel>
                    <TextBlock DockPanel.Dock="Right" Classes="glyph" Text="&#xE8C8;" FontSize="{DynamicResource Fs11}"
                               Opacity="0.55" VerticalAlignment="Center" Margin="6,0,0,0" />
                    <TextBlock Classes="mono synkey" Text="{Binding PublicKeyFull}"
                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                  </DockPanel>
                </Button>
                <!-- Revealed: the masked private key with only a regenerate button. -->
                <TextBox Classes="mono" MinWidth="0" ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                         IsVisible="{Binding EditingPrivateKey}"
                         Text="{Binding PrivateKeyEdit}" Watermark="private key" PasswordChar="●">
                  <TextBox.InnerRightContent>
                    <Button Classes="icon" Command="{Binding GenerateKeyCommand}"
                            ToolTip.Tip="Regenerate the keypair">
                      <TextBlock Classes="glyph" Text="&#xE72C;" FontSize="{DynamicResource Fs12}" Opacity="0.7" />
                    </Button>
                  </TextBox.InnerRightContent>
                </TextBox>
              </Panel>
            </DockPanel>
            <TextBox Grid.Row="0" Grid.Column="2" Classes="mono fit" MinWidth="0" Margin="10,0,0,4" VerticalAlignment="Center"
                     Text="{Binding ListenPortText}" Watermark="port" ToolTip.Tip="Listen port (blank = automatic)" />
            <TextBlock Grid.Row="1" Grid.Column="0" Classes="lbl" Text="Addresses" MinWidth="46"
                       Margin="0,5,8,0" VerticalAlignment="Top" />
            <ItemsControl Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" ItemsSource="{Binding Addresses}" VerticalAlignment="Top">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.DataTemplates>
                    <DataTemplate DataType="sys:String">
                      <Border Classes="item" Margin="0,0,6,4">
                        <DockPanel>
                          <Button Classes="chipx" ToolTip.Tip="Remove" DockPanel.Dock="Right" VerticalAlignment="Center" Margin="6,0,0,0"
                                  Command="{Binding $parent[ItemsControl].DataContext.RemoveAddressCommand}" CommandParameter="{Binding}">
                            <TextBlock Classes="glyph" Text="&#xE711;" FontSize="{DynamicResource Fs9}" Opacity="0.6" />
                          </Button>
                          <!-- Horizontal + NoWrap: an IP is one token, so keep it on a single line
                               (the outer WrapPanel flows whole chips to the next line instead). -->
                          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Classes="mono synip" TextWrapping="NoWrap" Text="{Binding Converter={x:Static views:Syntax.IpPart}}" />
                            <TextBlock Classes="mono synnum" TextWrapping="NoWrap" Text="{Binding Converter={x:Static views:Syntax.MaskPart}}" />
                          </StackPanel>
                        </DockPanel>
                      </Border>
                    </DataTemplate>
                    <DataTemplate DataType="vm:AddSlot">
                      <TextBox Classes="mono addbox" Margin="0,0,6,4" Watermark="+"
                               Classes.error="{Binding $parent[ItemsControl].DataContext.AddressAddError}"
                               Text="{Binding $parent[ItemsControl].DataContext.NewAddress}">
                        <TextBox.KeyBindings>
                          <KeyBinding Gesture="Enter" Command="{Binding $parent[ItemsControl].DataContext.AddAddressCommand}" />
                        </TextBox.KeyBindings>
                      </TextBox>
                    </DataTemplate>
                  </ItemsControl.DataTemplates>
                </ItemsControl>
          </Grid>

          <!-- Peers: full-width cards stacking vertically. -->
          <StackPanel Name="PeersHost" Margin="0,2,0,2">
            <ItemsControl ItemsSource="{Binding Peers}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <views:PeerBlock />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="12,0,0,6">
              <Button Classes="link" Command="{Binding AddPeerCommand}" FontSize="{DynamicResource Fs115}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Classes="glyph accentfg" Text="&#xE710;" FontSize="{DynamicResource Fs12}" />
                  <TextBlock Text="{Binding AddPeerLabel}" VerticalAlignment="Center" />
                </StackPanel>
              </Button>
              <!-- Scan / paste a peer's descriptor QR to add it (drop a QR on the card works too). -->
              <Button Classes="link" Name="ScanPeerBtn" Click="OnScanPeerClick" IsVisible="{Binding ShowInterfaceSection}"
                      FontSize="{DynamicResource Fs115}" ToolTip.Tip="Scan or paste a peer's code to add it">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Classes="glyph accentfg" Text="&#xEE6F;" FontSize="{DynamicResource Fs12}" />
                  <TextBlock Text="Scan peer" VerticalAlignment="Center" />
                </StackPanel>
              </Button>
            </StackPanel>
          </StackPanel>
        </StackPanel>

        <TextBlock Classes="warntext" Margin="12,0,12,8" Text="{Binding WarningText}"
                   IsVisible="{Binding WarningText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        <TextBlock Classes="errtext" Margin="12,0,12,8" Text="{Binding ValidationError}"
                   IsVisible="{Binding ValidationError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

        <DockPanel Margin="12,16,12,10">
          <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8">
            <!-- Export the whole tunnel .conf (QR / copy / save) — next to the raw-editor pen. -->
            <Button Classes="quiet" Name="ExportBtn" Command="{Binding ShowExportCommand}" IsVisible="{Binding CanExport}"
                    ToolTip.Tip="Export tunnel configuration (QR / copy / save)">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Classes="glyph accentfg" Text="&#xE72D;" />
                <TextBlock Text="Export" VerticalAlignment="Center" />
              </StackPanel>
            </Button>
            <Button Classes="quiet" Command="{Binding ToggleTextModeCommand}" IsVisible="{Binding ShowInterfaceSection}"
                    ToolTip.Tip="Toggle raw config editing (Ctrl+E)">
              <Panel>
                <TextBlock Classes="glyph" Text="&#xE70F;" IsVisible="{Binding !IsTextMode}" />
                <TextBlock Classes="glyph" Text="&#xE80A;" IsVisible="{Binding IsTextMode}" />
              </Panel>
            </Button>
            <Button Classes="quiet" Content="Cancel" Command="{Binding CancelEditCommand}" />
            <Button Classes="primary" Content="Save" Command="{Binding SaveEditCommand}" />
          </StackPanel>
          <Button Classes="danger" Classes.armed="{Binding DeleteArmed}" Content="{Binding DeleteLabel}"
                  Command="{Binding DeleteCommand}" HorizontalAlignment="Left" FontSize="{DynamicResource Fs115}" />
        </DockPanel>
      </StackPanel>
      </Panel>
      </Border>
    </StackPanel>
  </Border>
</UserControl>
