<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             xmlns:vm="clr-namespace:SplitGuard.ViewModels"
             xmlns:views="clr-namespace:SplitGuard.Views"
             xmlns:ae="using:AvaloniaEdit"
             x:Class="SplitGuard.Views.TunnelCard">
  <Border Classes="card" Classes.editing="{Binding IsEditing}" Background="{DynamicResource SurfaceBrush}">
    <Grid ColumnDefinitions="Auto,*">
      <Border Grid.Column="0" Width="4" Background="{DynamicResource AccentBrush}" />
      <StackPanel Grid.Column="1">
      <DockPanel Name="HeaderRow" Background="Transparent" Margin="12,8" Height="{DynamicResource HeaderH}">
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="3" IsVisible="{Binding StatsVisible}">
            <TextBlock Classes="glyph accentfg" Text="&#xE74A;" FontSize="{DynamicResource Fs11}" />
            <TextBlock Classes="mono" Text="{Binding UpRate}" Opacity="0.75" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="3" IsVisible="{Binding StatsVisible}">
            <TextBlock Classes="glyph accentfg" Text="&#xE74B;" FontSize="{DynamicResource Fs11}" />
            <TextBlock Classes="mono" Text="{Binding DownRate}" Opacity="0.75" />
          </StackPanel>
          <StackPanel Name="ConnectBox" Orientation="Horizontal" VerticalAlignment="Center" IsVisible="{Binding ShowConnect}">
            <ToggleButton Classes="conn" IsChecked="{Binding IsConnected}"
                          ToolTip.Tip="Connect / disconnect (saves &amp; applies while editing)">
              <TextBlock Classes="glyph" Text="&#xE7E8;" FontSize="{DynamicResource Fs17}" />
            </ToggleButton>
          </StackPanel>
        </StackPanel>
        <Grid VerticalAlignment="Center" ColumnDefinitions="Auto,Auto,Auto,*">
          <Ellipse Grid.Column="0" Name="StatusDot" Classes="dot" Classes.up="{Binding ShowUp}" Classes.connecting="{Binding ShowConnecting}"
                   PointerPressed="OnDotPressed" ToolTip.Tip="{Binding ConnLabel}" />
          <TextBox Grid.Column="1" MinWidth="60" HorizontalAlignment="Left" Margin="10,0,0,0" VerticalAlignment="Center"
                   FontSize="{DynamicResource Fs17}" FontWeight="SemiBold"
                   Foreground="{DynamicResource AccentBrush}" Text="{Binding Name}"
                   Classes.plainname="{Binding !NameEditable}"
                   IsReadOnly="{Binding !NameEditable}" IsHitTestVisible="{Binding NameEditable}" />
          <Border Grid.Column="2" Background="{DynamicResource ItemBrush}" CornerRadius="4" Padding="6,2" Margin="10,0,0,0"
                  IsVisible="{Binding IsExternal}" VerticalAlignment="Center">
            <TextBlock FontSize="{DynamicResource Fs11}" Opacity="0.7" Text="External" />
          </Border>
          <TextBlock Grid.Column="3" Classes="mono synip" Margin="10,0,0,0" VerticalAlignment="Center"
                     TextTrimming="CharacterEllipsis" Text="{Binding CollapsedSummary}" IsVisible="{Binding !IsEditing}" />
        </Grid>
      </DockPanel>

      <Border Name="Body" Classes="body">
      <Panel>
      <StackPanel Name="DetailPanel" Margin="30,0,12,8" IsHitTestVisible="{Binding !IsEditing}" />
      <StackPanel Name="ExpandContent" IsHitTestVisible="{Binding IsEditing}">
        <Separator />

        <Border Name="EditorHost" Margin="12,8" CornerRadius="4" BorderBrush="{DynamicResource FieldBorderBrush}" BorderThickness="1"
                IsVisible="{Binding IsTextMode}">
          <ae:TextEditor Name="ConfEditor" MinHeight="90" Padding="8,6"
                         FontFamily="Cascadia Mono, Consolas, Courier New, monospace" FontSize="{DynamicResource Fs12}"
                         Background="Transparent"
                         Foreground="{DynamicResource TextControlForeground}"
                         ShowLineNumbers="False"
                         HorizontalScrollBarVisibility="Auto"
                         VerticalScrollBarVisibility="Disabled" />
        </Border>

        <StackPanel Name="FieldsGrid" IsVisible="{Binding !IsTextMode}">
          <!-- Interface: one full-width line — keys and addresses flow left, generate +
               listen port dock to the upper-right corner. -->
          <Border Classes="peerblock" Margin="12,8,12,6" IsVisible="{Binding ShowInterfaceSection}">
            <StackPanel Margin="10,6,12,6">
              <!-- Interface bar: title · public key (copy) · private key (generate) · port -->
              <DockPanel Margin="0,0,0,6">
                <TextBox DockPanel.Dock="Right" Classes="mono" Width="56" VerticalAlignment="Center"
                         Text="{Binding ListenPortText}" Watermark="port" ToolTip.Tip="Listen port (blank = automatic)" />
                <Grid ColumnDefinitions="Auto,*,*" VerticalAlignment="Center" Margin="0,0,8,0">
                  <TextBlock Grid.Column="0" Classes="accentfg" FontSize="{DynamicResource Fs115}" FontWeight="Medium" VerticalAlignment="Center" Text="Interface" Margin="0,0,8,0" />
                  <TextBox Grid.Column="1" Classes="mono synkey" MinWidth="40" Text="{Binding PublicKeyFull}" IsReadOnly="True"
                           ToolTip.Tip="{Binding PublicKeyFull}" Margin="0,0,6,0">
                    <TextBox.InnerRightContent>
                      <Button Classes="icon" Command="{Binding CopyPublicKeyCommand}" ToolTip.Tip="Copy public key">
                        <TextBlock Classes="glyph" Text="&#xE8C8;" FontSize="{DynamicResource Fs12}" Opacity="0.6" />
                      </Button>
                    </TextBox.InnerRightContent>
                  </TextBox>
                  <TextBox Grid.Column="2" Classes="mono" MinWidth="40" Text="{Binding PrivateKeyEdit}" Watermark="private key">
                    <TextBox.InnerRightContent>
                      <Button Classes="icon" Command="{Binding GenerateKeyCommand}" IsVisible="{Binding CanGenerate}"
                              ToolTip.Tip="Generate a keypair">
                        <TextBlock Classes="glyph" Text="&#xE72C;" FontSize="{DynamicResource Fs12}" Opacity="0.7" />
                      </Button>
                    </TextBox.InnerRightContent>
                  </TextBox>
                </Grid>
              </DockPanel>
              <Grid ColumnDefinitions="70,*" RowDefinitions="Auto">
                <!-- Addresses on their own line. -->
                <TextBlock Grid.Row="0" Grid.Column="0" Classes="lbl" VerticalAlignment="Top" Text="Addresses" Margin="0,5,10,0" />
                <ItemsControl Grid.Row="0" Grid.Column="1" ItemsSource="{Binding Addresses}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.DataTemplates>
                    <DataTemplate DataType="sys:String">
                      <Border Classes="item" Margin="0,0,6,4">
                        <DockPanel>
                          <Button Classes="chipx" DockPanel.Dock="Right" VerticalAlignment="Center" Margin="6,0,0,0"
                                  Command="{Binding $parent[ItemsControl].DataContext.RemoveAddressCommand}" CommandParameter="{Binding}">
                            <TextBlock Classes="glyph" Text="&#xE711;" FontSize="{DynamicResource Fs9}" Opacity="0.6" />
                          </Button>
                          <WrapPanel VerticalAlignment="Center">
                            <TextBlock Classes="mono synip" TextWrapping="Wrap" Text="{Binding Converter={x:Static views:Syntax.IpPart}}" />
                            <TextBlock Classes="mono synnum" Text="{Binding Converter={x:Static views:Syntax.MaskPart}}" />
                          </WrapPanel>
                        </DockPanel>
                      </Border>
                    </DataTemplate>
                    <DataTemplate DataType="vm:AddSlot">
                      <TextBox Classes="mono addbox" Margin="0,0,6,4" Watermark="+"
                               Classes.error="{Binding $parent[ItemsControl].DataContext.AddressAddError}"
                               Text="{Binding $parent[ItemsControl].DataContext.NewAddress}">
                        <TextBox.KeyBindings>
                          <KeyBinding Gesture="Enter" Command="{Binding $parent[ItemsControl].DataContext.AddAddressCommand}" />
                        </TextBox.KeyBindings>
                      </TextBox>
                    </DataTemplate>
                  </ItemsControl.DataTemplates>
                </ItemsControl>
              </Grid>
            </StackPanel>
          </Border>

          <!-- Peers: full-width cards stacking vertically. -->
          <StackPanel Name="PeersHost" Margin="0,2,0,2">
            <ItemsControl ItemsSource="{Binding Peers}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <views:PeerBlock />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Button Classes="link" Content="{Binding AddPeerLabel}" Command="{Binding AddPeerCommand}" Margin="12,0,0,6" FontSize="{DynamicResource Fs115}" />
          </StackPanel>
        </StackPanel>

        <TextBlock Classes="warntext" Margin="12,0,12,8" Text="{Binding WarningText}"
                   IsVisible="{Binding WarningText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        <TextBlock Classes="errtext" Margin="12,0,12,8" Text="{Binding ValidationError}"
                   IsVisible="{Binding ValidationError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

        <Separator />
        <DockPanel Margin="12,8">
          <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8">
            <Button Command="{Binding ToggleTextModeCommand}" IsVisible="{Binding ShowInterfaceSection}"
                    ToolTip.Tip="Toggle raw config editing (Ctrl+E)">
              <Panel>
                <TextBlock Classes="glyph" Text="&#xE70F;" IsVisible="{Binding !IsTextMode}" />
                <TextBlock Classes="glyph" Text="&#xE80A;" IsVisible="{Binding IsTextMode}" />
              </Panel>
            </Button>
            <Button Content="Cancel" Command="{Binding CancelEditCommand}" />
            <Button Classes="primary" Content="Save" Command="{Binding SaveEditCommand}" />
          </StackPanel>
          <Button Classes="danger" Classes.armed="{Binding DeleteArmed}" Content="{Binding DeleteLabel}"
                  Command="{Binding DeleteCommand}" HorizontalAlignment="Left" FontSize="{DynamicResource Fs115}" />
        </DockPanel>
      </StackPanel>
      </Panel>
      </Border>
      </StackPanel>
    </Grid>
  </Border>
</UserControl>
