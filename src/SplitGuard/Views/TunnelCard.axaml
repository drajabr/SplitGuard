<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             xmlns:vm="clr-namespace:SplitGuard.ViewModels"
             xmlns:views="clr-namespace:SplitGuard.Views"
             xmlns:ae="using:AvaloniaEdit"
             x:Class="SplitGuard.Views.TunnelCard">
  <Border Classes="card" Classes.editing="{Binding IsEditing}" Background="{DynamicResource SurfaceBrush}">
    <StackPanel>
      <DockPanel Name="HeaderRow" Margin="12,8" Height="{DynamicResource HeaderH}">
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
          <TextBlock Classes="muted" Text="{Binding HeaderHandshake}" IsVisible="{Binding StatsVisible}" />
          <StackPanel Orientation="Horizontal" Spacing="3" IsVisible="{Binding StatsVisible}">
            <TextBlock Classes="glyph accentfg" Text="&#xE74A;" FontSize="{DynamicResource Fs11}" />
            <TextBlock Classes="mono" Text="{Binding UpRate}" Opacity="0.75" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="3" IsVisible="{Binding StatsVisible}">
            <TextBlock Classes="glyph accentfg" Text="&#xE74B;" FontSize="{DynamicResource Fs11}" />
            <TextBlock Classes="mono" Text="{Binding DownRate}" Opacity="0.75" />
          </StackPanel>
          <ToggleSwitch IsChecked="{Binding IsConnected}" IsVisible="{Binding !IsExternal}" IsEnabled="{Binding !IsEditing}"
                        OnContent="Connected" OffContent="Disconnected" MinWidth="0" />
        </StackPanel>
        <Grid VerticalAlignment="Center" ColumnDefinitions="Auto,Auto,Auto,*">
          <Ellipse Grid.Column="0" Classes="dot" Classes.up="{Binding IsConnected}" />
          <TextBox Grid.Column="1" MinWidth="60" HorizontalAlignment="Left" Margin="10,0,0,0" VerticalAlignment="Center"
                   FontSize="{DynamicResource Fs135}" FontWeight="Medium"
                   Foreground="{DynamicResource AccentBrush}" Text="{Binding Name}"
                   Classes.plainname="{Binding !IsEditing}"
                   IsReadOnly="{Binding !IsEditing}" IsHitTestVisible="{Binding IsEditing}" />
          <Border Grid.Column="2" Background="{DynamicResource ItemBrush}" CornerRadius="4" Padding="6,2" Margin="10,0,0,0"
                  IsVisible="{Binding IsExternal}" VerticalAlignment="Center">
            <TextBlock FontSize="{DynamicResource Fs11}" Opacity="0.7" Text="External" />
          </Border>
          <TextBlock Grid.Column="3" Classes="muted" Margin="10,0,0,0" VerticalAlignment="Center"
                     TextTrimming="CharacterEllipsis" Text="{Binding CollapsedSummary}" IsVisible="{Binding !IsEditing}" />
        </Grid>
      </DockPanel>

      <Border Classes="collapsehost" Classes.hidden="{Binding IsEditing}" IsHitTestVisible="{Binding !IsEditing}">
        <DockPanel Margin="30,0,12,8">
          <TextBlock DockPanel.Dock="Right" Classes="mono synip" Margin="12,0,0,0" Opacity="0.8"
                     VerticalAlignment="Top" Text="{Binding CollapsedAllowedIps}" />
          <WrapPanel Name="DetailPanel" VerticalAlignment="Top" />
        </DockPanel>
      </Border>

      <Border Name="ExpandHost" Classes="expandhost" Classes.expanded="{Binding IsEditing}" IsHitTestVisible="{Binding IsEditing}">
      <StackPanel>
        <Separator />

        <Border Name="EditorHost" Margin="12,8" CornerRadius="4" BorderBrush="{DynamicResource FieldBorderBrush}" BorderThickness="1"
                IsVisible="{Binding IsTextMode}">
          <ae:TextEditor Name="ConfEditor" MinHeight="90" Padding="8,6"
                         FontFamily="Cascadia Mono, Consolas, Courier New, monospace" FontSize="{DynamicResource Fs12}"
                         Background="Transparent"
                         Foreground="{DynamicResource TextControlForeground}"
                         ShowLineNumbers="False"
                         HorizontalScrollBarVisibility="Auto"
                         VerticalScrollBarVisibility="Disabled" />
        </Border>

        <Grid Name="FieldsGrid" ColumnDefinitions="3*,7*" IsVisible="{Binding !IsTextMode}">
          <StackPanel Grid.Column="0" Margin="12,8" Spacing="8" IsVisible="{Binding ShowInterfaceSection}">
            <StackPanel Spacing="3">
              <TextBlock Classes="lbl" Text="Public key" />
              <DockPanel>
                <Button DockPanel.Dock="Right" Classes="icon" Margin="6,0,0,0" Command="{Binding CopyPublicKeyCommand}" ToolTip.Tip="Copy full public key">
                  <TextBlock Classes="glyph" Text="&#xE8C8;" FontSize="{DynamicResource Fs12}" Opacity="0.6" />
                </Button>
                <Border Classes="item">
                  <TextBlock Classes="mono synkey" Text="{Binding PublicKeyFull}" TextTrimming="CharacterEllipsis" />
                </Border>
              </DockPanel>
            </StackPanel>

            <StackPanel Spacing="3">
              <TextBlock Classes="lbl" Text="Private key · listen port" />
              <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                <TextBox Grid.Column="0" Classes="mono" PasswordChar="●"
                         RevealPassword="{Binding #PrivEye.IsChecked}" Text="{Binding PrivateKeyEdit}" />
                <ToggleButton Grid.Column="1" Name="PrivEye" Background="Transparent" BorderThickness="0" Padding="4" ToolTip.Tip="Reveal">
                  <TextBlock Classes="glyph" Text="&#xE7B3;" FontSize="{DynamicResource Fs13}" />
                </ToggleButton>
                <Button Grid.Column="2" Classes="icon" Command="{Binding GenerateKeyCommand}" ToolTip.Tip="Generate new keypair">
                  <TextBlock Classes="glyph" Text="&#xE72C;" FontSize="{DynamicResource Fs13}" Opacity="0.6" />
                </Button>
                <TextBox Grid.Column="3" Classes="mono" Width="56" Text="{Binding ListenPortText}" Watermark="port" ToolTip.Tip="Listen port (blank = automatic)" Margin="4,0,0,0" />
              </Grid>
            </StackPanel>

            <StackPanel Spacing="3">
              <TextBlock Classes="lbl" Text="Address" />
              <ItemsControl ItemsSource="{Binding Addresses}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.DataTemplates>
                  <DataTemplate DataType="sys:String">
                    <Border Classes="item" Margin="0,0,6,4">
                      <StackPanel Orientation="Horizontal" Spacing="6">
                        <StackPanel Orientation="Horizontal">
                          <TextBlock Classes="mono synip" Text="{Binding Converter={x:Static views:Syntax.IpPart}}" />
                          <TextBlock Classes="mono synnum" Text="{Binding Converter={x:Static views:Syntax.MaskPart}}" />
                        </StackPanel>
                        <Button Classes="chipx"
                                Command="{Binding $parent[ItemsControl].DataContext.RemoveAddressCommand}" CommandParameter="{Binding}">
                          <TextBlock Classes="glyph" Text="&#xE711;" FontSize="{DynamicResource Fs9}" Opacity="0.6" />
                        </Button>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                  <DataTemplate DataType="vm:AddSlot">
                    <TextBox Classes="mono addbox" Margin="0,0,6,4" Watermark="+"
                             Classes.error="{Binding $parent[ItemsControl].DataContext.AddressAddError}"
                             Text="{Binding $parent[ItemsControl].DataContext.NewAddress}">
                      <TextBox.KeyBindings>
                        <KeyBinding Gesture="Enter" Command="{Binding $parent[ItemsControl].DataContext.AddAddressCommand}" />
                      </TextBox.KeyBindings>
                    </TextBox>
                  </DataTemplate>
                </ItemsControl.DataTemplates>
              </ItemsControl>
            </StackPanel>
          </StackPanel>

          <Border Grid.Column="1" Name="PeersHost" BorderBrush="{DynamicResource HairlineBrush}" BorderThickness="1,0,0,0">
            <StackPanel Margin="0,8,0,2">
              <ItemsControl ItemsSource="{Binding Peers}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <views:PeerBlock />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
              <Button Classes="link" Content="+ Add peer" Command="{Binding AddPeerCommand}" Margin="8,0,0,6" FontSize="{DynamicResource Fs115}" />
            </StackPanel>
          </Border>
        </Grid>

        <TextBlock Classes="warntext" Margin="12,0,12,8" Text="{Binding WarningText}"
                   IsVisible="{Binding WarningText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        <TextBlock Classes="errtext" Margin="12,0,12,8" Text="{Binding ValidationError}"
                   IsVisible="{Binding ValidationError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

        <Separator />
        <DockPanel Margin="12,8">
          <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8">
            <Button Command="{Binding ToggleTextModeCommand}" IsVisible="{Binding !IsExternal}"
                    ToolTip.Tip="Toggle raw config editing (Ctrl+E)">
              <Panel>
                <TextBlock Classes="glyph" Text="&#xE70F;" IsVisible="{Binding !IsTextMode}" />
                <TextBlock Classes="glyph" Text="&#xE80A;" IsVisible="{Binding IsTextMode}" />
              </Panel>
            </Button>
            <Button Content="Cancel" Command="{Binding CancelEditCommand}" />
            <Button Classes="primary" Content="Save" Command="{Binding SaveEditCommand}" />
          </StackPanel>
          <Button Classes="danger" Classes.armed="{Binding DeleteArmed}" Content="{Binding DeleteLabel}"
                  Command="{Binding DeleteCommand}" HorizontalAlignment="Left" FontSize="{DynamicResource Fs115}" />
        </DockPanel>
      </StackPanel>
      </Border>
    </StackPanel>
  </Border>
</UserControl>
