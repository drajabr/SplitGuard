<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:SplitGuard.Views"
             x:Class="SplitGuard.Views.MainView">
  <!-- PageRoot carries the themed page background. It must live on a control that actually
       renders its Background: a Window under ExtendClientAreaToDecorationsHint does NOT paint its
       own Background behind a UserControl child (the page went black on light themes), so the
       shared view paints the page itself. Because the strip is now opaque, native caption
       fall-through can't drag the window, so the title strip drives BeginMoveDrag explicitly. -->
  <DockPanel Name="PageRoot">
    <!-- Title strip inside the extended-client title bar: same color as the page (PageRoot paints
         it), and empty areas start a window move-drag (code-behind); the update button and logo
         opt out (button captures the pointer, logo/text are hit-test-invisible). -->
    <Panel DockPanel.Dock="Top" Name="TitleStrip" Background="Transparent">
      <Border Padding="14,5,146,5">
        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <Image Name="LogoImage" Source="avares://SplitGuard.Core/Assets/app.ico" Width="24" Height="24"
                 VerticalAlignment="Center" IsHitTestVisible="False" />
          <TextBlock Text="SplitGuard" FontSize="{DynamicResource Fs17}" FontWeight="SemiBold"
                     VerticalAlignment="Center" IsHitTestVisible="False" />
          <TextBlock Text="{Binding CurrentVersionText}" FontSize="{DynamicResource Fs11}" Opacity="0.5"
                     VerticalAlignment="Bottom" Margin="0,0,0,3" IsHitTestVisible="False" />
          <!-- Update affordance: hidden until a check/download is happening or an update is
               ready (accent glyph). First click downloads, a second installs. -->
          <Button Classes="hdr" Name="UpdateButton" Click="OnUpdateClick" VerticalAlignment="Center"
                  IsVisible="{Binding UpdateVisible}" ToolTip.Tip="{Binding UpdateTooltip}">
            <TextBlock Classes="glyph updicon" Classes.hot="{Binding UpdateHighlight}"
                       Text="{Binding UpdateGlyph}" FontSize="{DynamicResource Fs12}" />
          </Button>
        </StackPanel>
      </Border>
    </Panel>

    <!-- Grid (not a horizontal StackPanel) so the text gets a finite width and actually wraps
         instead of clipping off the right edge at narrow window widths. -->
    <Border DockPanel.Dock="Top" Background="{DynamicResource WarningBgBrush}" Padding="14,8" IsVisible="{Binding GpoWarning}">
      <Grid ColumnDefinitions="Auto,*">
        <TextBlock Grid.Column="0" Classes="glyph" Foreground="{DynamicResource WarningBrush}" Text="&#xE7BA;"
                   VerticalAlignment="Top" Margin="0,2,8,0" />
        <TextBlock Grid.Column="1" FontSize="{DynamicResource Fs12}" TextWrapping="Wrap" VerticalAlignment="Center"
                   Text="Group Policy DNS rules are active on this machine and override local ones — this tool's rules won't take effect." />
      </Grid>
    </Border>

    <!-- Everything below the title is one layered Panel: the list scrolls the FULL height, and
         the bottom cluster (Add drawer, Settings drawer, bottom bar) floats on top of it with a
         shadow — content visibly slides underneath instead of being clipped dead against it. -->
    <Panel Name="ListHost" ClipToBounds="True">
      <ScrollViewer Name="MainScroll" Focusable="True" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Hidden">
        <!-- Top margin = breathing room under the docked title strip (enough for the first
             card's glow to fade); the 70px bottom reserves the floating bottom bar's footprint
             so the last card can scroll fully clear of it. -->
        <StackPanel Margin="14,10,14,70">
          <ItemsControl ItemsSource="{Binding Tunnels}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <!-- Gap must exceed the elevation shadow's bottom reach (offset+blur), or two
                     stacked cards' shadows fill the whole gap edge-to-edge and read as a hard
                     clipped band instead of a fade. -->
                <views:TunnelCard Margin="0,0,0,16" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </ScrollViewer>

      <!-- Empty state: an inviting dashed dropzone instead of a wall of text. -->
      <Rectangle Classes="dropzone" IsVisible="{Binding !Tunnels.Count}"
                 Margin="14,10,14,70" IsHitTestVisible="False" />
      <StackPanel IsVisible="{Binding !Tunnels.Count}" VerticalAlignment="Center"
                  HorizontalAlignment="Center" Spacing="10" Margin="40,0,40,58">
        <TextBlock Classes="glyph" Text="&#xE8B5;" FontSize="34" Opacity="0.35" HorizontalAlignment="Center" />
        <TextBlock FontSize="{DynamicResource Fs14}" HorizontalAlignment="Center"
                   Text="Drop a WireGuard .conf here" />
        <TextBlock Classes="muted" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="330"
                   Text="or paste a config with Ctrl+V. Domains you attach to a peer resolve through that peer's DNS while connected; everything else keeps your normal system DNS." />
        <Button Classes="primary" Content="Add tunnel" HorizontalAlignment="Center" Margin="0,4,0,0"
                Click="OnAddToggleClick" />
      </StackPanel>

      <!-- Drag-over feedback: shown while a .conf hovers anywhere over the window. -->
      <Panel Name="DropOverlay" IsVisible="False" IsHitTestVisible="False" Margin="14,10,14,70">
        <Rectangle Classes="dropzone active" />
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
          <TextBlock Classes="glyph accentfg" Text="&#xE896;" FontSize="30" HorizontalAlignment="Center" />
          <TextBlock Classes="accentfg" FontSize="{DynamicResource Fs14}" HorizontalAlignment="Center" Text="Drop to import" />
        </StackPanel>
      </Panel>

      <!-- Floating bottom cluster. Drawers grow upward (bottom-anchored stack); their Height AND
           vertical margins are animated by the code-behind (closed = zero footprint, so the open
           drawer always sits 8px above the bar). Clipping lives on an INNER panel so the Border
           itself can round its background and cast a shadow without clipping either. The
           yield-to-content fade targets the three child Borders individually (never this
           StackPanel — an opacity layer on the parent would clip the children's BoxShadows);
           the transparent background keeps the full rect hover-sensitive. -->
      <StackPanel Name="BottomCluster" VerticalAlignment="Bottom" Background="Transparent">
        <!-- Expandable Add drawer: each row is an action with its keyboard shortcut flushed
             right, like a menu accelerator. -->
        <Border Name="AddRegion" Classes="drawer"
                Background="{DynamicResource MenuSurfaceBrush}" BorderBrush="{DynamicResource HairlineBrush}"
                BorderThickness="1" CornerRadius="8" Margin="14,0,14,0" Height="0" IsVisible="False">
          <Panel ClipToBounds="True">
            <StackPanel Name="AddCard" Spacing="1" Margin="6" VerticalAlignment="Bottom">
              <!-- Camera QR import (Android): leads the Add menu; hidden where there's no camera flow. -->
              <Button Classes="actionrow" Name="ScanQrRow" Click="OnScanQrClick" IsVisible="False">
                <DockPanel>
                  <TextBlock DockPanel.Dock="Left" Classes="glyph accentfg" Text="&#xE8B8;" VerticalAlignment="Center" Margin="0,0,10,0" />
                  <TextBlock Text="Scan QR code" Classes="setlabel" />
                </DockPanel>
              </Button>
              <Button Classes="actionrow" Click="OnImportClick">
                <DockPanel>
                  <TextBlock DockPanel.Dock="Right" Name="ImportShortcut" Classes="muted" Text="Ctrl+O" VerticalAlignment="Center" />
                  <TextBlock Text="Import configuration…" Classes="setlabel" />
                </DockPanel>
              </Button>
              <Button Classes="actionrow" Click="OnNewTunnelClick">
                <DockPanel>
                  <TextBlock DockPanel.Dock="Right" Name="NewShortcut" Classes="muted" Text="Ctrl+N" VerticalAlignment="Center" />
                  <TextBlock Text="New empty tunnel" Classes="setlabel" />
                </DockPanel>
              </Button>
              <Button Classes="actionrow" Click="OnRescanClick" Name="RescanRow">
                <DockPanel>
                  <TextBlock Text="Rescan external tunnels" Classes="setlabel" />
                </DockPanel>
              </Button>
            </StackPanel>
          </Panel>
        </Border>

        <!-- Expandable settings panel, same mechanism. -->
        <Border Name="SettingsRegion" Classes="drawer"
                Background="{DynamicResource MenuSurfaceBrush}" BorderBrush="{DynamicResource HairlineBrush}"
                BorderThickness="1" CornerRadius="8" Margin="14,0,14,0" Height="0" IsVisible="False">
          <Panel ClipToBounds="True">
            <Grid Name="SettingsCard" ColumnDefinitions="1.3*,Auto,1*" Margin="12,8" VerticalAlignment="Bottom">
              <StackPanel Grid.Column="0" Name="GeneralList" Spacing="1" VerticalAlignment="Center" />
              <Border Grid.Column="1" Width="1" Background="{DynamicResource SeparatorBrush}" Margin="14,0" />
              <StackPanel Grid.Column="2" Name="AppearanceList" Spacing="9" VerticalAlignment="Center" />
            </Grid>
          </Panel>
        </Border>

        <!-- QR scan drawer (Android): a live camera preview lives in a card like the Settings
             drawer. QrHost is filled by the platform's scanner preview; the corner frame + hint
             overlay it. Grows up from the bar with the same mechanism. -->
        <Border Name="QrRegion" Classes="drawer"
                Background="{DynamicResource MenuSurfaceBrush}" BorderBrush="{DynamicResource HairlineBrush}"
                BorderThickness="1" CornerRadius="8" Margin="14,0,14,0" Height="0" IsVisible="False">
          <Panel ClipToBounds="True">
            <StackPanel Name="QrCard" Spacing="10" Margin="12" VerticalAlignment="Bottom">
              <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                <TextBlock Grid.Column="0" Classes="glyph accentfg" Text="&#xE8B8;" FontSize="{DynamicResource Fs14}" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="Scan tunnel QR" Classes="setlabel" Margin="8,0,0,0" VerticalAlignment="Center" />
                <Button Grid.Column="2" Classes="hdr" Click="OnQrCancelClick" Padding="10,4">
                  <TextBlock Text="Cancel" Classes="setlabel" />
                </Button>
              </Grid>
              <!-- 1:1 camera stage: preview fills, corner brackets frame the target. -->
              <Panel Height="240" ClipToBounds="True">
                <Border CornerRadius="10" ClipToBounds="True" Background="#0A0A0A">
                  <ContentControl Name="QrHost" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                </Border>
                <Border Name="QrFrame" Width="150" Height="150" HorizontalAlignment="Center" VerticalAlignment="Center"
                        BorderBrush="{DynamicResource AccentBrush}" BorderThickness="2.5" CornerRadius="12" />
                <TextBlock Name="QrHint" Text="Point at a WireGuard QR" Classes="muted" FontSize="{DynamicResource Fs11}"
                           HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,8" />
              </Panel>
            </StackPanel>
          </Panel>
        </Border>

        <!-- Bottom bar: Settings expander (left) + Add (right). Same side inset (14) and radius
             (card = 8) as the tunnel cards so it lines up with them. -->
        <Border Name="BottomBar" Classes="card float" Background="{DynamicResource MenuSurfaceBrush}"
                Margin="14,0,14,12" Padding="5">
          <Grid ColumnDefinitions="*,Auto,Auto">
            <Button Grid.Column="0" Name="SettingsToggle" Classes="hdr" Click="OnSettingsToggleClick"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Padding="8,6">
              <DockPanel>
                <TextBlock DockPanel.Dock="Right" Name="SettingsChevron" Classes="glyph" Text="&#xE70E;"
                           FontSize="{DynamicResource Fs12}" Opacity="0.6" VerticalAlignment="Center" Margin="8,0,0,0" />
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                  <TextBlock Classes="glyph accentfg" Text="&#xE713;" FontSize="{DynamicResource Fs14}" />
                  <TextBlock Text="Settings" Classes="setlabel" />
                </StackPanel>
                <!-- Fill child: trims with an ellipsis instead of running under the chevron.
                     Deliberately smaller than the muted default — it's a hint, not a label. -->
                <TextBlock Classes="muted" Text="System · Updates · Appearance"
                           FontSize="{DynamicResource Fs11}" TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center" Margin="8,0,0,0" />
              </DockPanel>
            </Button>
            <Border Grid.Column="1" Width="1" Background="{DynamicResource SeparatorBrush}" Margin="4,5" />
            <Button Grid.Column="2" Name="AddToggle" Classes="hdr" Padding="12,6" Click="OnAddToggleClick" ToolTip.Tip="Add a tunnel">
              <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                <TextBlock Classes="glyph accentfg" Text="&#xE710;" FontSize="{DynamicResource Fs14}" />
                <TextBlock Text="Add" Classes="setlabel" />
                <TextBlock Name="AddChevron" Classes="glyph" Text="&#xE70E;" FontSize="{DynamicResource Fs12}" Opacity="0.6" VerticalAlignment="Center" />
              </StackPanel>
            </Button>
          </Grid>
        </Border>
      </StackPanel>

      <!-- Transient toast (connect errors / failover): floats bottom-right above the bar,
           slides+fades via the .shown class, auto-clears after a few seconds (VM timer),
           click dismisses immediately. -->
      <Border Name="Toast" Classes="toast" Classes.shown="{Binding HasStatus}" IsHitTestVisible="{Binding HasStatus}"
              HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="14,0,14,70"
              MaxWidth="380" PointerPressed="OnToastPressed">
        <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap"
                   Classes="oktext" Classes.errtext="{Binding !StatusOk}" />
      </Border>
    </Panel>
  </DockPanel>
</UserControl>
