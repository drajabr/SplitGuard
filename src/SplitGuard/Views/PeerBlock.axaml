<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             xmlns:vm="clr-namespace:SplitGuard.ViewModels"
             xmlns:views="clr-namespace:SplitGuard.Views"
             x:Class="SplitGuard.Views.PeerBlock">
  <Border Classes="peerblock" Margin="12,0,12,6">
    <StackPanel>
      <!-- Header (always visible; clicking its empty space toggles the body, like the
           tunnel card): name · endpoint, live badges + metric on the right. The endpoint
           is a starred column so it shrinks instead of ever wrapping to a second line. -->
      <DockPanel Name="HeaderRow" Background="Transparent" Margin="10,5,12,3">
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
          <Border Classes="rolebadge" Classes.active="{Binding FailoverRole, Converter={x:Static views:Syntax.IsActive}}"
                  IsVisible="{Binding FailoverRole, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <TextBlock FontSize="{DynamicResource Fs11}" Text="{Binding FailoverRole}" />
          </Border>
          <TextBlock Classes="muted" Text="{Binding HandshakeText}" IsVisible="{Binding ShowHandshake}" />
          <TextBlock Classes="muted" Text="{Binding PingText}"
                     IsVisible="{Binding PingText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        </StackPanel>
        <Grid ColumnDefinitions="Auto,*" VerticalAlignment="Center">
          <TextBlock Grid.Column="0" Classes="accentfg" FontSize="{DynamicResource Fs115}" FontWeight="Medium" VerticalAlignment="Center"
                     Text="{Binding BlockTitle}" IsVisible="{Binding IsDnsOnly}" Margin="0,0,8,0" />
          <TextBox Grid.Column="0" Classes="plainname" MinWidth="60" MaxWidth="160" Text="{Binding Name}" Watermark="Peer"
                   IsVisible="{Binding ShowWgFields}" Margin="0,0,8,0"
                   Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold" FontSize="{DynamicResource Fs17}" VerticalAlignment="Center" />
          <TextBox Grid.Column="1" Classes="mono" MinWidth="90" HorizontalAlignment="Stretch"
                   Text="{Binding Endpoint}" Watermark="host:port" IsVisible="{Binding ShowWgFields}"
                   Margin="0,0,8,0" VerticalAlignment="Center" />
        </Grid>
      </DockPanel>

      <StackPanel IsVisible="{Binding IsExpanded}">
        <Separator />
        <Grid Margin="10,6,12,0" ColumnDefinitions="64,*" RowDefinitions="Auto,Auto,Auto,Auto">

          <TextBlock Grid.Row="0" Grid.Column="0" Classes="lbl" VerticalAlignment="Top" Text="Keys" IsVisible="{Binding ShowWgFields}" Margin="0,5,10,4" />
          <Grid Grid.Row="0" Grid.Column="1" ColumnDefinitions="*,*,Auto,34,Auto,34" IsVisible="{Binding ShowWgFields}" Margin="0,0,0,4">
            <TextBox Grid.Column="0" Classes="mono synkey" MinWidth="40" Text="{Binding PublicKey}" Watermark="public key" Margin="0,0,6,0" />
            <TextBox Grid.Column="1" Classes="mono" MinWidth="40" Text="{Binding PresharedKey}" Watermark="preshared" />
            <TextBlock Grid.Column="2" Classes="lbl" Text="keepalive" Margin="10,0,6,0"
                       ToolTip.Tip="Seconds between keepalive packets (blank = off)" />
            <TextBox Grid.Column="3" Classes="mono num" Text="{Binding KeepaliveText}" Watermark="off" />
            <TextBlock Grid.Column="4" Classes="lbl" Text="metric" Margin="10,0,6,0"
                       ToolTip.Tip="Failover rank (0-10) when allowed IPs overlap another peer's — lower wins; peers in the same route group must use distinct values. Enabled only while an overlap exists." />
            <TextBox Grid.Column="5" Classes="mono num" Text="{Binding MetricText}" Watermark="0" IsEnabled="{Binding MetricEnabled}" />
          </Grid>

          <TextBlock Grid.Row="1" Grid.Column="0" Classes="lbl" VerticalAlignment="Top" Text="Ping" IsVisible="{Binding ShowWgFields}" Margin="0,5,10,4"
                     ToolTip.Tip="In-tunnel IP probed once per keepalive period. When set, it decides failover health; without it, handshake freshness decides." />
          <Grid Grid.Row="1" Grid.Column="1" ColumnDefinitions="*,Auto,34,Auto,34,Auto,34,Auto,34" IsVisible="{Binding ShowWgFields}" Margin="0,0,0,4">
            <TextBox Grid.Column="0" Classes="mono" MinWidth="56" Text="{Binding PingHostText}" Watermark="host to ping" />
            <TextBlock Grid.Column="1" Classes="lbl" Text="every" Margin="10,0,4,0" IsEnabled="{Binding HasPingHost}" ToolTip.Tip="How often to probe, in seconds (1-3600, default 5)" />
            <TextBox Grid.Column="2" Classes="mono num" Text="{Binding PingPeriodText}" Watermark="5" IsEnabled="{Binding HasPingHost}" />
            <TextBlock Grid.Column="3" Classes="lbl" Text="down" Margin="10,0,4,0" IsEnabled="{Binding HasPingHost}" ToolTip.Tip="Consecutive ping failures that mark this peer down (1-100, default 3)" />
            <TextBox Grid.Column="4" Classes="mono num" Text="{Binding PingDownText}" Watermark="3" IsEnabled="{Binding HasPingHost}" />
            <TextBlock Grid.Column="5" Classes="lbl" Text="up" Margin="10,0,4,0" IsEnabled="{Binding HasPingHost}" ToolTip.Tip="Consecutive ping successes that bring it back up (1-100, default 3)" />
            <TextBox Grid.Column="6" Classes="mono num" Text="{Binding PingUpText}" Watermark="3" IsEnabled="{Binding HasPingHost}" />
            <TextBlock Grid.Column="7" Classes="lbl" Text="timeout" Margin="10,0,4,0" IsEnabled="{Binding HasPingHost}" ToolTip.Tip="Seconds to wait for each ping reply (1-60, default 3)" />
            <TextBox Grid.Column="8" Classes="mono num" Text="{Binding PingTimeoutText}" Watermark="3" IsEnabled="{Binding HasPingHost}" />
          </Grid>

          <TextBlock Grid.Row="2" Grid.Column="0" Classes="lbl" VerticalAlignment="Top" Text="IPs" IsVisible="{Binding ShowWgFields}" Margin="0,5,10,4"
                     ToolTip.Tip="Allowed IPs — the ranges routed through this peer" />
          <ItemsControl Grid.Row="2" Grid.Column="1" ItemsSource="{Binding AllowedIps}" IsVisible="{Binding ShowWgFields}" Margin="0,0,0,4">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.DataTemplates>
              <DataTemplate DataType="sys:String">
                <Border Classes="item" Margin="0,0,6,4">
                  <DockPanel>
                    <Button Classes="chipx" DockPanel.Dock="Right" VerticalAlignment="Center" Margin="6,0,0,0"
                            Command="{Binding $parent[ItemsControl].DataContext.RemoveAllowedIpCommand}" CommandParameter="{Binding}">
                      <TextBlock Classes="glyph" Text="&#xE711;" FontSize="{DynamicResource Fs9}" Opacity="0.6" />
                    </Button>
                    <WrapPanel VerticalAlignment="Center">
                      <TextBlock Classes="mono synip" TextWrapping="Wrap" Text="{Binding Converter={x:Static views:Syntax.IpPart}}" />
                      <TextBlock Classes="mono synnum" Text="{Binding Converter={x:Static views:Syntax.MaskPart}}" />
                    </WrapPanel>
                  </DockPanel>
                </Border>
              </DataTemplate>
              <DataTemplate DataType="vm:AddSlot">
                <TextBox Classes="mono addbox" Margin="0,0,6,4" Watermark="+"
                         Classes.error="{Binding $parent[ItemsControl].DataContext.AllowedIpAddError}"
                         Text="{Binding $parent[ItemsControl].DataContext.NewAllowedIp}">
                  <TextBox.KeyBindings>
                    <KeyBinding Gesture="Enter" Command="{Binding $parent[ItemsControl].DataContext.AddAllowedIpCommand}" />
                  </TextBox.KeyBindings>
                </TextBox>
              </DataTemplate>
            </ItemsControl.DataTemplates>
          </ItemsControl>

          <!-- DNS + domains flow as one line: the DNS box is the first wrap item, chips
               fill the rest of the line and only the overflow wraps below. -->
          <TextBlock Grid.Row="3" Grid.Column="0" Classes="lbl" VerticalAlignment="Top" Text="DNS" Margin="0,5,10,0" />
          <ItemsControl Grid.Row="3" Grid.Column="1" ItemsSource="{Binding Domains}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.DataTemplates>
              <DataTemplate DataType="vm:DnsSlot">
                <TextBox Classes="mono" Width="150" Margin="0,0,8,4"
                         Text="{Binding $parent[ItemsControl].DataContext.Dns}" Watermark="optional">
                  <TextBox.InnerRightContent>
                    <Button Classes="icon" Command="{Binding $parent[ItemsControl].DataContext.TogglePinCommand}"
                            IsEnabled="{Binding $parent[ItemsControl].DataContext.PinEnabled}"
                            ToolTip.Tip="Pin this server as the device-wide DNS (with automatic fallback)">
                      <Panel>
                        <TextBlock Classes="glyph pinicon" Text="&#xE718;"
                                   IsVisible="{Binding $parent[ItemsControl].DataContext.IsPinned, Converter={x:Static views:Syntax.Not}}" />
                        <TextBlock Classes="glyph pinicon pinned" Classes.suspended="{Binding $parent[ItemsControl].DataContext.PinSuspended}"
                                   Text="&#xE842;" IsVisible="{Binding $parent[ItemsControl].DataContext.IsPinned}" />
                      </Panel>
                    </Button>
                  </TextBox.InnerRightContent>
                </TextBox>
              </DataTemplate>
              <DataTemplate DataType="sys:String">
                <Border Classes="item" Margin="0,0,6,4">
                  <DockPanel>
                    <Button Classes="chipx" DockPanel.Dock="Right" VerticalAlignment="Center" Margin="6,0,0,0"
                            Command="{Binding $parent[ItemsControl].DataContext.RemoveDomainCommand}" CommandParameter="{Binding}">
                      <TextBlock Classes="glyph" Text="&#xE711;" FontSize="{DynamicResource Fs9}" Opacity="0.6" />
                    </Button>
                    <TextBlock Classes="mono syndomain" TextWrapping="Wrap" VerticalAlignment="Center" Text="{Binding}" />
                  </DockPanel>
                </Border>
              </DataTemplate>
              <DataTemplate DataType="vm:AddSlot">
                <TextBox Classes="mono addbox" MinWidth="94" Margin="0,0,6,4" Watermark="Add domain"
                         Classes.error="{Binding $parent[ItemsControl].DataContext.DomainAddError}"
                         Text="{Binding $parent[ItemsControl].DataContext.NewDomain}">
                  <TextBox.KeyBindings>
                    <KeyBinding Gesture="Enter" Command="{Binding $parent[ItemsControl].DataContext.AddDomainCommand}" />
                  </TextBox.KeyBindings>
                </TextBox>
              </DataTemplate>
            </ItemsControl.DataTemplates>
          </ItemsControl>
        </Grid>

        <Button Classes="link danger" Content="Remove peer" Command="{Binding RemovePeerCommand}"
                HorizontalAlignment="Right" Margin="0,0,12,6" FontSize="{DynamicResource Fs115}" />
      </StackPanel>
    </StackPanel>
  </Border>
</UserControl>
