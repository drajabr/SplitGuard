<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             xmlns:vm="clr-namespace:SplitGuard.ViewModels"
             xmlns:views="clr-namespace:SplitGuard.Views"
             x:Class="SplitGuard.Views.PeerBlock"
             ClipToBounds="False">
  <Border Classes="peerblock" Margin="12,4,12,8">
    <StackPanel>
      <!-- Header (always visible; clicking its empty space toggles the body, like the
           tunnel card): name on the left, live status on the right. -->
      <DockPanel Name="HeaderRow" Background="Transparent" Margin="0,9,14,3">
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
          <TextBlock Classes="muted" Text="{Binding HandshakeText, Converter={x:Static views:Syntax.OrDots}}" />
          <TextBlock Classes="muted" Text="{Binding PingText, Converter={x:Static views:Syntax.OrDots}}"
                     IsVisible="{Binding HasPingHost}" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <TextBlock Classes="accentfg" FontSize="{DynamicResource Fs115}" FontWeight="Medium" VerticalAlignment="Center"
                     Text="{Binding BlockTitle}" IsVisible="{Binding IsDnsOnly}" />
          <TextBox Classes="plainname" MinWidth="60" MaxWidth="220" Text="{Binding Name}" Watermark="Peer"
                   IsVisible="{Binding ShowWgFields}"
                   Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" FontSize="{DynamicResource Fs17}" VerticalAlignment="Center" />
          <!-- Failover rank, only while this peer's routes actually overlap another's. -->
          <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center" IsVisible="{Binding MetricEnabled}">
            <TextBlock Classes="lbl" Text="metric" ToolTip.Tip="{Binding MetricRankText}" />
            <TextBox Classes="mono num" Text="{Binding MetricText}" Watermark="0"
                     LostFocus="OnMetricCommitted" ToolTip.Tip="{Binding MetricRankText}" />
          </StackPanel>
        </StackPanel>
      </DockPanel>

      <StackPanel x:Name="PeerBody" IsVisible="False">
        <Grid Margin="14,4,14,2" ColumnDefinitions="54,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">

          <TextBlock Grid.Row="0" Grid.Column="0" Classes="lbl" VerticalAlignment="Center" Text="Endpoint" IsVisible="{Binding ShowWgFields}" Margin="0,0,8,4" />
          <!-- Endpoint stays left (shrinks to content); keepalive is pegged to the right edge.
               The endpoint fills the gap and clips before it can push keepalive off the card. -->
          <DockPanel Grid.Row="0" Grid.Column="1" IsVisible="{Binding ShowWgFields}" Margin="0,0,0,4">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="12,0,0,0">
              <TextBlock Classes="lbl" Text="keepalive" VerticalAlignment="Center"
                         ToolTip.Tip="PersistentKeepalive — seconds between keepalive packets (blank = off)" />
              <TextBox Classes="mono num" Text="{Binding KeepaliveText}" Watermark="off" VerticalAlignment="Center" />
            </StackPanel>
            <TextBox Classes="mono fit" MinWidth="90" MaxWidth="260" Text="{Binding Endpoint}" Watermark="host:port" VerticalAlignment="Center" />
          </DockPanel>

          <TextBlock Grid.Row="1" Grid.Column="0" Classes="lbl" VerticalAlignment="Top" Text="Keys" IsVisible="{Binding ShowWgFields}" Margin="0,5,8,4" />
          <Grid Grid.Row="1" Grid.Column="1" ColumnDefinitions="*,*" IsVisible="{Binding ShowWgFields}" Margin="0,0,0,4">
            <TextBox Grid.Column="0" Classes="mono synkey" MinWidth="40" Text="{Binding PublicKey}" Watermark="public key" Margin="0,0,6,0" />
            <TextBox Grid.Column="1" Classes="mono" MinWidth="40" Text="{Binding PresharedKey}" Watermark="preshared (optional)" />
          </Grid>

          <TextBlock Grid.Row="2" Grid.Column="0" Classes="lbl" VerticalAlignment="Top" Text="IPs" IsVisible="{Binding ShowWgFields}" Margin="0,5,8,4"
                     ToolTip.Tip="Allowed IPs — the ranges routed through this peer" />
          <ItemsControl Grid.Row="2" Grid.Column="1" ItemsSource="{Binding AllowedIps}" IsVisible="{Binding ShowWgFields}" Margin="0,0,0,4">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.DataTemplates>
              <DataTemplate DataType="sys:String">
                <Border Classes="item" Margin="0,0,6,4">
                  <DockPanel>
                    <Button Classes="chipx" ToolTip.Tip="Remove" DockPanel.Dock="Right" VerticalAlignment="Center" Margin="6,0,0,0"
                            Command="{Binding $parent[ItemsControl].DataContext.RemoveAllowedIpCommand}" CommandParameter="{Binding}">
                      <TextBlock Classes="glyph" Text="&#xE711;" FontSize="{DynamicResource Fs9}" Opacity="0.6" />
                    </Button>
                    <WrapPanel VerticalAlignment="Center">
                      <TextBlock Classes="mono synip" TextWrapping="Wrap" Text="{Binding Converter={x:Static views:Syntax.IpPart}}" />
                      <TextBlock Classes="mono synnum" Text="{Binding Converter={x:Static views:Syntax.MaskPart}}" />
                    </WrapPanel>
                  </DockPanel>
                </Border>
              </DataTemplate>
              <DataTemplate DataType="vm:AddSlot">
                <TextBox Classes="mono addbox" Margin="0,0,6,4" Watermark="+"
                         Classes.error="{Binding $parent[ItemsControl].DataContext.AllowedIpAddError}"
                         Text="{Binding $parent[ItemsControl].DataContext.NewAllowedIp}">
                  <TextBox.KeyBindings>
                    <KeyBinding Gesture="Enter" Command="{Binding $parent[ItemsControl].DataContext.AddAllowedIpCommand}" />
                  </TextBox.KeyBindings>
                </TextBox>
              </DataTemplate>
            </ItemsControl.DataTemplates>
          </ItemsControl>

          <!-- DNS + domains flow as one line: the DNS box is the first wrap item, chips
               fill the rest of the line and only the overflow wraps below. -->
          <TextBlock Grid.Row="3" Grid.Column="0" Classes="lbl" VerticalAlignment="Top" Text="DNS" Margin="0,5,8,0"
                     ToolTip.Tip="These domains resolve through this server while the tunnel is up" />
          <ItemsControl Grid.Row="3" Grid.Column="1" ItemsSource="{Binding Domains}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.DataTemplates>
              <DataTemplate DataType="vm:DnsSlot">
                <TextBox Classes="mono fit" MinWidth="70" Margin="0,0,8,4"
                         Text="{Binding $parent[ItemsControl].DataContext.Dns}" Watermark="dns server">
                  <TextBox.InnerRightContent>
                    <Button Classes="icon" Command="{Binding $parent[ItemsControl].DataContext.TogglePinCommand}"
                            IsEnabled="{Binding $parent[ItemsControl].DataContext.PinEnabled}"
                            ToolTip.Tip="Pin this server as the device-wide DNS (with automatic fallback)">
                      <Panel>
                        <TextBlock Classes="glyph pinicon" Text="&#xE718;"
                                   IsVisible="{Binding $parent[ItemsControl].DataContext.IsPinned, Converter={x:Static views:Syntax.Not}}" />
                        <TextBlock Classes="glyph pinicon pinned" Classes.suspended="{Binding $parent[ItemsControl].DataContext.PinSuspended}"
                                   Text="&#xE842;" IsVisible="{Binding $parent[ItemsControl].DataContext.IsPinned}" />
                      </Panel>
                    </Button>
                  </TextBox.InnerRightContent>
                </TextBox>
              </DataTemplate>
              <DataTemplate DataType="sys:String">
                <Border Classes="item" Margin="0,0,6,4">
                  <DockPanel>
                    <Button Classes="chipx" ToolTip.Tip="Remove" DockPanel.Dock="Right" VerticalAlignment="Center" Margin="6,0,0,0"
                            Command="{Binding $parent[ItemsControl].DataContext.RemoveDomainCommand}" CommandParameter="{Binding}">
                      <TextBlock Classes="glyph" Text="&#xE711;" FontSize="{DynamicResource Fs9}" Opacity="0.6" />
                    </Button>
                    <TextBlock Classes="mono syndomain" TextWrapping="Wrap" VerticalAlignment="Center" Text="{Binding}" />
                  </DockPanel>
                </Border>
              </DataTemplate>
              <DataTemplate DataType="vm:AddSlot">
                <TextBox Classes="mono addbox fit" Margin="0,0,6,4" Watermark="Add domain"
                         Classes.error="{Binding $parent[ItemsControl].DataContext.DomainAddError}"
                         Text="{Binding $parent[ItemsControl].DataContext.NewDomain}">
                  <TextBox.KeyBindings>
                    <KeyBinding Gesture="Enter" Command="{Binding $parent[ItemsControl].DataContext.AddDomainCommand}" />
                  </TextBox.KeyBindings>
                </TextBox>
              </DataTemplate>
            </ItemsControl.DataTemplates>
          </ItemsControl>

          <TextBlock Grid.Row="4" Grid.Column="0" Classes="lbl" VerticalAlignment="Top" Text="Ping" IsVisible="{Binding ShowWgFields}" Margin="0,7,8,4"
                     ToolTip.Tip="Healthcheck — in-tunnel IP probed on a fixed period. When set, it decides failover health; without it, handshake freshness decides. The knobs unlock once a valid host is set." />
          <!-- Host then the four knobs flow left; each knob is its own wrap item (label + box
               kept together), so only the one that overflows drops to the next line, not the
               whole group. -->
          <WrapPanel Grid.Row="4" Grid.Column="1" IsVisible="{Binding ShowWgFields}" Margin="0,0,0,4">
            <TextBox Classes="mono fit" MinWidth="96" MaxWidth="220" Margin="0,0,10,4" Text="{Binding PingHostText}" Watermark="host to ping" />
            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" Margin="0,0,10,4">
              <TextBlock Classes="lbl" Text="every" VerticalAlignment="Center" IsEnabled="{Binding HasPingHost}" ToolTip.Tip="How often to probe, in seconds (1-3600, default 5)" />
              <TextBox Classes="mono num" Text="{Binding PingPeriodText}" Watermark="5" IsEnabled="{Binding HasPingHost}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" Margin="0,0,10,4">
              <TextBlock Classes="lbl" Text="down" VerticalAlignment="Center" IsEnabled="{Binding HasPingHost}" ToolTip.Tip="Consecutive ping failures that mark this peer down (1-100, default 3)" />
              <TextBox Classes="mono num" Text="{Binding PingDownText}" Watermark="3" IsEnabled="{Binding HasPingHost}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" Margin="0,0,10,4">
              <TextBlock Classes="lbl" Text="up" VerticalAlignment="Center" IsEnabled="{Binding HasPingHost}" ToolTip.Tip="Consecutive ping successes that bring it back up (1-100, default 3)" />
              <TextBox Classes="mono num" Text="{Binding PingUpText}" Watermark="3" IsEnabled="{Binding HasPingHost}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" Margin="0,0,10,4">
              <TextBlock Classes="lbl" Text="t/o" VerticalAlignment="Center" IsEnabled="{Binding HasPingHost}" ToolTip.Tip="Timeout — seconds to wait for each ping reply (1-60, default 3)" />
              <TextBox Classes="mono num" Text="{Binding PingTimeoutText}" Watermark="3" IsEnabled="{Binding HasPingHost}" />
            </StackPanel>
          </WrapPanel>

        </Grid>

        <Button Classes="link danger" Content="Remove peer" Command="{Binding RemovePeerCommand}"
                HorizontalAlignment="Right" Margin="0,0,14,6" FontSize="{DynamicResource Fs115}" />
      </StackPanel>
    </StackPanel>
  </Border>
</UserControl>
