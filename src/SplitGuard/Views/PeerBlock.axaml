<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             xmlns:vm="clr-namespace:SplitGuard.ViewModels"
             xmlns:views="clr-namespace:SplitGuard.Views"
             x:Class="SplitGuard.Views.PeerBlock">
  <Border Classes="peerblock" Margin="8,0,10,6">
    <StackPanel>
      <DockPanel Margin="10,4">
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8">
          <Border Classes="rolebadge" Classes.active="{Binding FailoverRole, Converter={x:Static views:Syntax.IsActive}}"
                  IsVisible="{Binding FailoverRole, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <TextBlock FontSize="{DynamicResource Fs11}" Text="{Binding FailoverRole}" />
          </Border>
          <TextBlock Classes="muted" Text="{Binding PingText}"
                     IsVisible="{Binding PingText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
          <TextBlock Classes="muted" Text="{Binding HandshakeText}" IsVisible="{Binding ShowHandshake}" />
          <Button Classes="link danger" Content="Remove peer" Command="{Binding RemovePeerCommand}" IsVisible="{Binding IsEditing}" FontSize="{DynamicResource Fs115}" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBlock Classes="accentfg" FontSize="{DynamicResource Fs115}" FontWeight="Medium" VerticalAlignment="Center" Text="{Binding BlockTitle}" />
        </StackPanel>
      </DockPanel>
      <Separator />

      <!-- Label column is Auto: inputs begin just past the widest label. -->
      <Grid Margin="10,6" ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">

        <TextBlock Grid.Row="0" Grid.Column="0" Classes="lbl" VerticalAlignment="Top" Text="Endpoint" IsVisible="{Binding ShowWgFields}" Margin="0,5,12,4" />
        <Grid Grid.Row="0" Grid.Column="1" ColumnDefinitions="*,Auto,56" IsVisible="{Binding ShowWgFields}" Margin="0,0,0,4">
          <TextBox Grid.Column="0" Classes="mono" Text="{Binding EndpointHost}" Watermark="host or ip" />
          <TextBlock Grid.Column="1" Classes="muted" Text=":" VerticalAlignment="Center" Margin="4,0,4,0" />
          <TextBox Grid.Column="2" Classes="mono" Text="{Binding EndpointPort}" Watermark="port" />
        </Grid>

        <TextBlock Grid.Row="1" Grid.Column="0" Classes="lbl" VerticalAlignment="Top" Text="Public key" IsVisible="{Binding ShowKeysRow}" Margin="0,5,12,4" />
        <TextBox Grid.Row="1" Grid.Column="1" Classes="mono" Text="{Binding PublicKey}" Watermark="peer public key"
                 HorizontalAlignment="Stretch" IsVisible="{Binding ShowKeysRow}" Margin="0,0,0,4" />

        <TextBlock Grid.Row="2" Grid.Column="0" Classes="lbl" VerticalAlignment="Top" Text="Preshared key" IsVisible="{Binding ShowKeysRow}" Margin="0,5,12,4" />
        <TextBox Grid.Row="2" Grid.Column="1" Classes="mono" Text="{Binding PresharedKey}" Watermark="optional"
                 HorizontalAlignment="Stretch" IsVisible="{Binding ShowKeysRow}" Margin="0,0,0,4" />

        <TextBlock Grid.Row="3" Grid.Column="0" Classes="lbl" VerticalAlignment="Top" Text="Allowed IPs" IsVisible="{Binding ShowWgFields}" Margin="0,5,12,4" />
        <ItemsControl Grid.Row="3" Grid.Column="1" ItemsSource="{Binding AllowedIps}" IsVisible="{Binding ShowWgFields}" Margin="0,0,0,4">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.DataTemplates>
            <DataTemplate DataType="sys:String">
              <Border Classes="item" Margin="0,0,6,4">
                <DockPanel>
                  <Button Classes="chipx" DockPanel.Dock="Right" VerticalAlignment="Top" Margin="6,3,0,0"
                          Command="{Binding $parent[ItemsControl].DataContext.RemoveAllowedIpCommand}" CommandParameter="{Binding}">
                    <TextBlock Classes="glyph" Text="&#xE711;" FontSize="{DynamicResource Fs9}" Opacity="0.6" />
                  </Button>
                  <WrapPanel VerticalAlignment="Center">
                    <TextBlock Classes="mono synip" TextWrapping="Wrap" Text="{Binding Converter={x:Static views:Syntax.IpPart}}" />
                    <TextBlock Classes="mono synnum" Text="{Binding Converter={x:Static views:Syntax.MaskPart}}" />
                  </WrapPanel>
                </DockPanel>
              </Border>
            </DataTemplate>
            <DataTemplate DataType="vm:AddSlot">
              <TextBox Classes="mono addbox" Margin="0,0,6,4" Watermark="+"
                       Classes.error="{Binding $parent[ItemsControl].DataContext.AllowedIpAddError}"
                       Text="{Binding $parent[ItemsControl].DataContext.NewAllowedIp}">
                <TextBox.KeyBindings>
                  <KeyBinding Gesture="Enter" Command="{Binding $parent[ItemsControl].DataContext.AddAllowedIpCommand}" />
                </TextBox.KeyBindings>
              </TextBox>
            </DataTemplate>
          </ItemsControl.DataTemplates>
        </ItemsControl>

        <TextBlock Grid.Row="4" Grid.Column="0" Classes="lbl" VerticalAlignment="Top" Text="DNS" Margin="0,5,12,4" />
        <TextBox Grid.Row="4" Grid.Column="1" Classes="mono" Text="{Binding Dns}" Watermark="optional" Margin="0,0,0,4">
          <TextBox.InnerRightContent>
            <Button Classes="icon" Command="{Binding TogglePinCommand}" IsEnabled="{Binding PinEnabled}"
                    ToolTip.Tip="Pin this server as the device-wide DNS (with automatic fallback)">
              <StackPanel Orientation="Horizontal" Spacing="5">
                <Panel>
                  <TextBlock Classes="glyph pinicon" Text="&#xE718;" IsVisible="{Binding !IsPinned}" />
                  <TextBlock Classes="glyph pinicon pinned" Classes.suspended="{Binding PinSuspended}"
                             Text="&#xE842;" IsVisible="{Binding IsPinned}" />
                </Panel>
                <TextBlock FontSize="{DynamicResource Fs11}" VerticalAlignment="Center" Opacity="0.7"
                           Text="pin as device DNS" IsVisible="{Binding !IsPinned}" />
                <TextBlock FontSize="{DynamicResource Fs11}" VerticalAlignment="Center" Classes="accentfg"
                           Text="device DNS" IsVisible="{Binding IsPinned}" />
              </StackPanel>
            </Button>
          </TextBox.InnerRightContent>
        </TextBox>

        <TextBlock Grid.Row="5" Grid.Column="0" Classes="lbl" VerticalAlignment="Top" Text="Keepalive" IsVisible="{Binding ShowWgFields}" Margin="0,5,12,4" />
        <Grid Grid.Row="5" Grid.Column="1" ColumnDefinitions="*,Auto,2*" IsVisible="{Binding ShowWgFields}" Margin="0,0,0,4">
          <TextBox Grid.Column="0" Classes="mono" Text="{Binding KeepaliveText}" Watermark="off" />
          <TextBlock Grid.Column="1" Classes="lbl" Text="Ping" Margin="12,0,8,0"
                     ToolTip.Tip="In-tunnel IP pinged once per keepalive period. When set, it decides failover health: count consecutive failures = down, count consecutive successes = up. Without it, handshake freshness decides." />
          <TextBox Grid.Column="2" Classes="mono" Text="{Binding PingHostText}" Watermark="host to ping" />
        </Grid>

        <TextBlock Grid.Row="6" Grid.Column="0" Classes="lbl" VerticalAlignment="Top" Text="Count" IsVisible="{Binding ShowWgFields}" Margin="0,5,12,4"
                   ToolTip.Tip="Consecutive pings that flip this peer down or back up (1-100, default 3)" />
        <Grid Grid.Row="6" Grid.Column="1" ColumnDefinitions="*,Auto,*,Auto,*" IsVisible="{Binding ShowWgFields}" Margin="0,0,0,4">
          <TextBox Grid.Column="0" Classes="mono" Text="{Binding PingCountText}" Watermark="3" />
          <TextBlock Grid.Column="1" Classes="lbl" Text="Timeout" Margin="12,0,8,0" ToolTip.Tip="Seconds to wait for each ping reply (1-60, default 3)" />
          <TextBox Grid.Column="2" Classes="mono" Text="{Binding PingTimeoutText}" Watermark="3" />
          <TextBlock Grid.Column="3" Classes="lbl" Text="Metric" Margin="12,0,8,0"
                     ToolTip.Tip="Failover rank (0-10) when allowed IPs overlap another peer's — lower wins; peers in the same route group must use distinct values. Enabled only while this peer's allowed IPs actually overlap another's." />
          <TextBox Grid.Column="4" Classes="mono" Text="{Binding MetricText}" Watermark="0" IsEnabled="{Binding MetricEnabled}" />
        </Grid>

        <TextBlock Grid.Row="7" Grid.Column="0" Classes="lbl" VerticalAlignment="Top" Text="Domains" Margin="0,5,12,0" />
        <ItemsControl Grid.Row="7" Grid.Column="1" ItemsSource="{Binding Domains}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.DataTemplates>
            <DataTemplate DataType="sys:String">
              <Border Classes="item" Margin="0,0,6,4">
                <DockPanel>
                  <Button Classes="chipx" DockPanel.Dock="Right" VerticalAlignment="Top" Margin="6,3,0,0"
                          Command="{Binding $parent[ItemsControl].DataContext.RemoveDomainCommand}" CommandParameter="{Binding}">
                    <TextBlock Classes="glyph" Text="&#xE711;" FontSize="{DynamicResource Fs9}" Opacity="0.6" />
                  </Button>
                  <TextBlock Classes="mono syndomain" TextWrapping="Wrap" VerticalAlignment="Center" Text="{Binding}" />
                </DockPanel>
              </Border>
            </DataTemplate>
            <DataTemplate DataType="vm:AddSlot">
              <TextBox Classes="mono addbox" Margin="0,0,6,4" Watermark="+"
                       Classes.error="{Binding $parent[ItemsControl].DataContext.DomainAddError}"
                       Text="{Binding $parent[ItemsControl].DataContext.NewDomain}">
                <TextBox.KeyBindings>
                  <KeyBinding Gesture="Enter" Command="{Binding $parent[ItemsControl].DataContext.AddDomainCommand}" />
                </TextBox.KeyBindings>
              </TextBox>
            </DataTemplate>
          </ItemsControl.DataTemplates>
        </ItemsControl>
      </Grid>
    </StackPanel>
  </Border>
</UserControl>
