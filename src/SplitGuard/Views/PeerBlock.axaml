<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             xmlns:vm="clr-namespace:SplitGuard.ViewModels"
             xmlns:views="clr-namespace:SplitGuard.Views"
             x:Class="SplitGuard.Views.PeerBlock">
  <Border Classes="peerblock" Margin="8,0,10,6">
    <StackPanel>
      <DockPanel Margin="10,4">
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8">
          <TextBlock Classes="muted" Text="{Binding HandshakeText}" IsVisible="{Binding ShowHandshake}" />
          <Button Classes="link danger" Content="Remove peer" Command="{Binding RemovePeerCommand}" IsVisible="{Binding IsEditing}" FontSize="{DynamicResource Fs115}" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBlock Classes="accentfg" FontSize="{DynamicResource Fs115}" FontWeight="Medium" VerticalAlignment="Center" Text="{Binding BlockTitle}" />
        </StackPanel>
      </DockPanel>
      <Separator />

      <!-- Label column is Auto: inputs begin just past the widest label. -->
      <Grid Margin="10,6" ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">

        <TextBlock Grid.Row="0" Grid.Column="0" Classes="lbl" VerticalAlignment="Top" Text="Endpoint" IsVisible="{Binding ShowWgFields}" Margin="0,5,12,4" />
        <Grid Grid.Row="0" Grid.Column="1" ColumnDefinitions="*,Auto,86" IsVisible="{Binding ShowWgFields}" Margin="0,0,0,4">
          <TextBox Grid.Column="0" Classes="mono" Text="{Binding EndpointHost}" Watermark="host or ip" />
          <TextBlock Grid.Column="1" Classes="muted" Text=":" VerticalAlignment="Center" Margin="4,0,4,0" />
          <TextBox Grid.Column="2" Classes="mono" Text="{Binding EndpointPort}" Watermark="port" />
        </Grid>

        <TextBlock Grid.Row="1" Grid.Column="0" Classes="lbl" VerticalAlignment="Top" Text="Public key" IsVisible="{Binding ShowKeysRow}" Margin="0,5,12,4" />
        <TextBox Grid.Row="1" Grid.Column="1" Classes="mono" Text="{Binding PublicKey}" Watermark="peer public key"
                 HorizontalAlignment="Stretch" IsVisible="{Binding ShowKeysRow}" Margin="0,0,0,4" />

        <TextBlock Grid.Row="2" Grid.Column="0" Classes="lbl" VerticalAlignment="Top" Text="Preshared key" IsVisible="{Binding ShowKeysRow}" Margin="0,5,12,4" />
        <TextBox Grid.Row="2" Grid.Column="1" Classes="mono" Text="{Binding PresharedKey}" Watermark="optional"
                 HorizontalAlignment="Stretch" IsVisible="{Binding ShowKeysRow}" Margin="0,0,0,4" />

        <TextBlock Grid.Row="3" Grid.Column="0" Classes="lbl" VerticalAlignment="Top" Text="Allowed IPs" IsVisible="{Binding ShowWgFields}" Margin="0,5,12,4" />
        <ItemsControl Grid.Row="3" Grid.Column="1" ItemsSource="{Binding AllowedIps}" IsVisible="{Binding ShowWgFields}" Margin="0,0,0,4">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.DataTemplates>
            <DataTemplate DataType="sys:String">
              <Border Classes="item" Margin="0,0,6,4">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Classes="mono synip" Text="{Binding Converter={x:Static views:Syntax.IpPart}}" />
                    <TextBlock Classes="mono synnum" Text="{Binding Converter={x:Static views:Syntax.MaskPart}}" />
                  </StackPanel>
                  <Button Classes="chipx"
                          Command="{Binding $parent[ItemsControl].DataContext.RemoveAllowedIpCommand}" CommandParameter="{Binding}">
                    <TextBlock Classes="glyph" Text="&#xE711;" FontSize="{DynamicResource Fs9}" Opacity="0.6" />
                  </Button>
                </StackPanel>
              </Border>
            </DataTemplate>
            <DataTemplate DataType="vm:AddSlot">
              <TextBox Classes="mono addbox" Margin="0,0,6,4" Watermark="+"
                       Classes.error="{Binding $parent[ItemsControl].DataContext.AllowedIpAddError}"
                       Text="{Binding $parent[ItemsControl].DataContext.NewAllowedIp}">
                <TextBox.KeyBindings>
                  <KeyBinding Gesture="Enter" Command="{Binding $parent[ItemsControl].DataContext.AddAllowedIpCommand}" />
                </TextBox.KeyBindings>
              </TextBox>
            </DataTemplate>
          </ItemsControl.DataTemplates>
        </ItemsControl>

        <TextBlock Grid.Row="4" Grid.Column="0" Classes="lbl" VerticalAlignment="Top" Text="DNS" Margin="0,5,12,4" />
        <Grid Grid.Row="4" Grid.Column="1" ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,4">
          <TextBox Grid.Column="0" Classes="mono" Text="{Binding Dns}" Watermark="optional">
            <TextBox.InnerRightContent>
              <Button Classes="icon" Command="{Binding TogglePinCommand}" IsEnabled="{Binding PinEnabled}"
                      ToolTip.Tip="Pin as device-wide DNS (applies immediately)">
                <StackPanel Orientation="Horizontal" Spacing="5">
                  <TextBlock Classes="glyph pinicon" Classes.pinned="{Binding IsPinned}" Text="&#xE718;" />
                  <TextBlock Classes="accent" FontSize="{DynamicResource Fs11}" VerticalAlignment="Center"
                             Text="{Binding PinCaption}" IsVisible="{Binding IsPinned}" />
                </StackPanel>
              </Button>
            </TextBox.InnerRightContent>
          </TextBox>
          <TextBlock Grid.Column="1" Classes="lbl" Text="Keepalive" VerticalAlignment="Center" Margin="12,0,8,0" IsVisible="{Binding ShowWgFields}" />
          <TextBox Grid.Column="2" Classes="mono" Width="72" Text="{Binding KeepaliveText}" Watermark="off" IsVisible="{Binding ShowWgFields}" />
        </Grid>

        <TextBlock Grid.Row="5" Grid.Column="0" Classes="lbl" VerticalAlignment="Top" Text="Domains" Margin="0,5,12,0" />
        <ItemsControl Grid.Row="5" Grid.Column="1" ItemsSource="{Binding Domains}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.DataTemplates>
            <DataTemplate DataType="sys:String">
              <Border Classes="item" Margin="0,0,6,4">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Classes="mono syndomain" Text="{Binding}" />
                  <Button Classes="chipx"
                          Command="{Binding $parent[ItemsControl].DataContext.RemoveDomainCommand}" CommandParameter="{Binding}">
                    <TextBlock Classes="glyph" Text="&#xE711;" FontSize="{DynamicResource Fs9}" Opacity="0.6" />
                  </Button>
                </StackPanel>
              </Border>
            </DataTemplate>
            <DataTemplate DataType="vm:AddSlot">
              <TextBox Classes="mono addbox" Margin="0,0,6,4" Watermark="+"
                       Classes.error="{Binding $parent[ItemsControl].DataContext.DomainAddError}"
                       Text="{Binding $parent[ItemsControl].DataContext.NewDomain}">
                <TextBox.KeyBindings>
                  <KeyBinding Gesture="Enter" Command="{Binding $parent[ItemsControl].DataContext.AddDomainCommand}" />
                </TextBox.KeyBindings>
              </TextBox>
            </DataTemplate>
          </ItemsControl.DataTemplates>
        </ItemsControl>
      </Grid>
    </StackPanel>
  </Border>
</UserControl>
