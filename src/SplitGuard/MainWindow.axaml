<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:SplitGuard.Views"
        x:Class="SplitGuard.Views.MainWindow"
        Title="SplitGuard"
        Icon="avares://SplitGuard/Assets/app.ico"
        Width="820" Height="700"
        MinWidth="660" MinHeight="420"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        ExtendClientAreaTitleBarHeightHint="46"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        RenderOptions.TextRenderingMode="SubpixelAntialias"
        DragDrop.AllowDrop="True">
  <DockPanel>
    <Border DockPanel.Dock="Top" Padding="10,4,146,4" Name="HeaderBar">
      <DockPanel>
        <TextBlock DockPanel.Dock="Right" Name="VersionLabel" FontSize="{DynamicResource Fs11}" Opacity="0.5"
                   VerticalAlignment="Center" Margin="0,0,6,0" />
        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
          <Image Name="LogoImage" Source="avares://SplitGuard/Assets/app.ico" Width="17" Height="17"
                 VerticalAlignment="Center" IsHitTestVisible="False" />
          <TextBlock FontSize="{DynamicResource Fs135}" FontWeight="Medium" VerticalAlignment="Center"
                     Text="SplitGuard" IsHitTestVisible="False" Margin="0,0,4,0" />
          <Menu Name="HeaderMenu" Background="Transparent" VerticalAlignment="Center">
            <MenuItem Name="AddMenu" Header="Add" />
            <MenuItem Header="View">
              <MenuItem Name="ThemeMenu" Header="Theme" />
              <MenuItem Name="AccentMenu" Header="Accent" />
              <MenuItem Name="FontMenu" Header="Font" />
              <MenuItem Name="ZoomMenu" Header="Zoom" />
            </MenuItem>
            <MenuItem Name="SettingsMenu" Header="Settings" />
          </Menu>
        </StackPanel>
      </DockPanel>
    </Border>

    <Border DockPanel.Dock="Top" Background="{DynamicResource WarningBgBrush}" Padding="14,8" IsVisible="{Binding GpoWarning}">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBlock Classes="glyph" Foreground="{DynamicResource WarningBrush}" Text="&#xE7BA;" VerticalAlignment="Top" />
        <TextBlock FontSize="{DynamicResource Fs12}" TextWrapping="Wrap" VerticalAlignment="Center"
                   Text="Group Policy DNS rules are active on this machine and override local ones — this tool's rules won't take effect." />
      </StackPanel>
    </Border>

    <Border DockPanel.Dock="Bottom" BorderBrush="{DynamicResource HairlineBrush}" BorderThickness="0,1,0,0" Padding="14,6"
            IsVisible="{Binding HasStatus}">
      <TextBlock Text="{Binding StatusText}" Classes="oktext" Classes.errtext="{Binding !StatusOk}" />
    </Border>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
      <StackPanel Margin="14,8,14,12">
        <ItemsControl ItemsSource="{Binding Tunnels}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <views:TunnelCard Margin="0,0,0,10" />
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
        <TextBlock Classes="muted" Margin="2,6" TextWrapping="Wrap"
                   IsVisible="{Binding !Tunnels.Count}"
                   Text="No tunnels yet. Drop a WireGuard .conf file anywhere in this window, or copy a config and press Ctrl+V. Domains you attach to a peer resolve through that peer's DNS while connected; everything else keeps using your normal system DNS." />
      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</Window>
