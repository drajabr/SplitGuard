<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:SplitGuard.Views"
        x:Class="SplitGuard.Views.MainWindow"
        Title="SplitGuard"
        Icon="avares://SplitGuard/Assets/app.ico"
        Width="520" Height="700"
        MinWidth="520" MinHeight="420"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        ExtendClientAreaTitleBarHeightHint="46"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        RenderOptions.TextRenderingMode="SubpixelAntialias"
        DragDrop.AllowDrop="True">
  <DockPanel>
    <Border DockPanel.Dock="Top" Padding="12,6,146,6" Name="HeaderBar">
      <!-- Left cluster only; the logo is the menu button. The title/version stay
           non-hit-testable so empty header space still drags the OS window. -->
      <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
        <Button Classes="hdr" Name="LogoButton" Click="OnLogoClick" Padding="3" VerticalAlignment="Center" ToolTip.Tip="Menu">
          <Image Name="LogoImage" Source="avares://SplitGuard/Assets/app.ico" Width="23" Height="23" VerticalAlignment="Center" />
        </Button>
        <TextBlock FontSize="{DynamicResource Fs15}" FontWeight="SemiBold" VerticalAlignment="Center"
                   Text="SplitGuard" IsHitTestVisible="False" />
        <TextBlock Name="VersionLabel" FontSize="{DynamicResource Fs11}" Opacity="0.5"
                   VerticalAlignment="Bottom" Margin="0,0,0,3" IsHitTestVisible="False" />
        <Button Classes="hdr" Name="UpdateButton" Click="OnUpdateClick" VerticalAlignment="Center"
                ToolTip.Tip="{Binding UpdateTooltip}">
          <TextBlock Classes="glyph updicon" Classes.hot="{Binding UpdateHighlight}"
                     Text="{Binding UpdateGlyph}" FontSize="{DynamicResource Fs12}" />
        </Button>
      </StackPanel>
    </Border>

    <Border DockPanel.Dock="Top" Background="{DynamicResource WarningBgBrush}" Padding="14,8" IsVisible="{Binding GpoWarning}">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBlock Classes="glyph" Foreground="{DynamicResource WarningBrush}" Text="&#xE7BA;" VerticalAlignment="Top" />
        <TextBlock FontSize="{DynamicResource Fs12}" TextWrapping="Wrap" VerticalAlignment="Center"
                   Text="Group Policy DNS rules are active on this machine and override local ones — this tool's rules won't take effect." />
      </StackPanel>
    </Border>

    <!-- Persistent bottom bar: DNS + tunnel status on the left, Add on the right. -->
    <Border DockPanel.Dock="Bottom" BorderBrush="{DynamicResource HairlineBrush}" BorderThickness="0,1,0,0" Padding="14,6">
      <DockPanel>
        <Button DockPanel.Dock="Right" Name="AddButton" Classes="hdr" ToolTip.Tip="Add tunnel">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Classes="glyph" Text="&#xE710;" FontSize="{DynamicResource Fs12}" Foreground="{DynamicResource AccentBrush}" />
            <TextBlock Text="Add" VerticalAlignment="Center" FontSize="{DynamicResource Fs12}" />
          </StackPanel>
        </Button>
        <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Panel VerticalAlignment="Center">
              <TextBlock Classes="glyph" Text="&#xE774;" FontSize="{DynamicResource Fs12}" Opacity="0.55"
                         IsVisible="{Binding !DnsPinned}" />
              <TextBlock Classes="glyph" Text="&#xE842;" FontSize="{DynamicResource Fs12}"
                         Foreground="{DynamicResource AccentBrush}" IsVisible="{Binding DnsPinned}" />
            </Panel>
            <TextBlock Text="{Binding DnsStatus}" FontSize="{DynamicResource Fs12}" Opacity="0.85" VerticalAlignment="Center"
                       Classes.accentfg="{Binding DnsPinned}" />
          </StackPanel>
        </StackPanel>
      </DockPanel>
    </Border>

    <Border DockPanel.Dock="Bottom" BorderBrush="{DynamicResource HairlineBrush}" BorderThickness="0,1,0,0" Padding="14,6"
            Classes="statusbar" Classes.shown="{Binding HasStatus}">
      <TextBlock Text="{Binding StatusText}" Classes="oktext" Classes.errtext="{Binding !StatusOk}" />
    </Border>

    <ScrollViewer Name="MainScroll" Focusable="True" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Hidden">
      <StackPanel Margin="14,8,14,12">
        <ItemsControl ItemsSource="{Binding Tunnels}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <views:TunnelCard Margin="0,0,0,10" />
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
        <TextBlock Classes="muted" Margin="2,6" TextWrapping="Wrap"
                   IsVisible="{Binding !Tunnels.Count}"
                   Text="No tunnels yet. Drop a WireGuard .conf file anywhere in this window, or copy a config and press Ctrl+V. Domains you attach to a peer resolve through that peer's DNS while connected; everything else keeps using your normal system DNS." />
      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</Window>
