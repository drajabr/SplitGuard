<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:SplitGuard.Views"
        x:Class="SplitGuard.Views.MainWindow"
        Title="SplitGuard"
        Icon="avares://SplitGuard/Assets/app.ico"
        Width="520" Height="700"
        MinWidth="520" MinHeight="420"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        ExtendClientAreaTitleBarHeightHint="46"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        RenderOptions.TextRenderingMode="SubpixelAntialias"
        DragDrop.AllowDrop="True">
  <DockPanel>
    <Border DockPanel.Dock="Top" Padding="12,4,146,4" Name="HeaderBar" PointerPressed="OnHeaderPressed"
            Background="{DynamicResource HeaderBandBrush}"
            BorderBrush="{DynamicResource HairlineBrush}" BorderThickness="0,0,0,1">
      <!-- Logo (non-hit-testable so empty header space still drags the OS window) + the menu
           bar. The app name lives in the OS title bar / taskbar, not here (keeps the menus
           clear of the caption buttons at the 520px minimum width). -->
      <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
        <Image Name="LogoImage" Source="avares://SplitGuard/Assets/app.ico" Width="27" Height="27"
               VerticalAlignment="Center" IsHitTestVisible="False" />
        <Menu Name="MenuBar" VerticalAlignment="Center">
          <MenuItem Name="TunnelMenu" Header="Tunnel" SubmenuOpened="OnMenuOpening" />
          <MenuItem Name="SettingsMenu" Header="Settings" SubmenuOpened="OnMenuOpening" />
          <MenuItem Name="AppearanceMenu" Header="Appearance" />
          <MenuItem Name="AboutMenu" SubmenuOpened="OnMenuOpening">
            <MenuItem.Header>
              <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                <TextBlock Text="About" VerticalAlignment="Center" />
                <Ellipse Width="6" Height="6" VerticalAlignment="Center"
                         Fill="{DynamicResource AccentBrush}" IsVisible="{Binding UpdateHighlight}" />
              </StackPanel>
            </MenuItem.Header>
          </MenuItem>
        </Menu>
      </StackPanel>
    </Border>

    <Border DockPanel.Dock="Top" Background="{DynamicResource WarningBgBrush}" Padding="14,8" IsVisible="{Binding GpoWarning}">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBlock Classes="glyph" Foreground="{DynamicResource WarningBrush}" Text="&#xE7BA;" VerticalAlignment="Top" />
        <TextBlock FontSize="{DynamicResource Fs12}" TextWrapping="Wrap" VerticalAlignment="Center"
                   Text="Group Policy DNS rules are active on this machine and override local ones — this tool's rules won't take effect." />
      </StackPanel>
    </Border>

    <!-- Transient status bar (connect errors / failover); hidden until an event fires. -->
    <Border DockPanel.Dock="Bottom" BorderBrush="{DynamicResource HairlineBrush}" BorderThickness="0,1,0,0" Padding="14,6"
            Classes="statusbar" Classes.shown="{Binding HasStatus}">
      <TextBlock Text="{Binding StatusText}" Classes="oktext" Classes.errtext="{Binding !StatusOk}" />
    </Border>

    <ScrollViewer Name="MainScroll" Focusable="True" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Hidden">
      <StackPanel Margin="14,8,14,12">
        <ItemsControl ItemsSource="{Binding Tunnels}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <views:TunnelCard Margin="0,0,0,10" />
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
        <TextBlock Classes="muted" Margin="2,6" TextWrapping="Wrap"
                   IsVisible="{Binding !Tunnels.Count}"
                   Text="No tunnels yet. Drop a WireGuard .conf file anywhere in this window, or copy a config and press Ctrl+V. Domains you attach to a peer resolve through that peer's DNS while connected; everything else keeps using your normal system DNS." />
      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</Window>
