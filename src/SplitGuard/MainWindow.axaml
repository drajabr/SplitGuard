<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:SplitGuard.Views"
        x:Class="SplitGuard.Views.MainWindow"
        Title="SplitGuard"
        Icon="avares://SplitGuard/Assets/app.ico"
        Width="820" Height="700"
        MinWidth="660" MinHeight="420"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        ExtendClientAreaTitleBarHeightHint="46"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        RenderOptions.TextRenderingMode="SubpixelAntialias"
        DragDrop.AllowDrop="True">
  <DockPanel>
    <Border DockPanel.Dock="Top" Padding="12,6,146,6" Name="HeaderBar">
      <DockPanel>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
          <Button Classes="hdr" Name="ThemeButton" Click="OnThemeClick" ToolTip.Tip="Theme">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Classes="glyph" Text="&#xE771;" FontSize="{DynamicResource Fs12}" Opacity="0.6" />
              <TextBlock Name="ThemeLabel" FontSize="{DynamicResource Fs115}" Opacity="0.75" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
          <Button Classes="hdr" Name="AccentButton" Click="OnAccentClick" ToolTip.Tip="Accent color">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Ellipse Width="11" Height="11" Fill="{DynamicResource AccentBrush}" VerticalAlignment="Center" />
              <TextBlock Name="AccentLabel" FontSize="{DynamicResource Fs115}" Opacity="0.75" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
          <Button Classes="hdr" Name="FontButton" Click="OnFontClick" ToolTip.Tip="UI font">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Classes="glyph" Text="&#xE8D2;" FontSize="{DynamicResource Fs12}" Opacity="0.6" />
              <TextBlock Name="FontLabel" FontSize="{DynamicResource Fs115}" Opacity="0.75" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
          <Button Classes="hdr" Name="ZoomButton" Click="OnZoomClick" ToolTip.Tip="Zoom">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Classes="glyph" Text="&#xE71E;" FontSize="{DynamicResource Fs12}" Opacity="0.6" />
              <TextBlock Name="ZoomLabel" FontSize="{DynamicResource Fs115}" Opacity="0.75" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
          <Image Name="LogoImage" Source="avares://SplitGuard/Assets/app.ico" Width="17" Height="17"
                 VerticalAlignment="Center" IsHitTestVisible="False" />
          <TextBlock FontSize="{DynamicResource Fs135}" FontWeight="Medium" VerticalAlignment="Center"
                     Text="SplitGuard" IsHitTestVisible="False" />
          <TextBlock Name="VersionLabel" FontSize="{DynamicResource Fs11}" Opacity="0.5"
                     VerticalAlignment="Bottom" Margin="0,0,0,2" IsHitTestVisible="False" />
        </StackPanel>
      </DockPanel>
    </Border>

    <Border DockPanel.Dock="Top" Background="{DynamicResource WarningBgBrush}" Padding="14,8" IsVisible="{Binding GpoWarning}">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBlock Classes="glyph" Foreground="{DynamicResource WarningBrush}" Text="&#xE7BA;" VerticalAlignment="Top" />
        <TextBlock FontSize="{DynamicResource Fs12}" TextWrapping="Wrap" VerticalAlignment="Center"
                   Text="Group Policy DNS rules are active on this machine and override local ones — this tool's rules won't take effect." />
      </StackPanel>
    </Border>

    <Border DockPanel.Dock="Bottom" BorderBrush="{DynamicResource HairlineBrush}" BorderThickness="0,1,0,0" Padding="14,6"
            IsVisible="{Binding HasStatus}">
      <TextBlock Text="{Binding StatusText}" Classes="oktext" Classes.errtext="{Binding !StatusOk}" />
    </Border>

    <Panel>
      <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="14,8,14,64">
          <ItemsControl ItemsSource="{Binding Tunnels}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <views:TunnelCard Margin="0,0,0,10" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <TextBlock Classes="muted" Margin="2,6" TextWrapping="Wrap"
                     IsVisible="{Binding !Tunnels.Count}"
                     Text="No tunnels yet. Drop a WireGuard .conf file anywhere in this window, or copy a config and press Ctrl+V. Domains you attach to a peer resolve through that peer's DNS while connected; everything else keeps using your normal system DNS." />
        </StackPanel>
      </ScrollViewer>

      <!-- Floating Add button (centered at the bottom; opens the add options popover). -->
      <Button Name="AddButton" Classes="addbtn" HorizontalAlignment="Center" VerticalAlignment="Bottom"
              Margin="0,0,0,14" ToolTip.Tip="Add tunnel">
        <StackPanel HorizontalAlignment="Center" Spacing="0">
          <TextBlock Classes="glyph" Text="&#xE710;" FontSize="{DynamicResource Fs17}" HorizontalAlignment="Center"
                     Foreground="{DynamicResource AccentBrush}" />
          <TextBlock Text="Add" FontSize="{DynamicResource Fs11}" Opacity="0.75" HorizontalAlignment="Center" />
        </StackPanel>
      </Button>
    </Panel>
  </DockPanel>
</Window>
