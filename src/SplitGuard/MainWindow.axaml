<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:SplitGuard.Views"
        x:Class="SplitGuard.Views.MainWindow"
        Title="SplitGuard"
        Icon="avares://SplitGuard/Assets/app.ico"
        Width="820" Height="700"
        MinWidth="660" MinHeight="420"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        ExtendClientAreaTitleBarHeightHint="46"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        RenderOptions.TextRenderingMode="SubpixelAntialias"
        DragDrop.AllowDrop="True">
  <DockPanel>
    <Border DockPanel.Dock="Top" Padding="14,8,146,8" Name="HeaderBar">
      <DockPanel>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="4">
          <Button Classes="icon" Name="AddButton" ToolTip.Tip="Add tunnel">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Classes="glyph" Text="&#xE710;" Foreground="{DynamicResource AccentBrush}" />
              <TextBlock FontSize="{DynamicResource Fs115}" Opacity="0.8" VerticalAlignment="Center" Text="Add" />
            </StackPanel>
            <Button.Flyout>
              <MenuFlyout Placement="BottomEdgeAlignedRight" />
            </Button.Flyout>
          </Button>
          <Border Width="1" Background="{DynamicResource HairlineBrush}" Margin="4,4" />
          <Button Classes="icon" Name="ThemeButton" ToolTip.Tip="Theme">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Classes="glyph" Text="&#xE771;" Opacity="0.6" />
              <TextBlock Name="ThemeLabel" Width="52" FontSize="{DynamicResource Fs115}" Opacity="0.7" VerticalAlignment="Center" Text="auto" />
            </StackPanel>
            <Button.Flyout>
              <MenuFlyout Placement="BottomEdgeAlignedRight" />
            </Button.Flyout>
          </Button>
          <Button Classes="icon" Name="AccentButton" ToolTip.Tip="Accent color">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Ellipse Width="11" Height="11" Fill="{DynamicResource AccentBrush}" VerticalAlignment="Center" />
              <TextBlock Name="AccentLabel" Width="52" FontSize="{DynamicResource Fs115}" Opacity="0.7" VerticalAlignment="Center" Text="blue" />
            </StackPanel>
            <Button.Flyout>
              <MenuFlyout Placement="BottomEdgeAlignedRight" />
            </Button.Flyout>
          </Button>
          <Button Classes="icon" Name="FontButton" ToolTip.Tip="UI font">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Classes="glyph" Text="&#xE8D2;" Opacity="0.6" />
              <TextBlock Name="FontLabel" Width="64" FontSize="{DynamicResource Fs115}" Opacity="0.7" VerticalAlignment="Center" Text="segoe" />
            </StackPanel>
            <Button.Flyout>
              <MenuFlyout Placement="BottomEdgeAlignedRight" />
            </Button.Flyout>
          </Button>
          <Button Classes="icon" Name="ZoomButton" ToolTip.Tip="Zoom (fonts and controls)">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Classes="glyph" Text="&#xE71E;" Opacity="0.6" />
              <TextBlock Name="ZoomLabel" Width="36" FontSize="{DynamicResource Fs115}" Opacity="0.7" VerticalAlignment="Center" Text="100%" />
            </StackPanel>
            <Button.Flyout>
              <MenuFlyout Placement="BottomEdgeAlignedRight" />
            </Button.Flyout>
          </Button>
          <Button Classes="icon" Name="SettingsButton" ToolTip.Tip="Settings">
            <TextBlock Classes="glyph" Text="&#xE713;" Opacity="0.6" />
            <Button.Flyout>
              <MenuFlyout Placement="BottomEdgeAlignedRight" />
            </Button.Flyout>
          </Button>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="8" IsHitTestVisible="False">
          <Image Name="LogoImage" Source="avares://SplitGuard/Assets/app.ico" Width="17" Height="17" VerticalAlignment="Center" />
          <TextBlock FontSize="{DynamicResource Fs135}" FontWeight="Medium" VerticalAlignment="Center" Text="SplitGuard" />
          <TextBlock Name="VersionLabel" FontSize="{DynamicResource Fs11}" Opacity="0.5" VerticalAlignment="Bottom" Margin="0,0,0,2" />
        </StackPanel>
      </DockPanel>
    </Border>

    <Border DockPanel.Dock="Top" Background="{DynamicResource WarningBgBrush}" Padding="14,8" IsVisible="{Binding GpoWarning}">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBlock Classes="glyph" Foreground="{DynamicResource WarningBrush}" Text="&#xE7BA;" VerticalAlignment="Top" />
        <TextBlock FontSize="{DynamicResource Fs12}" TextWrapping="Wrap" VerticalAlignment="Center"
                   Text="Group Policy DNS rules are active on this machine and override local ones — this tool's rules won't take effect." />
      </StackPanel>
    </Border>

    <Border DockPanel.Dock="Bottom" BorderBrush="{DynamicResource HairlineBrush}" BorderThickness="0,1,0,0" Padding="14,6"
            IsVisible="{Binding HasStatus}">
      <TextBlock Text="{Binding StatusText}" Classes="oktext" Classes.errtext="{Binding !StatusOk}" />
    </Border>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
      <StackPanel Margin="14,8,14,12">
        <ItemsControl ItemsSource="{Binding Tunnels}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <views:TunnelCard Margin="0,0,0,10" />
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
        <TextBlock Classes="muted" Margin="2,6" TextWrapping="Wrap"
                   IsVisible="{Binding !Tunnels.Count}"
                   Text="No tunnels yet. Drop a WireGuard .conf file anywhere in this window, or copy a config and press Ctrl+V. Domains you attach to a peer resolve through that peer's DNS while connected; everything else keeps using your normal system DNS." />
      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</Window>
