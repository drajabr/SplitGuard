<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="SplitGuard.App"
             RequestedThemeVariant="Default">
  <Application.Resources>
    <x:Double x:Key="DimOpacity">0.68</x:Double>
    <SolidColorBrush x:Key="AccentBrush">#3378DD</SolidColorBrush>
    <SolidColorBrush x:Key="AccentDimBrush">#663378DD</SolidColorBrush>
    <SolidColorBrush x:Key="HairlineBrush">#33808080</SolidColorBrush>
    <SolidColorBrush x:Key="FieldBorderBrush">#40808080</SolidColorBrush>
    <SolidColorBrush x:Key="SynIpBrush">#4098D7</SolidColorBrush>
    <SolidColorBrush x:Key="SynDomainBrush">#58A65C</SolidColorBrush>
    <SolidColorBrush x:Key="SynKeyBrush">#9A6FD0</SolidColorBrush>
    <SolidColorBrush x:Key="SynNumBrush">#C77E16</SolidColorBrush>
  </Application.Resources>
  <Application.Styles>
    <FluentTheme />
    <StyleInclude Source="avares://AvaloniaEdit/Themes/Fluent/AvaloniaEdit.xaml" />
    <StyleInclude Source="avares://SplitGuard/Views/Styles.axaml" />
  </Application.Styles>
</Application>
