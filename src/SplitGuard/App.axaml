<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="SplitGuard.App"
             RequestedThemeVariant="Default">
  <Application.Resources>
    <!-- Icon font for TextBlock.glyph. Windows uses the native Segoe icon fonts; the
         Android head swaps this resource for the bundled SplitGuard Symbols TTF
         (tools/build_symbols.py — open Fluent System Icons remapped to the same
         codepoints), since Segoe Fluent Icons doesn't exist there. -->
    <FontFamily x:Key="GlyphFontFamily">Segoe Fluent Icons, Segoe MDL2 Assets</FontFamily>
    <x:Double x:Key="DimOpacity">0.68</x:Double>
    <x:Double x:Key="Fs9">9</x:Double>
    <x:Double x:Key="Fs11">11</x:Double>
    <x:Double x:Key="Fs115">11.5</x:Double>
    <x:Double x:Key="Fs12">12</x:Double>
    <x:Double x:Key="Fs125">12.5</x:Double>
    <x:Double x:Key="Fs13">13</x:Double>
    <x:Double x:Key="Fs135">13.5</x:Double>
    <x:Double x:Key="Fs14">14</x:Double>
    <x:Double x:Key="Fs15">15</x:Double>
    <x:Double x:Key="Fs17">17</x:Double>
    <x:Double x:Key="CtrlH">26</x:Double>
    <x:Double x:Key="HeaderH">38</x:Double>
    <x:Double x:Key="CollapseH">170</x:Double>
    <SolidColorBrush x:Key="AccentBrush">#3378DD</SolidColorBrush>
    <SolidColorBrush x:Key="AccentTextBrush">#3378DD</SolidColorBrush>
    <SolidColorBrush x:Key="AccentDimBrush">#663378DD</SolidColorBrush>
    <SolidColorBrush x:Key="HairlineBrush">#33808080</SolidColorBrush>
    <SolidColorBrush x:Key="FieldBorderBrush">#40808080</SolidColorBrush>
    <SolidColorBrush x:Key="SurfaceBrush">#00FFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="ItemBrush">#14808080</SolidColorBrush>
    <!-- Syntax palette: must match SplitGuard.Views.Syntax.* constants. -->
    <SolidColorBrush x:Key="SynIpBrush">#4098D7</SolidColorBrush>
    <SolidColorBrush x:Key="SynDomainBrush">#58A65C</SolidColorBrush>
    <SolidColorBrush x:Key="SynKeyBrush">#9A6FD0</SolidColorBrush>
    <SolidColorBrush x:Key="SynNumBrush">#C77E16</SolidColorBrush>
    <!-- Semantic/status roles: one source of truth. -->
    <SolidColorBrush x:Key="DangerBrush">#D14B41</SolidColorBrush>
    <SolidColorBrush x:Key="WarningBrush">#C77E16</SolidColorBrush>
    <SolidColorBrush x:Key="SuccessBrush">#4F9A34</SolidColorBrush>
    <SolidColorBrush x:Key="DotBrush">#8A8A8A</SolidColorBrush>
    <SolidColorBrush x:Key="WarningBgBrush">#22C77E16</SolidColorBrush>
    <SolidColorBrush x:Key="DangerBgBrush">#22D14B41</SolidColorBrush>
    <!-- Faded hairline for separators: transparent at both ends, faint neutral middle —
         quieter and more modern than the flat HairlineBrush. -->
    <LinearGradientBrush x:Key="SeparatorBrush" StartPoint="0%,50%" EndPoint="100%,50%">
      <GradientStop Offset="0" Color="#00808080" />
      <GradientStop Offset="0.15" Color="#30808080" />
      <GradientStop Offset="0.5" Color="#30808080" />
      <GradientStop Offset="0.85" Color="#30808080" />
      <GradientStop Offset="1" Color="#00808080" />
    </LinearGradientBrush>
  </Application.Resources>
  <Application.Styles>
    <FluentTheme />
    <StyleInclude Source="avares://AvaloniaEdit/Themes/Fluent/AvaloniaEdit.xaml" />
    <StyleInclude Source="avares://SplitGuard.Core/Views/Styles.axaml" />
  </Application.Styles>
</Application>
