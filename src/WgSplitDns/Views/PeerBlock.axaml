<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="WgSplitDns.Views.PeerBlock">
  <Border Classes="peerblock" Margin="10,0,10,8">
    <StackPanel>
      <DockPanel Margin="10,6">
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8">
          <TextBlock Classes="muted" Text="{Binding HandshakeText}" IsVisible="{Binding ShowHandshake}" />
          <Button Classes="link danger" Content="Remove peer" Command="{Binding RemovePeerCommand}" IsVisible="{Binding IsEditing}" FontSize="11.5" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBlock FontSize="11.5" FontWeight="Medium" Opacity="0.75" VerticalAlignment="Center" Text="Peer" />
          <TextBlock Classes="mono muted" Text="{Binding KeyShort}" IsVisible="{Binding !IsExternal}" />
          <TextBlock Classes="glyph muted" Text="&#xE72E;" FontSize="11" IsVisible="{Binding HasPsk}" ToolTip.Tip="Preshared key set" />
        </StackPanel>
      </DockPanel>
      <Separator Height="1" Background="#25808080" Margin="0" />

      <Grid Margin="10,8" ColumnDefinitions="80,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">

        <TextBlock Grid.Row="0" Grid.Column="0" Classes="lbl" Text="Endpoint" IsVisible="{Binding !IsExternal}" Margin="0,0,0,6" />
        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" IsVisible="{Binding !IsExternal}" Margin="0,0,0,6">
          <Border Classes="item" IsVisible="{Binding !IsEditing}">
            <TextBlock Classes="mono" Text="{Binding Endpoint}" />
          </Border>
          <TextBox Classes="mono" Width="240" Text="{Binding Endpoint}" IsVisible="{Binding IsEditing}" />
        </StackPanel>

        <TextBlock Grid.Row="1" Grid.Column="0" Classes="lbl" Text="Public key" IsVisible="{Binding IsEditing}" Margin="0,0,0,6" />
        <TextBox Grid.Row="1" Grid.Column="1" Classes="mono" Text="{Binding PublicKey}" IsVisible="{Binding IsEditing}" Margin="0,0,0,6" />

        <TextBlock Grid.Row="2" Grid.Column="0" Classes="lbl" Text="Preshared key" IsVisible="{Binding IsEditing}" Margin="0,0,0,6" />
        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="6" IsVisible="{Binding IsEditing}" Margin="0,0,0,6">
          <TextBox Classes="mono" Width="360" PasswordChar="●" RevealPassword="{Binding #PskEye.IsChecked}" Text="{Binding PresharedKey}" Watermark="optional" />
          <ToggleButton Name="PskEye" Background="Transparent" BorderThickness="0" Padding="4">
            <TextBlock Classes="glyph" Text="&#xE7B3;" FontSize="13" />
          </ToggleButton>
        </StackPanel>

        <TextBlock Grid.Row="3" Grid.Column="0" Classes="lbl" Text="Allowed IPs" IsVisible="{Binding !IsExternal}" Margin="0,0,0,6" />
        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" IsVisible="{Binding !IsExternal}" Margin="0,0,0,6">
          <ItemsControl ItemsSource="{Binding AllowedIps}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Classes="item" Margin="0,0,6,0">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Classes="mono" Text="{Binding}" />
                    <Button Classes="chipx" IsVisible="{Binding $parent[UserControl].DataContext.IsEditing}"
                            Command="{Binding $parent[UserControl].DataContext.RemoveAllowedIpCommand}" CommandParameter="{Binding}">
                      <TextBlock Classes="glyph" Text="&#xE711;" FontSize="9" Opacity="0.6" />
                    </Button>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <TextBox Classes="mono addbox" Classes.error="{Binding AllowedIpAddError}" Watermark="+ add"
                   Text="{Binding NewAllowedIp}" IsVisible="{Binding IsEditing}">
            <TextBox.KeyBindings>
              <KeyBinding Gesture="Enter" Command="{Binding AddAllowedIpCommand}" />
            </TextBox.KeyBindings>
          </TextBox>
        </StackPanel>

        <TextBlock Grid.Row="4" Grid.Column="0" Classes="lbl" Text="DNS" Margin="0,0,0,6" />
        <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,6">
          <Border Classes="item" IsVisible="{Binding !IsEditing}">
            <TextBlock Classes="mono" Text="{Binding Dns}" />
          </Border>
          <TextBox Classes="mono" Width="160" Text="{Binding Dns}" IsVisible="{Binding IsEditing}" Watermark="optional" />
          <Button Classes="icon" Command="{Binding TogglePinCommand}" IsEnabled="{Binding PinEnabled}"
                  IsVisible="{Binding !IsEditing}" ToolTip.Tip="Pin as device-wide DNS">
            <TextBlock Classes="glyph pinicon" Classes.pinned="{Binding IsPinned}" Text="&#xE718;" />
          </Button>
          <TextBlock Classes="accent" Text="{Binding PinCaption}" IsVisible="{Binding !IsEditing}" />
        </StackPanel>

        <TextBlock Grid.Row="5" Grid.Column="0" Classes="lbl" Text="Domains" />
        <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal">
          <ItemsControl ItemsSource="{Binding Domains}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Classes="item" Margin="0,0,6,4">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Classes="mono" Text="{Binding}" />
                    <Button Classes="chipx"
                            Command="{Binding $parent[UserControl].DataContext.RemoveDomainCommand}" CommandParameter="{Binding}">
                      <TextBlock Classes="glyph" Text="&#xE711;" FontSize="9" Opacity="0.6" />
                    </Button>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <TextBox Classes="mono addbox" Classes.error="{Binding DomainAddError}" Watermark="+ add"
                   Text="{Binding NewDomain}">
            <TextBox.KeyBindings>
              <KeyBinding Gesture="Enter" Command="{Binding AddDomainCommand}" />
            </TextBox.KeyBindings>
          </TextBox>
        </StackPanel>
      </Grid>
    </StackPanel>
  </Border>
</UserControl>
