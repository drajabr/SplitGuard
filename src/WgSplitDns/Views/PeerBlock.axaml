<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             xmlns:vm="clr-namespace:WgSplitDns.ViewModels"
             x:Class="WgSplitDns.Views.PeerBlock">
  <Border Classes="peerblock" Margin="8,0,10,6">
    <StackPanel>
      <DockPanel Margin="10,4">
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8">
          <TextBlock Classes="muted" Text="{Binding HandshakeText}" IsVisible="{Binding ShowHandshake}" />
          <Button Classes="link danger" Content="Remove peer" Command="{Binding RemovePeerCommand}" IsVisible="{Binding IsEditing}" FontSize="11.5" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBlock FontSize="11.5" FontWeight="Medium" Opacity="0.75" VerticalAlignment="Center" Text="Peer" />
          <TextBlock Classes="mono muted" Text="{Binding KeyShort}" IsVisible="{Binding !IsExternal}" />
          <TextBlock Classes="glyph muted" Text="&#xE72E;" FontSize="11" IsVisible="{Binding HasPsk}" ToolTip.Tip="Preshared key set" />
        </StackPanel>
      </DockPanel>
      <Separator />

      <Grid Margin="10,6" ColumnDefinitions="80,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">

        <TextBlock Grid.Row="0" Grid.Column="0" Classes="lbl" Text="Endpoint" IsVisible="{Binding !IsExternal}" Margin="0,0,0,4" />
        <Grid Grid.Row="0" Grid.Column="1" ColumnDefinitions="*,Auto" IsVisible="{Binding !IsExternal}" Margin="0,0,0,4">
          <Border Grid.Column="0" Classes="item" HorizontalAlignment="Left" IsVisible="{Binding !IsEditing}">
            <TextBlock Classes="mono" Text="{Binding Endpoint}" />
          </Border>
          <TextBox Grid.Column="0" Classes="mono" Text="{Binding Endpoint}" IsVisible="{Binding IsEditing}" Watermark="host:port" />
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5" Margin="8,0,0,0" IsVisible="{Binding IsEditing}">
            <TextBox Classes="mono" Width="60" Text="{Binding KeepaliveText}" Watermark="off" ToolTip.Tip="Persistent keepalive, seconds" />
            <TextBlock Classes="muted" Text="s keepalive" />
          </StackPanel>
        </Grid>

        <TextBlock Grid.Row="1" Grid.Column="0" Classes="lbl" Text="Keys" IsVisible="{Binding ShowKeysRow}" Margin="0,0,0,4" />
        <Grid Grid.Row="1" Grid.Column="1" ColumnDefinitions="*,8,*,Auto" IsVisible="{Binding ShowKeysRow}" Margin="0,0,0,4">
          <TextBox Grid.Column="0" Classes="mono" Text="{Binding PublicKey}" Watermark="peer public key" />
          <TextBox Grid.Column="2" Classes="mono" PasswordChar="●" RevealPassword="{Binding #PskEye.IsChecked}"
                   Text="{Binding PresharedKey}" Watermark="preshared key (optional)" />
          <ToggleButton Grid.Column="3" Name="PskEye" Background="Transparent" BorderThickness="0" Padding="4">
            <TextBlock Classes="glyph" Text="&#xE7B3;" FontSize="13" />
          </ToggleButton>
        </Grid>

        <TextBlock Grid.Row="2" Grid.Column="0" Classes="lbl" Text="Allowed IPs" IsVisible="{Binding !IsExternal}" Margin="0,0,0,4" />
        <ItemsControl Grid.Row="2" Grid.Column="1" ItemsSource="{Binding AllowedIps}" IsVisible="{Binding !IsExternal}" Margin="0,0,0,4">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.DataTemplates>
            <DataTemplate DataType="sys:String">
              <Border Classes="item" Margin="0,0,6,4">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Classes="mono" Text="{Binding}" />
                  <Button Classes="chipx" IsVisible="{Binding $parent[ItemsControl].DataContext.IsEditing}"
                          Command="{Binding $parent[ItemsControl].DataContext.RemoveAllowedIpCommand}" CommandParameter="{Binding}">
                    <TextBlock Classes="glyph" Text="&#xE711;" FontSize="9" Opacity="0.6" />
                  </Button>
                </StackPanel>
              </Border>
            </DataTemplate>
            <DataTemplate DataType="vm:AddSlot">
              <TextBox Classes="mono addbox" Margin="0,0,6,4" Watermark="+"
                       Classes.error="{Binding $parent[ItemsControl].DataContext.AllowedIpAddError}"
                       Text="{Binding $parent[ItemsControl].DataContext.NewAllowedIp}"
                       IsVisible="{Binding $parent[ItemsControl].DataContext.IsEditing}">
                <TextBox.KeyBindings>
                  <KeyBinding Gesture="Enter" Command="{Binding $parent[ItemsControl].DataContext.AddAllowedIpCommand}" />
                </TextBox.KeyBindings>
              </TextBox>
            </DataTemplate>
          </ItemsControl.DataTemplates>
        </ItemsControl>

        <TextBlock Grid.Row="3" Grid.Column="0" Classes="lbl" Text="DNS" Margin="0,0,0,4" />
        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,4">
          <Border Classes="item" IsVisible="{Binding !IsEditing}">
            <TextBlock Classes="mono" Text="{Binding Dns}" />
          </Border>
          <TextBox Classes="mono" Width="160" Text="{Binding Dns}" IsVisible="{Binding IsEditing}" Watermark="optional" />
          <Button Classes="icon" Command="{Binding TogglePinCommand}" IsEnabled="{Binding PinEnabled}"
                  IsVisible="{Binding !IsEditing}" ToolTip.Tip="Pin as device-wide DNS">
            <TextBlock Classes="glyph pinicon" Classes.pinned="{Binding IsPinned}" Text="&#xE718;" />
          </Button>
          <TextBlock Classes="accent" Text="{Binding PinCaption}" IsVisible="{Binding !IsEditing}" />
        </StackPanel>

        <TextBlock Grid.Row="4" Grid.Column="0" Classes="lbl" Text="Domains" />
        <ItemsControl Grid.Row="4" Grid.Column="1" ItemsSource="{Binding Domains}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.DataTemplates>
            <DataTemplate DataType="sys:String">
              <Border Classes="item" Margin="0,0,6,4">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Classes="mono" Text="{Binding}" />
                  <Button Classes="chipx" IsVisible="{Binding $parent[ItemsControl].DataContext.IsEditing}"
                          Command="{Binding $parent[ItemsControl].DataContext.RemoveDomainCommand}" CommandParameter="{Binding}">
                    <TextBlock Classes="glyph" Text="&#xE711;" FontSize="9" Opacity="0.6" />
                  </Button>
                </StackPanel>
              </Border>
            </DataTemplate>
            <DataTemplate DataType="vm:AddSlot">
              <TextBox Classes="mono addbox" Margin="0,0,6,4" Watermark="+"
                       Classes.error="{Binding $parent[ItemsControl].DataContext.DomainAddError}"
                       Text="{Binding $parent[ItemsControl].DataContext.NewDomain}"
                       IsVisible="{Binding $parent[ItemsControl].DataContext.IsEditing}">
                <TextBox.KeyBindings>
                  <KeyBinding Gesture="Enter" Command="{Binding $parent[ItemsControl].DataContext.AddDomainCommand}" />
                </TextBox.KeyBindings>
              </TextBox>
            </DataTemplate>
          </ItemsControl.DataTemplates>
        </ItemsControl>
      </Grid>
    </StackPanel>
  </Border>
</UserControl>
