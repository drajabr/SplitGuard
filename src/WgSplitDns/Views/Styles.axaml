<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Style Selector="TextBox">
    <Setter Property="MinHeight" Value="26" />
    <Setter Property="Padding" Value="8,3" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>
  <Style Selector="TextBox.mono">
    <Setter Property="FontFamily" Value="Consolas,Courier New,monospace" />
    <Setter Property="FontSize" Value="12" />
  </Style>
  <Style Selector="TextBox.error">
    <Setter Property="BorderBrush" Value="#C42B1C" />
  </Style>
  <Style Selector="TextBox.addbox">
    <Setter Property="MinWidth" Value="72" />
    <Setter Property="Height" Value="26" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="#38808080" />
  </Style>

  <Style Selector="Button">
    <Setter Property="MinHeight" Value="26" />
    <Setter Property="Padding" Value="10,3" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="Button.icon">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="4" />
    <Setter Property="MinHeight" Value="0" />
  </Style>
  <Style Selector="Button.chipx">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="1" />
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="Button.link">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="4,2" />
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="Foreground" Value="#3378DD" />
  </Style>
  <Style Selector="Button.danger">
    <Setter Property="Foreground" Value="#C42B1C" />
  </Style>
  <Style Selector="Button.primary">
    <Setter Property="Background" Value="#3378DD" />
    <Setter Property="Foreground" Value="White" />
  </Style>

  <Style Selector="Border.card">
    <Setter Property="BorderBrush" Value="#26808080" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="4" />
  </Style>
  <Style Selector="Border.card.editing">
    <Setter Property="BorderBrush" Value="#663378DD" />
  </Style>
  <Style Selector="Border.item">
    <Setter Property="Background" Value="#12808080" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Padding" Value="8,0" />
    <Setter Property="Height" Value="26" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="Border.item > StackPanel">
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="Border.item > TextBlock">
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="Border.peerblock">
    <Setter Property="BorderBrush" Value="#20808080" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="4" />
  </Style>

  <Style Selector="TextBlock.lbl">
    <Setter Property="FontSize" Value="11.5" />
    <Setter Property="Opacity" Value="0.55" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="TextBlock.mono">
    <Setter Property="FontFamily" Value="Consolas,Courier New,monospace" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="TextBlock.muted">
    <Setter Property="FontSize" Value="12" />
    <Setter Property="Opacity" Value="0.55" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="TextBlock.glyph">
    <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="TextBlock.pinicon">
    <Setter Property="Opacity" Value="0.45" />
  </Style>
  <Style Selector="TextBlock.pinicon.pinned">
    <Setter Property="Foreground" Value="#3378DD" />
    <Setter Property="Opacity" Value="1" />
  </Style>
  <Style Selector="TextBlock.accent">
    <Setter Property="Foreground" Value="#3378DD" />
    <Setter Property="FontSize" Value="11.5" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="TextBlock.errtext">
    <Setter Property="Foreground" Value="#C42B1C" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>
  <Style Selector="TextBlock.warntext">
    <Setter Property="Foreground" Value="#B25E09" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>
  <Style Selector="TextBlock.oktext">
    <Setter Property="Foreground" Value="#2E7D32" />
    <Setter Property="FontSize" Value="12" />
  </Style>

  <Style Selector="Ellipse.dot">
    <Setter Property="Width" Value="8" />
    <Setter Property="Height" Value="8" />
    <Setter Property="Fill" Value="#888888" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="Ellipse.dot.up">
    <Setter Property="Fill" Value="#639922" />
  </Style>

  <Style Selector="ToggleSwitch">
    <Setter Property="OnContent" Value="{x:Null}" />
    <Setter Property="OffContent" Value="{x:Null}" />
    <Setter Property="MinWidth" Value="0" />
  </Style>
  <Style Selector="Separator">
    <Setter Property="Background" Value="#1E808080" />
    <Setter Property="Height" Value="1" />
    <Setter Property="Margin" Value="0" />
  </Style>
</Styles>
