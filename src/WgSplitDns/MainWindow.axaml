<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:WgSplitDns.Views"
        x:Class="WgSplitDns.Views.MainWindow"
        Title="WG Split DNS"
        Width="780" Height="720"
        MinWidth="620" MinHeight="420">
  <DockPanel>
    <Border DockPanel.Dock="Top" BorderBrush="#25808080" BorderThickness="0,0,0,1" Padding="14,10">
      <DockPanel>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
          <Button Content="Add tunnel">
            <Button.Flyout>
              <MenuFlyout>
                <MenuItem Header="Import .conf file…" Command="{Binding ImportFileCommand}" />
                <MenuItem Header="Paste config…" Command="{Binding PasteConfigCommand}" />
              </MenuFlyout>
            </Button.Flyout>
          </Button>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="10">
          <TextBlock Classes="glyph" Text="&#xE968;" Foreground="#3378DD" FontSize="17" />
          <TextBlock FontSize="14" FontWeight="Medium" VerticalAlignment="Center" Text="WG Split DNS" />
        </StackPanel>
      </DockPanel>
    </Border>

    <Border DockPanel.Dock="Top" Background="#2ED83B01" Padding="14,8" IsVisible="{Binding GpoWarning}">
      <TextBlock FontSize="12" TextWrapping="Wrap"
                 Text="Group Policy DNS rules are active on this machine and override local ones — this tool's rules won't take effect." />
    </Border>

    <Border DockPanel.Dock="Bottom" BorderBrush="#25808080" BorderThickness="0,1,0,0" Padding="14,10">
      <StackPanel Spacing="6">
        <Grid ColumnDefinitions="Auto,8,2*,8,*,8,Auto">
          <TextBlock Grid.Column="0" Classes="glyph" Text="&#xEA37;" Opacity="0.55" />
          <TextBox Grid.Column="2" Classes="mono" Text="{Binding TestHost}" Watermark="hostname to resolve">
            <TextBox.KeyBindings>
              <KeyBinding Gesture="Enter" Command="{Binding TestCommand}" />
            </TextBox.KeyBindings>
          </TextBox>
          <ComboBox Grid.Column="4" ItemsSource="{Binding TestTargets}" SelectedItem="{Binding SelectedTestTarget}"
                    HorizontalAlignment="Stretch" FontSize="12" />
          <Button Grid.Column="6" Content="Test" Command="{Binding TestCommand}" />
        </Grid>
        <TextBlock Margin="24,0,0,0" Text="{Binding TestResult}" IsVisible="{Binding HasTestResult}"
                   Classes="oktext" Classes.errtext="{Binding !TestOk}" />
      </StackPanel>
    </Border>

    <ScrollViewer>
      <StackPanel Margin="14,12">
        <ItemsControl ItemsSource="{Binding Tunnels}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <views:TunnelCard Margin="0,0,0,10" />
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
        <TextBlock Classes="muted" Margin="2,6" TextWrapping="Wrap"
                   IsVisible="{Binding !Tunnels.Count}"
                   Text="No tunnels yet. Use 'Add tunnel' to import a WireGuard .conf file or paste a config. Domains you attach to a peer resolve through that peer's DNS while connected; everything else keeps using your normal system DNS." />
      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</Window>
